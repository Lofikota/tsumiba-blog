{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "pubDate": {
      "type": "string",
      "format": "date-time"
    },
    "updatedDate": {
      "type": "string",
      "format": "date-time"
    },
    "category": {
      "type": "string"
    },
    "tags": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "heroImage": {
      "type": "string"
    },
    "affiliate": {
      "default": true,
      "type": "boolean"
    },
    "articleType": {
      "type": "string",
      "enum": [
        "review",
        "guide",
        "comparison",
        "news"
      ]
    },
    "rating": {
      "type": "number",
      "minimum": 1,
      "maximum": 5
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "description",
    "pubDate",
    "category"
  ]
}