# 1Password secret reference template for tsumiba-blog.
# Copy to .env.1password, adjust item names, then run with:
# op run --env-file .env.1password -- npm run dev

X_API_KEY=op://Affiliate/X API/API Key
X_API_SECRET=op://Affiliate/X API/API Secret
X_ACCESS_TOKEN=op://Affiliate/X API/Access Token
X_ACCESS_TOKEN_SECRET=op://Affiliate/X API/Access Token Secret
PUBLIC_LINE_HARNESS_AUTH_BASE_URL=op://Private/LINE Harness/auth_base_url
# Google Ads / GA4 の Google tag ID を入れる
# 1Password item 例: Affiliate / ren-blog env / PUBLIC_GOOGLE_TAG_ID
PUBLIC_GOOGLE_TAG_ID=op://Affiliate/ren-blog env/notesPlain
PUBLIC_GOOGLE_ADS_CONVERSION_SEND_TO=

# 記事画像生成（OpenAI Image API）
OPENAI_API_KEY=op://Affiliate/OpenAI/API Key
OPENAI_IMAGE_MODEL=gpt-image-1.5
OPENAI_IMAGE_SIZE=1536x1024
OPENAI_IMAGE_QUALITY=high
