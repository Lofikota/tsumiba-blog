---
interface Props {
  heading?: string;
  lead?: string;
}

const {
  heading = 'まず2口座を比較する',
  lead = 'FX口座はJFXとFXTFを優先して確認してください。JFXは取引機能・MT4重視、FXTFはコスト・商品幅重視と特性が異なります。',
} = Astro.props;
---

<section class="fx-priority" aria-label="FX口座の優先確認リンク">
  <p class="fx-priority-kicker">PR</p>
  <h2>{heading}</h2>
  <p class="fx-priority-lead">{lead}</p>
  <div class="fx-priority-grid fx-priority-grid-2">
    <a href="/go/jfx/" class="fx-priority-card fx-priority-main" data-google-event="affiliate_click" data-google-category="affiliate" data-google-label="fx-priority-jfx">
      <span class="fx-priority-rank">1</span>
      <strong>JFX</strong>
      <small>オリコン顧客満足度FX総合1位。MT4対応・約定力重視の短期売買に強い。</small>
    </a>
    <a href="/go/fxtf/" class="fx-priority-card" data-google-event="affiliate_click" data-google-category="affiliate" data-google-label="fx-priority-fxtf">
      <span class="fx-priority-rank">2</span>
      <strong>FXTF</strong>
      <small>ゼロスプ・CFD・ノックアウトオプションまで扱える。コストと商品幅を細かく見たい人向け。</small>
    </a>
  </div>
  <p class="fx-priority-note">FXは元本割れや預け入れた資金を上回る損失が発生するリスクがあります。申込前に必ず公式条件を確認してください。</p>
</section>

<style>
  .fx-priority {
    margin: 1.75rem 0 2rem;
    padding: 18px;
    border: 1px solid #bfdbfe;
    border-radius: 10px;
    background: #eff6ff;
  }
  .fx-priority-kicker {
    margin: 0 0 6px;
    color: #1d4ed8;
    font-size: 12px;
    font-weight: 800;
  }
  .fx-priority h2 {
    margin: 0 0 8px;
    font-size: 20px;
    line-height: 1.45;
  }
  .fx-priority-lead {
    margin: 0 0 14px;
    color: #334155;
    font-size: 14px;
    line-height: 1.8;
  }
  .fx-priority-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 10px;
  }
  .fx-priority-grid-2 {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
  .fx-priority-card {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 4px 8px;
    align-items: center;
    min-height: 112px;
    padding: 13px;
    border: 1px solid #dbeafe;
    border-radius: 8px;
    background: #fff;
    color: #0f172a;
    text-decoration: none;
  }
  .fx-priority-main {
    border-color: #2563eb;
    box-shadow: 0 8px 22px rgba(37, 99, 235, 0.14);
  }
  .fx-priority-muted {
    background: #f8fafc;
  }
  .fx-priority-rank {
    display: inline-grid;
    place-items: center;
    min-width: 26px;
    height: 26px;
    padding: 0 8px;
    border-radius: 999px;
    background: #2563eb;
    color: #fff;
    font-size: 13px;
    font-weight: 800;
  }
  .fx-priority-card strong {
    font-size: 15px;
  }
  .fx-priority-card small {
    grid-column: 1 / -1;
    color: #475569;
    font-size: 12px;
    line-height: 1.6;
  }
  .fx-priority-note {
    margin: 12px 0 0;
    color: #64748b;
    font-size: 12px;
    line-height: 1.7;
  }
  @media (max-width: 720px) {
    .fx-priority-grid,
    .fx-priority-grid-2 {
      grid-template-columns: 1fr;
    }
    .fx-priority-card {
      min-height: auto;
    }
  }
</style>
