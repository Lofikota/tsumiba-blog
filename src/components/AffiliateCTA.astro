---
import { getAffiliatePath } from '../data/affiliateLinks';

interface Props {
  href?: string;
  product?: string;
  text: string;
  label?: string;
  color?: 'blue' | 'green' | 'orange' | 'red';
  note?: string;
  badge?: string;
  compact?: boolean;
  external?: boolean;
}

const { href, product, text = '公式サイトで確認する', label = 'PR', color = 'blue', note, badge, compact = false, external = true } = Astro.props;
const isStoppedDmmFx = product === 'dmm-fx';
const ctaHref = isStoppedDmmFx ? getAffiliatePath('jfx') : product ? getAffiliatePath(product) : href ?? '#';
const ctaText = isStoppedDmmFx ? 'JFXの公式条件を確認する（DMM FXはリンク確認中）' : text;
const ctaLabel = isStoppedDmmFx ? 'dmm-fx:reroute-jfx' : product ?? href ?? text;

const colorMap: Record<string, string> = {
  blue:   'background:#2563EB;',
  green:  'background:#16A34A;',
  orange: 'background:#D97706;',
  red:    'background:#DC2626;',
};
const bg = colorMap[color] ?? colorMap.blue;
---

<div class={`acta-wrap${compact ? ' acta-wrap-compact' : ''}`}>
  {badge && <div class={`acta-badge${compact ? ' acta-badge-compact' : ''}`}>{badge}</div>}
  {note && <p class={`acta-note${compact ? ' acta-note-compact' : ''}`}>{note}</p>}
  <a href={ctaHref} {...(external ? { target: '_blank', rel: 'noopener noreferrer sponsored nofollow' } : {})}
     data-google-event="affiliate_click"
     data-google-category="affiliate"
     data-google-label={ctaLabel}
     class={`acta-btn${compact ? ' acta-btn-compact' : ''}`} style={bg}>
    <span class="acta-arrow">→</span>
    {ctaText}
  </a>
  <p class={`acta-sub${compact ? ' acta-sub-compact' : ''}`}><span class={`acta-pr${compact ? ' acta-pr-compact' : ''}`}>{label}</span> {isStoppedDmmFx ? '確認済みの公式サイトへ移動します' : '公式サイトへ移動します'}</p>
</div>

<style>
.acta-wrap {
  margin: 2rem 0;
  text-align: center;
  background: #f9fafb;
  border: 1.5px solid #d1d5db;
  border-radius: 14px;
  padding: 24px 24px 18px;
  box-shadow: 0 2px 12px rgba(0,0,0,.07);
}
.acta-wrap-compact {
  margin: 1rem 0;
  padding: 18px 18px 14px;
}
.acta-badge {
  display: inline-block;
  background: #1e293b; color: #fff;
  font-size: 11px; font-weight: 700;
  padding: 3px 12px; border-radius: 999px;
  margin-bottom: 12px; letter-spacing: .05em;
}
.acta-badge-compact {
  margin-bottom: 8px;
}
.acta-note {
  font-size: 13px; color: #374151;
  margin-bottom: 16px; line-height: 1.7;
}
.acta-note-compact {
  font-size: 12px;
  margin-bottom: 10px;
}
.acta-btn {
  display: flex; align-items: center; justify-content: center; gap: 10px;
  width: 100%;
  color: #fff; font-size: 17px; font-weight: 800;
  padding: 17px 24px; border-radius: 10px;
  text-decoration: none; letter-spacing: .03em;
  transition: filter .15s, transform .1s;
  box-shadow: 0 4px 16px rgba(0,0,0,.2);
}
.acta-btn-compact {
  font-size: 15px;
  padding: 14px 18px;
}
.acta-btn:hover { filter: brightness(1.08); transform: translateY(-2px); }
.acta-arrow { font-size: 20px; }
.acta-sub {
  font-size: 11px; color: #6B7280;
  margin-top: 12px;
}
.acta-sub-compact {
  margin-top: 8px;
}
.acta-pr {
  background: #e5e7eb; color: #374151;
  font-size: 10px; font-weight: 700;
  padding: 1px 6px; border-radius: 3px;
  margin-right: 4px;
}
.acta-pr-compact { font-size: 9px; }
</style>
