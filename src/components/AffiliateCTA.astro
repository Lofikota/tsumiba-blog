---
import { getAffiliatePath } from '../data/affiliateLinks';

interface Props {
  href?: string;
  product?: string;
  text: string;
  label?: string;
  color?: 'blue' | 'green' | 'orange' | 'red';
  note?: string;
}

const { href, product, text, label = 'PR', color = 'blue', note } = Astro.props;
const ctaHref = product ? getAffiliatePath(product) : href ?? '#';
---

<div style="text-align:center;margin:1.75rem 0;">
  {note && <p style="font-size:0.85rem;color:var(--color-text-muted);margin-bottom:0.6rem;">{note}</p>}
  <a href={ctaHref} target="_blank" rel="noopener noreferrer sponsored nofollow" class={`cta-button ${color}`}>
    {text}
  </a>
  <p style="font-size:0.75rem;color:var(--color-text-muted);margin-top:0.4rem;">{label} ・ 公式サイトへ移動します</p>
</div>
