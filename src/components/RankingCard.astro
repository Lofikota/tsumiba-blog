---
interface Bar {
  label: string;
  pct: number;
}
interface Spec {
  v: string;
  k: string;
}
interface Props {
  rank: number;
  name: string;
  initial: string;
  catch: string;
  rating: number;
  bars: Bar[];
  specs?: Spec[];
  href: string;
  reviewHref?: string;
  score?: number;
  comment?: string;
  ctaText?: string;
  featured?: boolean;
  trackLabel?: string;
}

const {
  rank,
  name,
  initial,
  catch: catchCopy,
  rating,
  bars,
  specs = [],
  href,
  reviewHref,
  score,
  comment,
  ctaText = '公式サイトで口座開設（無料）',
  featured = false,
  trackLabel = name,
} = Astro.props;

const fullStars = Math.round(rating);
---

<article class={`rc${featured ? ' rc-featured' : ''}`}>
  {featured && (
    <span class="rc-ribbon">
      <span class="rc-crown">♛</span> 編集部イチ押し
    </span>
  )}
  <header class="rc-head">
    <span class="rc-rank">{rank}</span>
    <span class="rc-logo">{initial}</span>
    <div class="rc-id">
      <strong>{name}</strong>
      <small>{catchCopy}</small>
    </div>
    <div class="rc-rate">
      {score !== undefined && <span class="rc-score">{score}<small>点</small></span>}
      <span class="rc-stars" aria-hidden="true">{'★'.repeat(fullStars)}{'☆'.repeat(5 - fullStars)}</span>
      <span class="rc-rate-num">総合 {rating.toFixed(1)}</span>
    </div>
  </header>

  <div class="rc-bars">
    {bars.map((b) => (
      <div class="rc-bar">
        <span class="rc-bar-label">{b.label}</span>
        <span class="rc-track"><span class="rc-fill" style={`width:${b.pct}%`}></span></span>
      </div>
    ))}
  </div>

  {specs.length > 0 && (
    <div class="rc-specs">
      {specs.map((s) => (
        <div class="rc-spec">
          <span class="rc-spec-v">{s.v}</span>
          <span class="rc-spec-k">{s.k}</span>
        </div>
      ))}
    </div>
  )}

  {comment && (
    <p class="rc-comment"><span class="rc-comment-by">編集部</span>{comment}</p>
  )}

  <div class="rc-actions">
    <a
      href={href}
      class="rc-cta"
      data-google-event="affiliate_click"
      data-google-category="affiliate"
      data-google-label={`fx-ranking-${trackLabel}`}
    >公式サイト{featured ? 'で口座開設（無料）' : ''}</a>
    {reviewHref && <a href={reviewHref} class="rc-review">詳細レビュー</a>}
  </div>
</article>

<style>
  .rc {
    background: #fff;
    border: 1px solid #E5E7EB;
    border-radius: 13px;
    padding: 16px;
    position: relative;
  }
  .rc-featured {
    border: 2px solid #1B3A5B;
    margin-top: 12px;
  }
  .rc-ribbon {
    position: absolute;
    top: -12px;
    left: 16px;
    display: inline-flex;
    align-items: center;
    gap: 5px;
    background: #1B3A5B;
    color: #fff;
    font-size: 11px;
    font-weight: 700;
    padding: 3px 11px;
    border-radius: 7px;
  }
  .rc-crown { color: #E0A458; }
  .rc-head {
    display: flex;
    align-items: center;
    gap: 12px;
    margin: 4px 0 12px;
  }
  .rc-rank {
    display: inline-grid;
    place-items: center;
    min-width: 26px;
    height: 26px;
    border-radius: 999px;
    background: #1B3A5B;
    color: #fff;
    font-size: 13px;
    font-weight: 700;
  }
  .rc-logo {
    width: 42px;
    height: 42px;
    border-radius: 11px;
    background: #1B3A5B;
    color: #fff;
    display: grid;
    place-items: center;
    font-size: 15px;
    font-weight: 700;
  }
  .rc-id { flex: 1; }
  .rc-id strong { display: block; font-size: 16px; color: #1B3A5B; }
  .rc-id small { color: #6b7280; font-size: 12px; }
  .rc-rate { text-align: right; }
  .rc-stars { color: #E0A458; font-size: 13px; letter-spacing: -1px; }
  .rc-rate-num { display: block; font-size: 11px; font-weight: 500; color: #6b7280; }
  .rc-score { display: block; font-size: 23px; font-weight: 700; color: #1B3A5B; line-height: 1.1; }
  .rc-score small { font-size: 11px; font-weight: 500; color: #6b7280; }
  .rc-comment {
    font-size: 12px;
    color: #374151;
    border: 1px solid #E5E7EB;
    border-left: 3px solid #1B3A5B;
    padding: 8px 11px;
    margin: 0 0 12px;
    line-height: 1.7;
    background: #fff;
  }
  .rc-comment-by { font-weight: 700; color: #1B3A5B; margin-right: 6px; }
  .rc-bars { margin-bottom: 12px; }
  .rc-bar { display: flex; align-items: center; gap: 8px; margin: 5px 0; }
  .rc-bar-label { font-size: 11px; color: #6b7280; width: 56px; }
  .rc-track { flex: 1; height: 7px; background: #F0F1F3; border-radius: 4px; overflow: hidden; }
  .rc-fill { display: block; height: 100%; background: #1B3A5B; border-radius: 4px; }
  .rc-specs {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 9px;
    margin-bottom: 12px;
  }
  .rc-spec {
    border: 1px solid #E5E7EB;
    border-radius: 9px;
    padding: 7px 6px;
    text-align: center;
  }
  .rc-spec-v { display: block; font-size: 15px; font-weight: 700; color: #1B3A5B; }
  .rc-spec-k { font-size: 10px; color: #6b7280; }
  .rc-actions { display: flex; align-items: center; gap: 12px; }
  .rc-cta {
    flex: 1;
    text-align: center;
    background: #E0A458;
    color: #412402;
    font-weight: 700;
    padding: 11px;
    border-radius: 9px;
    font-size: 14px;
    text-decoration: none;
  }
  .rc-review { color: #1B3A5B; font-size: 12px; white-space: nowrap; text-decoration: none; }
  @media (max-width: 600px) {
    .rc-actions { flex-direction: column; align-items: stretch; }
    .rc-review { text-align: center; }
  }
</style>
