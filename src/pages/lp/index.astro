---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
const siteUrl = 'https://ren-money.com';
const allPosts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const featuredSlugs = [
  'fx-kouza-hikaku',
  'fx-small-start-guide',
  'fx-company-barenai',
  'fx-shoshinsha-guide',
  'jfx-review',
  'fxtf-review',
];
const featuredPosts: CollectionEntry<'blog'>[] = featuredSlugs
  .map((slug) => allPosts.find((post) => post.id === slug))
  .filter((post): post is CollectionEntry<'blog'> => Boolean(post));
const googleTagId = import.meta.env.PUBLIC_GOOGLE_TAG_ID ?? import.meta.env.PUBLIC_GA_ID ?? 'AW-17326430733';
const googleAdsConversionSendTo = import.meta.env.PUBLIC_GOOGLE_ADS_CONVERSION_SEND_TO ?? '';
type CatStyle = { cls: string; bg: string };
const catStyle: Record<string, CatStyle> = {
  '副業・節税': { cls: 'cat-income',  bg: 'linear-gradient(135deg,#D4EDDA,#86EFAC)' },
  'お得情報':   { cls: 'cat-savings', bg: 'linear-gradient(135deg,#FEF3C7,#FDE68A)' },
  'FX・外貨':   { cls: 'cat-debt',    bg: 'linear-gradient(135deg,#FFE4E6,#FCA5A5)' },
};
---
<!doctype html>
<html lang="ja">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width,initial-scale=1"/>
  <title>やさしいFXの教室 | FX口座選びで失敗しない順番をLINEで無料整理。</title>
  <meta name="description" content="FXを何から始めればいいか分からない人へ。tsumibaが口座選びで失敗しないための順番をLINEで無料で整理します。勧誘なし・3分で登録完了・いつでも退会OK。"/>
  <meta name="robots" content="index,follow"/>
  <link rel="canonical" href={`${siteUrl}/lp/`}/>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700;900&family=Noto+Serif+JP:wght@700;900&display=swap" rel="stylesheet"/>

  {googleTagId && (
    <>
      <script async src={`https://www.googletagmanager.com/gtag/js?id=${googleTagId}`}></script>
      <script is:inline define:vars={{ googleTagId, googleAdsConversionSendTo }}>
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        window.gtag = window.gtag || gtag;
        gtag('js', new Date());
        gtag('config', googleTagId);

        document.addEventListener('click', (event) => {
          const target = event.target;
          if (!(target instanceof Element)) return;
          const anchor = target.closest('a[data-google-event]');
          if (!anchor || !window.gtag) return;
          const eventName = anchor.getAttribute('data-google-event') || 'click';
          const label = anchor.getAttribute('data-google-label') || anchor.textContent?.trim().replace(/\s+/g, ' ').slice(0, 80) || '';
          window.gtag('event', eventName, {
            event_category: anchor.getAttribute('data-google-category') || 'engagement',
            event_label: label,
            link_url: anchor.getAttribute('href') || '',
            page_path: window.location.pathname,
            lp_variant: 'money_anxiety_to_line_v1',
          });
          if (googleAdsConversionSendTo && ['affiliate_click', 'line_click', 'line_add_click', 'lp_line_cta_click'].includes(eventName)) {
            window.gtag('event', 'conversion', {
              send_to: googleAdsConversionSendTo,
              event_category: anchor.getAttribute('data-google-category') || 'engagement',
              event_label: label,
              link_url: anchor.getAttribute('href') || '',
              page_path: window.location.pathname,
              lp_variant: 'money_anxiety_to_line_v1',
            });
          }
        }, true);
      </script>
    </>
  )}

  <style>
  /* ═══════════════════════════════════════
     DESIGN TOKENS — Money Journal Tokyo
  ═══════════════════════════════════════ */
  :root {
    /* Core palette */
    --ink:        #0A0A0A;
    --paper:      #F6F3EC;
    --navy:       #0B1942;
    --navy-mid:   #162254;
    --amber:      #B8780E;
    --amber-warm: #E8940F;
    --amber-pale: #FEF3D0;
    --rust:       #C0392B;
    --sage:       #1E6B45;
    --sage-pale:  #D4EDDA;
    --white:      #FFFFFF;
    --cream:      #FBF8F2;
    --mist:       #EEF1F7;
    --border:     #D9D4CA;
    --gray:       #6B6560;
    --gray-light: #F0EDE8;

    /* Typography */
    --serif: "Noto Serif JP", "Hiragino Mincho ProN", serif;
    --sans:  "Noto Sans JP", "Hiragino Kaku Gothic ProN", sans-serif;

    /* Radii */
    --r-xs: 3px;
    --r-sm: 6px;
    --r-md: 10px;
    --r-lg: 16px;
    --r-pill: 999px;

    /* Shadows */
    --sh-sm: 0 1px 3px rgba(10,10,10,.08), 0 4px 10px rgba(10,10,10,.06);
    --sh-md: 0 4px 16px rgba(10,10,10,.10), 0 12px 32px rgba(10,10,10,.06);
    --sh-amber: 0 4px 20px rgba(184,120,14,.30);
  }

  /* ── Reset ── */
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }
  body {
    font-family: var(--sans);
    color: var(--ink);
    background: var(--white);
    font-size: 15px;
    line-height: 1.75;
    -webkit-font-smoothing: antialiased;
    overflow-x: hidden;
  }
  img { max-width: 100%; display: block; }
  a   { color: inherit; text-decoration: none; }
  button { font-family: inherit; cursor: pointer; border: none; background: none; }

  /* ── Layout ── */
  .container { max-width: 1080px; margin: 0 auto; padding: 0 28px; }
  .container--narrow { max-width: 780px; margin: 0 auto; padding: 0 28px; }
  .section { padding: 72px 0; }
  .section--tint { background: var(--cream); }
  .section--dark  { background: var(--navy); color: #fff; }
  .section--paper { background: var(--paper); }

  /* ── Editorial heading ── */
  .editorial-label {
    display: inline-flex; align-items: center; gap: 10px;
    font-size: 11px; font-weight: 700; letter-spacing: .18em;
    text-transform: uppercase; color: var(--amber);
  }
  .editorial-label::before,
  .editorial-label::after {
    content: ''; display: block;
    width: 24px; height: 1px; background: var(--amber);
  }
  .section-title {
    font-family: var(--serif);
    font-size: clamp(22px, 3.5vw, 30px);
    font-weight: 900; line-height: 1.35;
    margin-top: 10px;
  }
  .section-sub {
    margin-top: 8px;
    color: var(--gray);
    font-size: 13.5px;
    line-height: 1.8;
  }
  .section-head { text-align: center; margin-bottom: 48px; }

  /* ═══════════════════════════════════════
     ANNOUNCEMENT BAR
  ═══════════════════════════════════════ */
  .announce-bar {
    background: var(--amber-pale);
    border-bottom: 1px solid #E8D4A0;
    padding: 9px 24px;
    font-size: 11.5px;
    color: #6B4A0A;
    text-align: center;
    line-height: 1.5;
    font-weight: 500;
  }
  .announce-bar strong { color: var(--amber); }

  /* ═══════════════════════════════════════
     HEADER — Editorial newspaper style
  ═══════════════════════════════════════ */
  .site-header {
    background: var(--white);
    border-bottom: 3px solid var(--ink);
    position: sticky; top: 0; z-index: 60;
  }
  .header-inner {
    display: flex; align-items: center;
    justify-content: space-between;
    height: 58px;
  }
  .brand {
    display: inline-flex; align-items: center; gap: 9px;
    border-right: 1px solid var(--border);
    padding-right: 20px;
    margin-right: 6px;
  }
  .brand-text {
    font-family: var(--serif);
    font-weight: 700; font-size: 15px;
    color: var(--ink); letter-spacing: .03em;
    white-space: nowrap;
  }
  .nav { display: flex; gap: 24px; }
  .nav-link {
    font-size: 13px; font-weight: 500;
    color: var(--ink); opacity: .75;
    transition: opacity .15s;
  }
  .nav-link:hover { opacity: 1; }
  .header-right {
    display: flex; flex-direction: column;
    align-items: flex-end; line-height: 1.25;
  }
  .header-pr { font-size: 10px; color: var(--gray); letter-spacing: .05em; }

  /* ═══════════════════════════════════════
     HERO — Split-panel editorial
     Left: deep navy  |  Right: amber warm
  ═══════════════════════════════════════ */
  .hero {
    display: grid;
    grid-template-columns: 55% 45%;
    min-height: 88vh;
    overflow: hidden;
    position: relative;
  }

  /* Left panel: dark editorial */
  .hero-left {
    background: var(--navy);
    padding: 72px 56px 72px 72px;
    display: flex; flex-direction: column; justify-content: center;
    position: relative; overflow: hidden;
  }
  /* Halftone dot texture */
  .hero-left::before {
    content: '';
    position: absolute; inset: 0;
    background-image: radial-gradient(circle, rgba(255,255,255,.04) 1px, transparent 1px);
    background-size: 22px 22px;
    pointer-events: none;
  }
  /* Decorative vertical line */
  .hero-left::after {
    content: '';
    position: absolute; right: 0; top: 15%; bottom: 15%;
    width: 3px;
    background: linear-gradient(to bottom, transparent, var(--amber-warm), transparent);
  }

  .hero-issue {
    font-size: 10.5px; font-weight: 700; letter-spacing: .22em;
    color: var(--amber-warm); text-transform: uppercase;
    margin-bottom: 28px;
    opacity: 0;
    animation: fadeUp .6s ease forwards;
    animation-delay: .1s;
  }

  .hero-h1 {
    font-family: var(--serif);
    font-size: clamp(32px, 4.5vw, 56px);
    font-weight: 900;
    line-height: 1.25;
    letter-spacing: .03em;
    color: #fff;
    margin-bottom: 24px;
    opacity: 0;
    animation: fadeUp .7s ease forwards;
    animation-delay: .25s;
  }
  .hero-h1 em {
    font-style: normal;
    color: var(--amber-warm);
    position: relative;
    display: inline-block;
  }
  .hero-h1 em::after {
    content: '';
    position: absolute; left: 0; bottom: -2px;
    width: 100%; height: 2px;
    background: var(--amber-warm); opacity: .6;
  }

  .hero-lead {
    font-size: 14px; color: rgba(255,255,255,.72);
    line-height: 1.9; margin-bottom: 32px;
    opacity: 0;
    animation: fadeUp .7s ease forwards;
    animation-delay: .4s;
  }
  .hero-disclaimer {
    font-size: 10px; color: rgba(255,255,255,.4);
    display: block; margin-top: 8px;
    letter-spacing: .02em;
  }

  .hero-cta-row {
    display: flex; gap: 12px; flex-wrap: wrap;
    margin-bottom: 40px;
    opacity: 0;
    animation: fadeUp .7s ease forwards;
    animation-delay: .55s;
  }

  /* Achievement mini-row */
  .hero-stats {
    display: flex; gap: 0;
    border-top: 1px solid rgba(255,255,255,.12);
    padding-top: 24px;
    opacity: 0;
    animation: fadeUp .7s ease forwards;
    animation-delay: .7s;
  }
  .hero-stat {
    flex: 1;
    padding: 0 20px 0 0;
    border-right: 1px solid rgba(255,255,255,.12);
    margin-right: 20px;
  }
  .hero-stat:last-child { border-right: none; margin-right: 0; }
  .hero-stat-num {
    font-family: var(--serif);
    font-size: 26px; font-weight: 900;
    color: var(--amber-warm);
    line-height: 1;
    display: block;
  }
  .hero-stat-label {
    font-size: 10.5px; color: rgba(255,255,255,.55);
    margin-top: 4px; line-height: 1.4;
    display: block;
  }
  .hero-microcopy {
    display: block;
    width: 100%;
    color: rgba(255,255,255,.58);
    font-size: 11px;
    line-height: 1.6;
    margin-top: -4px;
  }

  /* Right panel: amber manga character */
  .hero-right {
    background: var(--amber-pale);
    display: flex; align-items: flex-end; justify-content: center;
    position: relative; overflow: hidden;
    padding-bottom: 0;
  }
  /* Manga screen tone */
  .hero-right::before {
    content: '';
    position: absolute; inset: 0;
    background-image: radial-gradient(circle, rgba(184,120,14,.10) 1.5px, transparent 1.5px);
    background-size: 14px 14px;
    pointer-events: none;
  }
  /* Speed-lines from top corner */
  .hero-right::after {
    content: '';
    position: absolute; top: 0; left: 0; right: 0; bottom: 0;
    background: repeating-linear-gradient(
      -30deg,
      transparent 0px,
      transparent 40px,
      rgba(184,120,14,.04) 40px,
      rgba(184,120,14,.04) 41px
    );
    pointer-events: none;
  }

  .hero-char-wrap {
    position: relative; z-index: 2;
    padding: 40px 20px 0;
    opacity: 0;
    animation: charReveal .8s cubic-bezier(.34,1.56,.64,1) forwards;
    animation-delay: .5s;
    max-width: 320px; width: 100%;
  }
  .hero-char-caption {
    position: absolute;
    top: 24px; left: 50%; transform: translateX(-50%);
    background: var(--navy);
    color: #fff;
    font-family: var(--serif);
    font-size: 12px; font-weight: 700;
    padding: 6px 18px;
    border-radius: var(--r-pill);
    white-space: nowrap;
    border: 2px solid var(--amber-warm);
    z-index: 3;
  }

  /* ═══════════════════════════════════════
     BUTTONS
  ═══════════════════════════════════════ */
  .btn {
    display: inline-flex; align-items: center;
    gap: 10px; padding: 13px 24px;
    border-radius: var(--r-sm);
    font-weight: 700; font-size: 14px;
    line-height: 1;
    transition: transform .15s ease, box-shadow .15s ease, background .15s ease;
    white-space: nowrap; cursor: pointer;
  }
  .btn:hover { transform: translateY(-2px); }

  .btn-primary {
    background: var(--amber-warm);
    color: var(--ink);
    box-shadow: 0 3px 0 var(--amber), var(--sh-amber);
  }
  .btn-primary:hover { background: #F0A500; box-shadow: 0 4px 0 var(--amber), 0 6px 24px rgba(184,120,14,.4); }

  .btn-navy {
    background: var(--navy);
    color: #fff;
    box-shadow: 0 3px 0 #040C26;
  }
  .btn-navy:hover { background: var(--navy-mid); }

  .btn-ghost {
    background: transparent;
    color: #fff;
    border: 1.5px solid rgba(255,255,255,.5);
  }
  .btn-ghost:hover { background: rgba(255,255,255,.08); border-color: #fff; }

  .btn-sage {
    background: var(--sage);
    color: #fff;
    box-shadow: 0 3px 0 #154D31;
  }

  .btn-block { width: 100%; justify-content: center; }
  .btn-lg { padding: 16px 32px; font-size: 15px; }
  .btn .arrow { font-size: 16px; }

  /* ═══════════════════════════════════════
     SUB-BANNER
  ═══════════════════════════════════════ */
  .subbanner-wrap {
    position: relative; z-index: 10;
    margin-top: -32px;
  }
  .subbanner {
    background: var(--white);
    border: 1.5px solid var(--border);
    border-radius: var(--r-lg);
    box-shadow: var(--sh-md);
    padding: 20px 28px;
    display: flex; align-items: center; justify-content: space-between; gap: 24px;
  }
  .sb-left { display: flex; align-items: center; gap: 16px; }
  .sb-icon {
    width: 52px; height: 52px; border-radius: var(--r-md);
    background: var(--paper); border: 1px solid var(--border);
    display: flex; align-items: center; justify-content: center; flex-shrink: 0;
  }
  .sb-title { font-family: var(--serif); font-size: 15px; font-weight: 700; }
  .sb-sub   { font-size: 12px; color: var(--gray); margin-top: 2px; }

  /* ═══════════════════════════════════════
     DECISION PATH — Result / Evidence / Trust / Safety
  ═══════════════════════════════════════ */
  .decision-grid {
    display: grid;
    grid-template-columns: repeat(4,1fr);
    gap: 14px;
    margin-top: 12px;
  }
  .decision-card {
    background: var(--white);
    border: 1.5px solid var(--border);
    border-radius: var(--r-md);
    padding: 20px 18px;
    min-height: 150px;
  }
  .decision-step {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: var(--navy);
    color: #fff;
    font-size: 11px;
    font-weight: 900;
    margin-bottom: 12px;
  }
  .decision-title {
    font-size: 14px;
    font-weight: 800;
    line-height: 1.45;
    margin-bottom: 6px;
  }
  .decision-body {
    font-size: 12px;
    color: var(--gray);
    line-height: 1.75;
  }

  /* ═══════════════════════════════════════
     PROBLEM SECTION — こんな悩みありませんか？
  ═══════════════════════════════════════ */
  .problem-grid {
    display: grid;
    grid-template-columns: repeat(3,1fr);
    gap: 16px; margin-top: 12px;
  }
  .problem-card {
    background: var(--white);
    border: 1.5px solid var(--border);
    border-radius: var(--r-md);
    padding: 22px 20px;
    position: relative;
    transition: transform .2s, box-shadow .2s;
  }
  .problem-card:hover { transform: translateY(-3px); box-shadow: var(--sh-md); }
  .problem-card::before {
    content: '';
    position: absolute; left: 0; top: 16px; bottom: 16px;
    width: 3px; background: var(--rust);
    border-radius: 2px;
  }
  .problem-num {
    font-family: var(--serif);
    font-size: 44px; font-weight: 900;
    color: var(--paper);
    line-height: 1;
    position: absolute; right: 16px; top: 10px;
    pointer-events: none;
  }
  .problem-icon { font-size: 28px; margin-bottom: 10px; }
  .problem-title { font-size: 15px; font-weight: 700; margin-bottom: 6px; line-height: 1.4; }
  .problem-body  { font-size: 12.5px; color: var(--gray); line-height: 1.7; }

  /* ═══════════════════════════════════════
     STORY — 4コマ manga editorial (redesigned)
  ═══════════════════════════════════════ */
  .manga-grid {
    display: grid;
    grid-template-columns: repeat(4,1fr);
    gap: 0;
    border: 3px solid var(--ink);
    border-radius: var(--r-md);
    overflow: hidden;
    margin-top: 40px;
    box-shadow: 5px 5px 0 var(--navy-mid);
  }
  .manga-panel {
    background: var(--white);
    display: flex; flex-direction: column;
    border-right: 3px solid var(--ink);
    position: relative;
  }
  .manga-panel:last-child { border-right: none; }

  .manga-panel-head {
    padding: 9px 13px;
    border-bottom: 2px solid var(--ink);
    display: flex; align-items: center; gap: 8px;
    background: var(--white);
    flex-shrink: 0;
  }
  .manga-num {
    width: 26px; height: 26px;
    background: var(--ink); color: var(--white);
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-weight: 900; font-size: 13px; flex-shrink: 0;
  }
  .manga-panel-title { font-size: 13px; font-weight: 700; line-height: 1.3; }

  /* Scene area: colored background + character */
  .manga-scene-bg {
    flex: 1;
    min-height: 220px;
    display: flex; flex-direction: column;
    align-items: center; justify-content: flex-end;
    padding: 16px 12px 10px;
    position: relative;
    overflow: hidden;
  }
  .manga-char-svg {
    display: block;
    width: 90px;
    max-width: 75%;
    margin: 0 auto;
    position: relative; z-index: 2;
  }
  .manga-prop {
    position: absolute;
    top: 12px; left: 12px;
    z-index: 3;
  }
  .manga-prop-tr {
    position: absolute;
    top: 10px; right: 12px;
    z-index: 3;
  }

  /* Speech section — below scene, full width, big readable text */
  .manga-speech {
    border-top: 2px solid var(--ink);
    padding: 13px 14px 14px;
    font-size: 13px;
    font-weight: 700;
    line-height: 1.65;
    color: var(--ink);
    background: var(--white);
    flex-shrink: 0;
  }
  .manga-speech--dark {
    background: var(--navy);
    color: rgba(255,255,255,.88);
    border-top-color: rgba(255,255,255,.2);
  }

  /* Panel connector arrows */
  .manga-connector {
    position: absolute;
    right: -15px; top: 48%;
    transform: translateY(-50%);
    z-index: 10;
    width: 28px; height: 28px;
    background: var(--navy);
    border: 2px solid var(--white);
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    color: #fff; font-size: 12px;
    box-shadow: 0 2px 8px rgba(0,0,0,.3);
  }

  /* Illustrated 4コマ strip (image-based) */
  .manga-img-wrap {
    margin-top: 40px;
    border: 3px solid var(--ink);
    border-radius: var(--r-md);
    overflow: hidden;
    box-shadow: 5px 5px 0 var(--navy-mid);
    background: var(--white);
  }
  .manga-strip-img {
    display: block;
    width: 100%;
    height: auto;
  }

  /* ═══════════════════════════════════════
     THEMES — 4-card grid
  ═══════════════════════════════════════ */
  .themes-grid {
    display: grid;
    grid-template-columns: repeat(4,1fr);
    gap: 16px;
    margin-top: 12px;
  }
  .theme-card {
    background: var(--white);
    border: 1.5px solid var(--border);
    border-radius: var(--r-md);
    padding: 24px 20px 22px;
    transition: transform .2s, box-shadow .2s, border-color .2s;
  }
  .theme-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--sh-md);
    border-color: var(--amber);
  }
  .theme-icon-wrap {
    width: 48px; height: 48px;
    background: var(--paper);
    border-radius: var(--r-sm);
    display: flex; align-items: center; justify-content: center;
    margin-bottom: 14px;
    border: 1px solid var(--border);
  }
  .theme-title { font-size: 15px; font-weight: 700; margin-bottom: 6px; }
  .theme-body  { font-size: 12px; color: var(--gray); line-height: 1.7; }

  /* ═══════════════════════════════════════
     ARTICLES — 3-col editorial grid
  ═══════════════════════════════════════ */
  .articles-grid {
    display: grid;
    grid-template-columns: repeat(3,1fr);
    gap: 20px;
    margin-top: 12px;
  }
  .article-card {
    background: var(--white);
    border: 1.5px solid var(--border);
    border-radius: var(--r-md);
    overflow: hidden;
    transition: transform .2s, box-shadow .2s;
  }
  .article-card:hover { transform: translateY(-3px); box-shadow: var(--sh-md); }

  .article-thumb {
    aspect-ratio: 16/10;
    overflow: hidden;
    position: relative;
  }
  .article-thumb svg { position: absolute; inset: 0; width: 100%; height: 100%; }

  .article-body { padding: 16px 18px 18px; }
  .article-cat {
    display: inline-block;
    font-size: 10.5px; font-weight: 700;
    padding: 3px 10px;
    border-radius: var(--r-pill);
    margin-bottom: 10px;
    letter-spacing: .03em;
  }
  .cat-savings  { background: #FEF3C7; color: #92400E; }
  .cat-invest   { background: var(--mist); color: var(--navy); }
  .cat-income   { background: var(--sage-pale); color: #155234; }
  .cat-debt     { background: #FFE4E6; color: #9B1C1C; }
  .cat-tax      { background: #EDE9FE; color: #4C1D95; }
  .cat-insurance { background: #DCFCE7; color: #166534; }

  .article-title {
    font-size: 13.5px; font-weight: 700;
    line-height: 1.55; color: var(--ink);
    margin-bottom: 12px;
  }
  .article-meta {
    display: flex; align-items: center; gap: 5px;
    font-size: 11px; color: var(--gray);
  }

  /* ═══════════════════════════════════════
     REASONS — 4-card editorial
  ═══════════════════════════════════════ */
  .reasons-grid {
    display: grid;
    grid-template-columns: repeat(4,1fr);
    gap: 16px;
    margin-top: 12px;
  }
  .reason-card {
    background: var(--paper);
    border-radius: var(--r-md);
    padding: 24px 18px;
    text-align: center;
    border: 1.5px solid var(--border);
  }
  .reason-badge {
    display: inline-block;
    background: var(--navy);
    color: #fff;
    font-size: 10px; font-weight: 700;
    padding: 4px 12px; border-radius: var(--r-pill);
    letter-spacing: .04em; margin-bottom: 14px;
  }
  .reason-icon-wrap {
    width: 64px; height: 64px;
    background: var(--white); border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    margin: 0 auto 12px; overflow: hidden;
    border: 1px solid var(--border);
  }
  .reason-text { font-size: 12px; color: var(--ink); line-height: 1.65; }

  /* ═══════════════════════════════════════
     ACHIEVEMENT BAR
  ═══════════════════════════════════════ */
  .achievement-bar {
    background: var(--ink);
    padding: 40px 0;
  }
  .achievement-inner {
    display: flex; align-items: center;
    justify-content: center; gap: 0;
  }
  .achievement-item {
    flex: 1; text-align: center;
    padding: 0 32px;
    border-right: 1px solid rgba(255,255,255,.1);
    max-width: 220px;
  }
  .achievement-item:last-child { border-right: none; }
  .achievement-num {
    font-family: var(--serif);
    font-size: clamp(36px, 5vw, 52px);
    font-weight: 900;
    color: var(--amber-warm);
    line-height: 1;
    display: block;
  }
  .achievement-label {
    font-size: 12px; color: rgba(255,255,255,.55);
    margin-top: 6px; display: block;
  }

  /* ═══════════════════════════════════════
     COMPARE TABLE
  ═══════════════════════════════════════ */
  .compare-wrap { overflow-x: auto; margin-top: 12px; }
  .compare-table {
    width: 100%; border-collapse: collapse;
    border: 1.5px solid var(--border);
    border-radius: var(--r-md);
    overflow: hidden;
    font-size: 13px;
    min-width: 600px;
  }
  .compare-table thead tr { background: var(--navy); color: #fff; }
  .compare-table th {
    padding: 13px 16px; font-weight: 700; font-size: 12px;
    letter-spacing: .03em; text-align: center;
  }
  .compare-table th:first-child { text-align: left; }
  .compare-table td {
    padding: 13px 16px; border-top: 1px solid var(--border);
    text-align: center;
  }
  .compare-table td:first-child {
    text-align: left; font-weight: 700;
    background: var(--paper);
  }
  .compare-table tr:hover td { background: var(--cream); }
  .compare-table tr:hover td:first-child { background: #EEEBE3; }
  .highlight-cell {
    background: var(--amber-pale) !important;
    font-weight: 700; color: #7A4A00;
  }
  .btn-compare {
    display: inline-flex; align-items: center; gap: 4px;
    background: var(--amber-warm); color: var(--ink);
    padding: 7px 14px; border-radius: var(--r-sm);
    font-size: 11.5px; font-weight: 700;
    transition: background .15s;
    box-shadow: 0 2px 0 var(--amber);
  }
  .btn-compare:hover { background: #F0A500; }

  /* ═══════════════════════════════════════
     FAQ
  ═══════════════════════════════════════ */
  .faq-list { display: flex; flex-direction: column; gap: 8px; margin-top: 12px; }
  .faq-item {
    background: var(--white);
    border: 1.5px solid var(--border);
    border-radius: var(--r-md); overflow: hidden;
    transition: border-color .15s;
  }
  .faq-item[open] { border-color: var(--amber); }
  .faq-item summary {
    display: flex; align-items: center; gap: 12px;
    padding: 16px 20px;
    font-size: 14px; font-weight: 700;
    cursor: pointer; list-style: none;
    transition: background .15s;
  }
  .faq-item summary::-webkit-details-marker { display: none; }
  .faq-item summary:hover { background: var(--cream); }
  .faq-q-icon {
    width: 26px; height: 26px; flex-shrink: 0;
    background: var(--navy); color: #fff;
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 12px; font-weight: 900;
  }
  .faq-q-text { flex: 1; }
  .faq-toggle {
    width: 22px; height: 22px;
    background: var(--paper); border: 1px solid var(--border);
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 16px; font-weight: 700; flex-shrink: 0;
    color: var(--amber); transition: transform .2s;
  }
  .faq-item[open] .faq-toggle { transform: rotate(45deg); }
  .faq-a {
    padding: 0 20px 16px 60px;
    font-size: 13.5px; color: var(--gray); line-height: 1.8;
  }

  /* ═══════════════════════════════════════
     FINAL CTA
  ═══════════════════════════════════════ */
  .finalcta {
    background: var(--navy);
    padding: 80px 0;
    position: relative; overflow: hidden;
  }
  .finalcta::before {
    content: '';
    position: absolute; inset: 0;
    background-image: radial-gradient(circle, rgba(255,255,255,.03) 1px, transparent 1px);
    background-size: 28px 28px;
  }
  .finalcta-inner {
    position: relative; z-index: 2;
    text-align: center; max-width: 680px; margin: 0 auto;
  }
  .finalcta-eyebrow {
    font-size: 11px; font-weight: 700; letter-spacing: .18em;
    color: var(--amber-warm); text-transform: uppercase;
    margin-bottom: 16px; display: block;
  }
  .finalcta-h {
    font-family: var(--serif);
    font-size: clamp(26px, 4vw, 38px);
    font-weight: 900; color: #fff;
    line-height: 1.35; margin-bottom: 14px;
  }
  .finalcta-sub { font-size: 14px; color: rgba(255,255,255,.65); margin-bottom: 36px; }
  .finalcta-row {
    display: flex; align-items: center; justify-content: center;
    gap: 12px; flex-wrap: wrap;
  }

  /* ═══════════════════════════════════════
     FOOTER
  ═══════════════════════════════════════ */
  .footer { background: #080E21; color: #A8B4CC; padding-top: 40px; }
  .footer-grid {
    display: grid; grid-template-columns: repeat(4,1fr);
    gap: 28px; padding-bottom: 32px;
  }
  .footer-h {
    font-family: var(--serif);
    color: #fff; font-weight: 700; font-size: 13px;
    margin-bottom: 12px; padding-bottom: 8px;
    border-bottom: 1px solid rgba(255,255,255,.08);
  }
  .footer-list { list-style: none; display: flex; flex-direction: column; gap: 7px; font-size: 12px; }
  .footer-list a:hover { color: #fff; }
  .footer-bottom { border-top: 1px solid rgba(255,255,255,.08); padding: 16px 0; }
  .footer-bottom-inner { display: flex; align-items: center; justify-content: space-between; font-size: 11px; }
  .footer-brand { display: flex; align-items: center; gap: 8px; color: #fff; font-weight: 700; font-family: var(--serif); }
  .footer-copy  { color: #5A6478; }

  /* ═══════════════════════════════════════
     STICKY CTA (mobile)
  ═══════════════════════════════════════ */
  .sticky-cta {
    display: none;
    position: fixed; bottom: 0; left: 0; right: 0;
    background: var(--white);
    border-top: 2px solid var(--amber-warm);
    padding: 10px 16px;
    z-index: 70;
    box-shadow: 0 -4px 20px rgba(0,0,0,.12);
    backdrop-filter: blur(8px);
  }
  .sticky-cta .btn { width: 100%; justify-content: center; padding: 15px; font-size: 15px; }

  /* ═══════════════════════════════════════
     CHIP / BADGE
  ═══════════════════════════════════════ */
  .chip {
    display: inline-flex; align-items: center;
    padding: 4px 12px; border-radius: var(--r-pill);
    font-size: 11px; font-weight: 700;
  }

  /* ═══════════════════════════════════════
     ANIMATIONS
  ═══════════════════════════════════════ */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @keyframes charReveal {
    from { opacity: 0; transform: translateY(40px) scale(.96); }
    to   { opacity: 1; transform: translateY(0) scale(1); }
  }
  @keyframes shimmer {
    0%,100% { opacity: .6; }
    50% { opacity: 1; }
  }

  /* Scroll-reveal base (JS enhances with .is-visible) */
  .reveal {
    opacity: 0; transform: translateY(24px);
    transition: opacity .6s ease, transform .6s ease;
  }
  .reveal.is-visible { opacity: 1; transform: translateY(0); }

  /* ═══════════════════════════════════════
     RESPONSIVE
  ═══════════════════════════════════════ */
  @media (max-width: 960px) {
    .hero { grid-template-columns: 1fr; min-height: auto; }
    .hero-left { padding: 56px 28px 40px; }
    .hero-right { min-height: 320px; }
    .themes-grid, .reasons-grid, .footer-grid { grid-template-columns: 1fr 1fr; }
    .decision-grid { grid-template-columns: 1fr 1fr; }
    .articles-grid { grid-template-columns: 1fr 1fr; }
    .problem-grid  { grid-template-columns: 1fr; }
    .manga-grid    { grid-template-columns: 1fr 1fr; gap: 2px; }
    .manga-connector { display: none; }
    .achievement-inner { flex-wrap: wrap; gap: 32px; justify-content: center; }
    .nav { display: none; }
    .sticky-cta { display: block; }
    body { padding-bottom: 72px; }
  }
  @media (max-width: 600px) {
    .hero-h1 { font-size: 28px; }
    .hero-stats { flex-direction: column; gap: 16px; }
    .hero-stat { border-right: none; padding-right: 0; }
    .themes-grid, .reasons-grid { grid-template-columns: 1fr; }
    .decision-grid { grid-template-columns: 1fr; }
    .articles-grid { grid-template-columns: 1fr; }
    .footer-grid { grid-template-columns: 1fr 1fr; gap: 20px; }
    .manga-grid { grid-template-columns: 1fr 1fr; }
    .finalcta-row { flex-direction: column; }
    .finalcta-row .btn { width: 100%; max-width: 360px; }
    .subbanner { flex-direction: column; gap: 12px; }
  }
  </style>
</head>
<body>

  <!-- PR開示バー -->
  <div class="announce-bar">
    <strong>PR</strong> 当サイトはアフィリエイト広告を含みます。紹介するサービスは実際に調査したものです。
    投資・副業にはリスクがあり、成果を保証するものではありません。
