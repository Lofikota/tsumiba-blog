---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getLineAddUrl, lineRefs, type LineRef } from '../../data/lineLinks';

export function getStaticPaths() {
  return lineRefs.map((lineRef) => ({
    params: { ref: lineRef.ref },
    props: { lineRef },
  }));
}

interface Props {
  lineRef: LineRef;
}

const { lineRef } = Astro.props;
const addUrl = getLineAddUrl(lineRef.ref);
---

<BaseLayout title={lineRef.headline} description={lineRef.description}>
  <section class="line-ref">
    <p class="line-ref-label">{lineRef.label}</p>
    <h1>{lineRef.headline}</h1>
    <p>{lineRef.description}</p>
    <ul class="line-ref-list">
      <li>登録直後に、今の悩みに近い記事をまとめて受け取れます。</li>
      <li>テーマ別に整理しているので、あとで見返しやすいです。</li>
      <li>必要ない配信はいつでも止められます。</li>
    </ul>
    <a class="line-ref-button" href={addUrl} rel="noopener noreferrer">LINEで受け取る</a>
    <p class="line-ref-note">登録後、知りたいテーマを番号で選べます。</p>
  </section>
</BaseLayout>

<style>
  .line-ref {
    background: #0f172a;
    color: #fff;
    border-radius: 12px;
    padding: 32px 24px;
  }
  .line-ref-label {
    color: #38bdf8;
    font-size: 13px;
    font-weight: 700;
    margin-bottom: 8px;
  }
  .line-ref h1 {
    font-size: clamp(26px, 7vw, 40px);
    line-height: 1.3;
    margin-bottom: 14px;
  }
  .line-ref p {
    color: #cbd5e1;
    line-height: 1.8;
  }
  .line-ref-list {
    margin: 14px 0 0 1.15rem;
    padding: 0;
    color: #e2e8f0;
    line-height: 1.7;
    font-size: 14px;
  }
  .line-ref-list li + li {
    margin-top: 0.3rem;
  }
  .line-ref-button {
    display: inline-block;
    margin-top: 20px;
    padding: 14px 22px;
    border-radius: 8px;
    background: #06c755;
    color: #fff;
    font-weight: 800;
    text-decoration: none;
  }
  .line-ref-note {
    margin-top: 10px;
    font-size: 13px;
  }
</style>
