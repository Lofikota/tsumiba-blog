---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getLineAddUrl, lineRefs, type LineRef } from '../../data/lineLinks';

export function getStaticPaths() {
  return lineRefs.map((lineRef) => ({
    params: { ref: lineRef.ref },
    props: { lineRef },
  }));
}

interface Props {
  lineRef: LineRef;
}

const { lineRef } = Astro.props;
const addUrl = getLineAddUrl(lineRef.ref);
const isCampaign = lineRef.source === 'campaign';
const isFx = lineRef.intent === 'fx';
const isFxCampaign = ['campaign-jfx', 'campaign-fxtf', 'campaign-dmm-fx'].includes(lineRef.ref);
const showFxRoute = isFx || isFxCampaign;
const flowLead = isCampaign
  ? '案件は、特典額より先に条件を見ると迷いが減ります。'
  : isFx
    ? 'FXは、口座を作る前に条件とリスクを見ると判断が安定します。'
  : '登録直後に、今の悩みに近い記事をまとめて受け取れます。';
---

<BaseLayout title={lineRef.headline} description={lineRef.description}>
  <section class="line-ref">
    <p class="line-ref-label">{lineRef.label}</p>
    <h1>{lineRef.headline}</h1>
    <p>{lineRef.description}</p>
    <ul class="line-ref-list">
      <li>{flowLead}</li>
      <li>{showFxRoute ? 'JFX → FXTF の順で、条件と向いている人を整理します。DMM FXの申込導線はリンク確認後に再開します。' : 'テーマ別に整理しているので、あとで見返しやすいです。'}</li>
      <li>必要ない配信はいつでも止められます。</li>
    </ul>
    {showFxRoute && (
      <div class="line-fx-route" aria-label="FX送客の優先順">
        <a href="/line/campaign-jfx/">1. JFX<span>取引機能・MT4</span></a>
        <a href="/line/campaign-fxtf/">2. FXTF<span>コスト・商品幅</span></a>
        <a href="/line/blog-fx-roundup/">確認中. DMM FX<span>申込はJFX・FXTFを優先</span></a>
      </div>
    )}
    <a class="line-ref-button" href={addUrl} rel="noopener noreferrer"
       data-google-event="line_add_click"
       data-google-category="line"
       data-google-label={lineRef.ref}>{isCampaign ? 'この案件を受け取る' : 'このテーマで受け取る'}</a>
    <p class="line-ref-note">{isCampaign ? '申し込む前に、条件だけ先に整理します。' : '登録後、知りたいテーマを番号で選べます。'}</p>
  </section>
</BaseLayout>

<style>
  .line-ref {
    background: #0f172a;
    color: #fff;
    border-radius: 12px;
    padding: 32px 24px;
  }
  .line-ref-label {
    color: #38bdf8;
    font-size: 13px;
    font-weight: 700;
    margin-bottom: 8px;
  }
  .line-ref h1 {
    font-size: clamp(26px, 7vw, 40px);
    line-height: 1.3;
    margin-bottom: 14px;
  }
  .line-ref p {
    color: #cbd5e1;
    line-height: 1.8;
  }
  .line-ref-list {
    margin: 14px 0 0 1.15rem;
    padding: 0;
    color: #e2e8f0;
    line-height: 1.7;
    font-size: 14px;
  }
  .line-ref-list li + li {
    margin-top: 0.3rem;
  }
  .line-fx-route {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 10px;
    margin-top: 18px;
  }
  .line-fx-route a {
    display: block;
    padding: 12px;
    border: 1px solid rgba(56, 189, 248, 0.4);
    border-radius: 8px;
    background: rgba(15, 23, 42, 0.55);
    color: #fff;
    font-weight: 800;
    text-decoration: none;
  }
  .line-fx-route span {
    display: block;
    margin-top: 4px;
    color: #cbd5e1;
    font-size: 12px;
    font-weight: 500;
  }
  .line-ref-button {
    display: inline-block;
    margin-top: 20px;
    padding: 14px 22px;
    border-radius: 8px;
    background: #06c755;
    color: #fff;
    font-weight: 800;
    text-decoration: none;
  }
  .line-ref-note {
    margin-top: 10px;
    font-size: 13px;
  }
  @media (max-width: 640px) {
    .line-fx-route {
      grid-template-columns: 1fr;
    }
  }
</style>
