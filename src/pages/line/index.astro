---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getLineAddUrl, getLineRef, lineOfficial, type LineRef } from '../../data/lineLinks';

const addUrl = getLineAddUrl('direct-line-page');
const featuredRefs: LineRef[] = ['blog-main', 'blog-tax-basic', 'blog-card-roundup', 'blog-fx-roundup', 'blog-nisa-mistake']
  .map((ref) => getLineRef(ref))
  .filter((ref): ref is LineRef => Boolean(ref));
const campaignRefs: LineRef[] = ['campaign-dmm-fx', 'campaign-jfx', 'campaign-fxtf', 'campaign-epos-card']
  .map((ref) => getLineRef(ref))
  .filter((ref): ref is LineRef => Boolean(ref));
---

<BaseLayout
  title="田中蓮の公式LINE"
  description="FX、クレカ、副業税金を先に整理し、NISAは補助入口として届ける田中蓮の公式LINEです。"
>
  <section class="line-hero">
    <p class="line-kicker">公式LINE</p>
    <h1>今の悩みを1つ選べるLINE</h1>
    <p>
      FX、クレカ、副業税金を先に整理し、NISAは補助として届けます。
      登録したら、まずは4択から1つだけ選ぶだけです。
    </p>
    <a class="line-button" href={addUrl} rel="noopener noreferrer">1分で診断を始める</a>
    <p class="line-note">LINE ID: {lineOfficial.accountId}</p>
  </section>

  <section class="line-section">
    <h2>登録後に選べるテーマ</h2>
    <div class="line-grid">
      <article>
        <h3>FX・高単価キャンペーン</h3>
        <p>口座条件、取引条件、スプレッド、リスクを整理します。</p>
      </article>
      <article>
        <h3>副業税金・確定申告</h3>
        <p>収入、経費、青色申告、控除の確認順を整理します。</p>
      </article>
      <article>
        <h3>クレカ・ポイント</h3>
        <p>年会費、還元条件、クレカ積立の相性を整理します。</p>
      </article>
      <article>
        <h3>NISA・証券口座</h3>
        <p>口座選び、積立設定、ポイント条件を整理します。</p>
      </article>
    </div>
  </section>

  <section class="line-section">
    <h2>登録後の流れ</h2>
    <div class="line-flow">
      <article>
        <h3>1. 追加してすぐ</h3>
        <p>あいさつメッセージで、今ほしいテーマを1つだけ選べます。</p>
      </article>
      <article>
        <h3>2. 悩み別に受け取る</h3>
        <p>選んだテーマに合わせて、記事・チェック項目・注意点を整理して届けます。</p>
      </article>
      <article>
        <h3>3. 必要なときだけ開く</h3>
        <p>通知が多すぎないようにしつつ、必要なときに見返せる形で残します。</p>
      </article>
    </div>
  </section>

  <section class="line-section">
    <h2>案件別の入口</h2>
    <div class="line-topic-list">
      {campaignRefs.map((ref) => (
        <article>
          <h3>{ref.label}</h3>
          <p>{ref.description}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="line-section">
    <h2>記事別の入口</h2>
    <div class="line-topic-list">
      {featuredRefs.map((ref) => (
        <article>
          <h3>{ref.label}</h3>
          <p>{ref.description}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="line-caution">
    <strong>PR・免責</strong>
    <p>
      アフィリエイト広告を含む場合があります。投資には元本割れのリスクがあります。
      税金・保険等の個別判断は専門家へご相談ください。
    </p>
  </section>
</BaseLayout>

<style>
  .line-hero {
    background: #0f172a;
    color: #fff;
    border-radius: 12px;
    padding: 32px 24px;
  }
  .line-kicker {
    color: #38bdf8;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: .08em;
    margin-bottom: 8px;
  }
  .line-hero h1 {
    font-size: clamp(28px, 7vw, 44px);
    line-height: 1.25;
    margin-bottom: 14px;
  }
  .line-hero p {
    color: #cbd5e1;
    line-height: 1.8;
    max-width: 620px;
  }
  .line-button {
    display: inline-block;
    margin-top: 20px;
    padding: 14px 22px;
    border-radius: 8px;
    background: #06c755;
    color: #fff;
    font-weight: 800;
    text-decoration: none;
  }
  .line-note {
    font-size: 13px;
    margin-top: 10px;
  }
  .line-section {
    margin-top: 28px;
  }
  .line-section h2 {
    font-size: 22px;
    margin-bottom: 14px;
  }
  .line-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 12px;
  }
  .line-grid article {
    background: #fff;
    border: 1px solid #e2e8f0;
    border-radius: 10px;
    padding: 16px;
  }
  .line-grid h3 {
    font-size: 16px;
    margin-bottom: 8px;
  }
  .line-grid p {
    color: #64748b;
    font-size: 14px;
    line-height: 1.7;
  }
  .line-flow {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 12px;
  }
  .line-topic-list {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 12px;
  }
  .line-flow article,
  .line-topic-list article {
    background: #fff;
    border: 1px solid #e2e8f0;
    border-radius: 10px;
    padding: 16px;
  }
  .line-flow h3,
  .line-topic-list h3 {
    font-size: 16px;
    margin-bottom: 8px;
  }
  .line-flow p,
  .line-topic-list p {
    color: #64748b;
    font-size: 14px;
    line-height: 1.7;
  }
  .line-caution {
    margin-top: 24px;
    border: 1px solid #fde68a;
    background: #fffbeb;
    border-radius: 10px;
    padding: 16px;
    color: #78350f;
    font-size: 14px;
  }
  @media (max-width: 640px) {
    .line-grid {
      grid-template-columns: 1fr;
    }
    .line-flow,
    .line-topic-list {
      grid-template-columns: 1fr;
    }
  }
</style>
