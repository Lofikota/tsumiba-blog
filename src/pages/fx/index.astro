---
import BaseLayout from '../../layouts/BaseLayout.astro';
import RankingCard from '../../components/RankingCard.astro';

const updated = '2026年6月13日';

const ranking = [
  {
    rank: 1,
    name: 'JFX',
    initial: 'J',
    catch: '約定力No.1・スキャルピング歓迎',
    rating: 4.9,
    score: 92,
    comment: '約定スピードとスキャルピング歓迎が強み。コストも業界最狭水準で、1社目に選んで後悔しにくい万能型です。',
    bars: [
      { label: 'コスト', pct: 88 },
      { label: '約定力', pct: 98 },
      { label: '初心者', pct: 80 },
    ],
    specs: [
      { v: '0.2銭', k: '米ドル/円' },
      { v: '1,000', k: '最小通貨' },
      { v: '5万円', k: 'CB上限' },
    ],
    href: '/go/jfx/',
    reviewHref: '/blog/jfx-review/',
    featured: true,
    trackLabel: 'jfx',
  },
  {
    rank: 2,
    name: 'FXTF',
    initial: 'F',
    catch: 'MT4・自動売買が使える',
    rating: 4.6,
    score: 88,
    comment: 'MT4と自動売買を使いたい人に最適。裁量よりも仕組みで取引したい中級者に向きます。',
    bars: [
      { label: '自動売買', pct: 92 },
      { label: 'コスト', pct: 84 },
    ],
    href: '/go/fxtf/',
    reviewHref: '/blog/fxtf-review/',
    trackLabel: 'fxtf',
  },
  {
    rank: 3,
    name: 'セントラル短資FX',
    initial: 'セ',
    catch: '老舗の信頼性・スワップに強い',
    rating: 4.5,
    score: 86,
    comment: '1909年創業の老舗。スワップと情報量に強く、長期保有・安心感を重視する人向けです。',
    bars: [
      { label: '信頼性', pct: 95 },
      { label: 'スワップ', pct: 86 },
    ],
    href: '/blog/central-tanshi-fx-review/',
    reviewHref: '/blog/central-tanshi-fx-review/',
    trackLabel: 'central-tanshi',
  },
];

const howto = [
  { icon: 'コスト重視', title: 'とにかくコストを抑えたい', body: 'スプレッドが狭いJFX・FXTFが有力。少額で始めるなら1,000通貨対応を選びましょう。', pick: 'JFX / FXTF' },
  { icon: '約定力', title: '短期売買・スキャルがしたい', body: '約定スピードとスキャル公認のJFXが安心。滑りにくさが利益に直結します。', pick: 'JFX' },
  { icon: '自動売買', title: '仕組みで放置運用したい', body: 'MT4・自動売買が使えるFXTF。スワップ長期ならセントラル短資FXも候補です。', pick: 'FXTF / セントラル短資FX' },
];
---

<BaseLayout
  title="国内FX口座比較ランキング【2026年最新】"
  description="国内FX口座をコスト・約定力・初心者向けやすさで毎週比較。JFX・FXTF・セントラル短資FXを編集部が総合スコアで正直に評価し、今いちばんお得に始められる一社を最速で見つけます。"
  wide={true}
>
  <section class="fx-hero">
    <div class="fx-hero-text">
      <span class="fx-hero-badge">2026年上半期 編集部総合ランキング</span>
      <h1>資産は、一段ずつ。<br />国内FXの“今いちばんお得”を最速で。</h1>
      <p class="fx-hero-lead">キャンペーン・コスト・使いやすさを毎週更新。あなたが損しない一社を、編集部が総合スコアで選びます。</p>
      <div class="fx-hero-trust">
        <span><span class="fx-stars">★★★★★</span> <b>4.8</b> <span class="fx-muted">(312件)</span></span>
        <span>15社を調査・比較</span>
      </div>
      <a href="#ranking" class="fx-hero-cta">無料で比較して始める →</a>
    </div>
    <svg class="fx-hero-art" viewBox="0 0 230 165" role="img" aria-label="積み上がるブロックと上昇チャート">
      <rect x="0" y="0" width="230" height="165" rx="12" fill="#F7F8FA"></rect>
      <rect x="26" y="120" width="40" height="28" rx="3" fill="#1B3A5B"></rect>
      <rect x="74" y="98" width="40" height="50" rx="3" fill="#1B3A5B"></rect>
      <rect x="122" y="72" width="40" height="76" rx="3" fill="#1B3A5B"></rect>
      <rect x="170" y="44" width="40" height="104" rx="3" fill="#274C73"></rect>
      <polyline points="30,118 88,96 138,70 196,42" fill="none" stroke="#E0A458" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"></polyline>
      <circle cx="196" cy="42" r="11" fill="#E0A458"></circle>
      <text x="196" y="46" text-anchor="middle" font-size="11" font-weight="700" fill="#412402">¥</text>
    </svg>
  </section>

  <div class="fx-ticker">
    <strong>今週のキャンペーン速報</strong>　JFX 最大<b>5万円</b>キャッシュバック中／FXTF 口座開設で<b>最大3万円</b>
  </div>

  <nav class="fx-toc" aria-label="目次">
    <span class="fx-toc-label">目次</span>
    <a href="#ranking">総合ランキング</a>
    <a href="#table">比較表</a>
    <a href="#howto">タイプ別の選び方</a>
    <a href="#criteria">評価基準・出典</a>
  </nav>

  <section class="fx-diag" aria-label="30秒診断">
    <div class="fx-diag-head"><strong>30秒診断</strong><span>何を重視しますか？</span></div>
    <div class="fx-diag-chips">
      <a href="#howto" class="fx-chip">コストの安さ</a>
      <a href="#howto" class="fx-chip">約定力・スキャル</a>
      <a href="#howto" class="fx-chip">自動売買</a>
      <a href="#howto" class="fx-chip">初心者向け</a>
    </div>
  </section>

  <section id="ranking" class="fx-rank-sec">
    <div class="fx-sech"><h2>編集部総合ランキング</h2><span class="fx-updated">{updated} 更新</span></div>
    <p class="fx-sub">コスト・約定力・初心者向けやすさを100点満点で総合評価（基準は<a href="#criteria">こちら</a>）</p>

    <RankingCard {...ranking[0]} />
    <div class="fx-rank-grid">
      <RankingCard {...ranking[1]} />
      <RankingCard {...ranking[2]} />
    </div>
  </section>

  <section id="table" class="fx-table-sec">
    <div class="fx-sech"><h2>スペック比較表</h2></div>
    <div class="fx-table-wrap">
      <table class="fx-table">
        <thead>
          <tr><th>会社</th><th>総合</th><th>米ドル/円</th><th>最小通貨</th><th>取引ツール</th><th>キャンペーン</th></tr>
        </thead>
        <tbody>
          <tr><td>JFX</td><td><b class="fx-score-cell">92</b></td><td><b>0.2銭</b></td><td>1,000</td><td>MATRIX・MT4</td><td><b>最大5万円</b></td></tr>
          <tr><td>FXTF</td><td><b class="fx-score-cell">88</b></td><td><b>0.2銭</b></td><td>1,000</td><td>MT4</td><td><b>最大3万円</b></td></tr>
          <tr><td>セントラル短資FX</td><td><b class="fx-score-cell">86</b></td><td><b>0.2銭</b></td><td>1,000</td><td>独自ツール</td><td>条件あり</td></tr>
        </tbody>
      </table>
    </div>
    <p class="fx-note">※スプレッドは原則固定（例外あり）。キャンペーン金額・条件は変動します。申込前に必ず各社公式の最新情報をご確認ください。</p>
  </section>

  <section id="howto" class="fx-howto-sec">
    <div class="fx-sech"><h2>タイプ別の選び方</h2></div>
    <p class="fx-sub">迷ったら、自分が一番重視するものから選ぶのが失敗しにくいです。</p>
    <div class="fx-howto-grid">
      {howto.map((h) => (
        <div class="fx-howto-card">
          <span class="fx-howto-tag">{h.icon}</span>
          <strong>{h.title}</strong>
          <p>{h.body}</p>
          <span class="fx-howto-pick">おすすめ：{h.pick}</span>
        </div>
      ))}
    </div>
  </section>

  <section id="criteria" class="fx-criteria-sec">
    <div class="fx-sech"><h2>評価基準と出典</h2></div>
    <div class="fx-criteria-grid">
      <div class="fx-criteria-box">
        <strong>総合スコアの内訳</strong>
        <ul>
          <li><b>コスト</b>（スプレッド・手数料）… 40%</li>
          <li><b>約定力</b>（スピード・滑りにくさ）… 30%</li>
          <li><b>始めやすさ</b>（最小通貨・ツール・サポート）… 30%</li>
        </ul>
      </div>
      <div class="fx-criteria-box">
        <strong>調査方法・出典</strong>
        <ul>
          <li>国内FX <b>15社</b>を対象に毎週見直し</li>
          <li>数値は各社<b>公式サイト</b>の公開情報を参照</li>
          <li>キャンペーンは告知ページの条件を確認のうえ掲載</li>
        </ul>
      </div>
    </div>
  </section>

  <footer class="fx-editor">
    <span class="fx-editor-avatar">編</span>
    <div>
      <strong>tsumiba編集部</strong>
      <p>国内FXのコスト・約定力を毎週検証しています。広告（PR）を含みますが、評価は上記の基準に基づいて公平に行います。FXは元本保証のない投機的取引で、損失が生じる可能性があります。投資判断はご自身の責任で行ってください。</p>
    </div>
  </footer>
</BaseLayout>

<style>
  .fx-hero {
    display: grid;
    grid-template-columns: 1.45fr 1fr;
    gap: 20px;
    align-items: center;
    margin: 1rem 0 1.5rem;
  }
  .fx-hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    border: 1px solid #E5E7EB;
    border-left: 3px solid #E0A458;
    padding: 5px 11px;
    font-size: 12px;
    color: #1B3A5B;
    font-weight: 700;
  }
  .fx-hero h1 {
    font-size: 28px;
    line-height: 1.4;
    color: #1B3A5B;
    margin: 12px 0 8px;
  }
  .fx-hero-lead { color: #6b7280; font-size: 14px; margin: 0 0 14px; }
  .fx-hero-trust { display: flex; gap: 18px; font-size: 12px; color: #6b7280; margin-bottom: 14px; }
  .fx-hero-trust b { color: #1B3A5B; }
  .fx-stars { color: #E0A458; letter-spacing: -1px; }
  .fx-muted { color: #9ca3af; }
  .fx-hero-cta {
    display: inline-block;
    background: #E0A458;
    color: #412402;
    font-weight: 700;
    padding: 11px 22px;
    border-radius: 9px;
    font-size: 14px;
    text-decoration: none;
  }
  .fx-hero-art { width: 100%; height: auto; }

  .fx-ticker {
    border: 1px solid #E5E7EB;
    border-left: 3px solid #E0A458;
    padding: 10px 14px;
    font-size: 13px;
    color: #1F2937;
    margin-bottom: 1.5rem;
  }
  .fx-ticker strong, .fx-ticker b { color: #1B3A5B; }

  .fx-toc {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 8px 16px;
    border: 1px solid #E5E7EB;
    border-radius: 11px;
    padding: 12px 16px;
    margin-bottom: 1.75rem;
    font-size: 13px;
  }
  .fx-toc-label { font-weight: 700; color: #1B3A5B; }
  .fx-toc a { color: #1B3A5B; text-decoration: none; position: relative; padding-left: 14px; }
  .fx-toc a::before { content: '›'; position: absolute; left: 2px; color: #E0A458; }

  .fx-diag {
    border: 1px solid #E5E7EB;
    border-radius: 13px;
    padding: 14px 16px;
    margin-bottom: 2rem;
  }
  .fx-diag-head { display: flex; align-items: center; gap: 8px; margin-bottom: 9px; }
  .fx-diag-head strong { color: #1B3A5B; font-size: 14px; }
  .fx-diag-head span { font-size: 11px; color: #9ca3af; }
  .fx-diag-chips { display: flex; gap: 9px; flex-wrap: wrap; }
  .fx-chip {
    border: 1px solid #E5E7EB;
    border-radius: 20px;
    padding: 7px 14px;
    font-size: 12px;
    color: #1B3A5B;
    text-decoration: none;
  }
  .fx-chip:hover { border-color: #1B3A5B; }

  .fx-sech { display: flex; align-items: center; gap: 9px; margin-bottom: 4px; }
  .fx-sech::before { content: ''; width: 4px; height: 20px; background: #1B3A5B; border-radius: 2px; }
  .fx-sech h2 { font-size: 19px; color: #1B3A5B; margin: 0; }
  .fx-updated { font-size: 11px; color: #9ca3af; margin-left: auto; }
  .fx-sub { font-size: 12px; color: #6b7280; margin: 4px 0 16px; }
  .fx-sub a { color: #1B3A5B; }

  .fx-rank-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    margin-top: 14px;
  }
  .fx-rank-sec { margin-bottom: 2.5rem; }

  .fx-table-sec { margin-bottom: 2.5rem; }
  .fx-table-wrap { overflow-x: auto; margin-top: 10px; }
  .fx-table { width: 100%; border-collapse: collapse; font-size: 13px; }
  .fx-table th, .fx-table td { border-bottom: 1px solid #E5E7EB; padding: 10px 8px; text-align: center; }
  .fx-table th { background: #F7F8FA; color: #1B3A5B; font-weight: 700; font-size: 12px; }
  .fx-table tbody tr:nth-child(even) { background: #F7F8FA; }
  .fx-table td:first-child, .fx-table th:first-child { text-align: left; color: #1B3A5B; font-weight: 500; }
  .fx-table td b { color: #1B3A5B; }
  .fx-score-cell {
    display: inline-grid;
    place-items: center;
    min-width: 30px;
    padding: 2px 6px;
    border-radius: 6px;
    background: #1B3A5B;
    color: #fff !important;
    font-size: 13px;
  }
  .fx-note { font-size: 11px; color: #9ca3af; margin: 8px 0 0; line-height: 1.7; }

  .fx-howto-sec { margin-bottom: 2.5rem; }
  .fx-howto-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
  }
  .fx-howto-card {
    border: 1px solid #E5E7EB;
    border-radius: 12px;
    padding: 14px;
  }
  .fx-howto-tag {
    display: inline-block;
    font-size: 11px;
    font-weight: 700;
    color: #1B3A5B;
    border: 1px solid #E5E7EB;
    border-left: 3px solid #1B3A5B;
    padding: 3px 9px;
    margin-bottom: 8px;
  }
  .fx-howto-card strong { display: block; font-size: 14px; color: #1B3A5B; margin-bottom: 6px; }
  .fx-howto-card p { font-size: 12px; color: #6b7280; margin: 0 0 10px; line-height: 1.7; }
  .fx-howto-pick { font-size: 12px; font-weight: 700; color: #412402; background: #fff; border: 1px solid #E0A458; border-radius: 6px; padding: 4px 8px; display: inline-block; }

  .fx-criteria-sec { margin-bottom: 2.5rem; }
  .fx-criteria-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    margin-top: 10px;
  }
  .fx-criteria-box {
    border: 1px solid #E5E7EB;
    border-left: 3px solid #1B3A5B;
    padding: 12px 16px;
    background: #fff;
  }
  .fx-criteria-box strong { display: block; font-size: 13px; color: #1B3A5B; margin-bottom: 8px; }
  .fx-criteria-box ul { margin: 0; padding-left: 18px; }
  .fx-criteria-box li { font-size: 12px; color: #374151; line-height: 1.9; }
  .fx-criteria-box b { color: #1B3A5B; }

  .fx-editor {
    display: flex;
    gap: 12px;
    align-items: flex-start;
    border-top: 1px solid #E5E7EB;
    padding-top: 16px;
  }
  .fx-editor-avatar {
    width: 36px; height: 36px;
    border-radius: 50%;
    background: #1B3A5B; color: #fff;
    display: grid; place-items: center;
    font-size: 13px; flex-shrink: 0;
  }
  .fx-editor strong { font-size: 13px; color: #1B3A5B; }
  .fx-editor p { font-size: 12px; color: #6b7280; margin: 3px 0 0; line-height: 1.7; }

  @media (max-width: 720px) {
    .fx-hero { grid-template-columns: 1fr; }
    .fx-hero-art { max-width: 280px; }
    .fx-rank-grid { grid-template-columns: 1fr; }
    .fx-howto-grid { grid-template-columns: 1fr; }
    .fx-criteria-grid { grid-template-columns: 1fr; }
  }
</style>
