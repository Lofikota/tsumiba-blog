---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const featuredPosts = allPosts.slice(0, 6);
const hokenPosts = allPosts.filter((post) => post.data.category.includes('保険')).slice(0, 3);

const categoryTone: Record<string, string> = {
  '保険': 'tone-green',
  '保険相談': 'tone-green',
  'NISA・投資': 'tone-blue',
  '投資・資産運用': 'tone-blue',
  '副業・節税': 'tone-amber',
  'FX・外貨': 'tone-red',
  'お得情報': 'tone-yellow',
  'クレジットカード': 'tone-yellow',
  '家計・節約': 'tone-green',
};
---

<BaseLayout
  title="田中蓮のマネーブログ"
  description="30代会社員の目線で、保険・家計・NISA・副業・FXを無理なく整理する個人ブログ。無料相談やサービス選びの前に、注意点と選び方をわかりやすく確認できます。"
  image="/images/ren-consultation-hero.svg"
  wide={true}
>
  <section class="home-hero">
    <div class="home-hero-copy">
      <p class="home-eyebrow">PRを含む個人マネーブログ</p>
      <h1>保険・家計・投資の迷いを、<br />会社員目線でやさしく整理。</h1>
      <p class="home-lead">
        いきなり申し込みをすすめるのではなく、まずは「何を比べるべきか」「どこに注意するか」を整理します。
        30代会社員の田中蓮が、保険相談・NISA・副業・FXを初心者向けにまとめています。
      </p>
      <div class="home-actions">
        <a class="home-btn home-btn-primary" href="/blog/hoken-soudan-muryou-hikaku/">無料保険相談を比較する</a>
        <a class="home-btn home-btn-secondary" href="/blog/">記事一覧を見る</a>
      </div>
      <p class="home-note">投資・保険・副業にはリスクや個人差があります。最終判断は公式情報を確認してください。</p>
    </div>
    <div class="home-hero-visual" aria-label="家計相談のイメージ画像">
      <img src="/images/ren-consultation-hero.svg" alt="家計や保険を相談する会社員のイメージ" width="640" height="520" />
      <div class="home-proof-card home-proof-card-a">
        <strong>相談前に整理</strong>
        <span>保険料・保障・家計</span>
      </div>
      <div class="home-proof-card home-proof-card-b">
        <strong>PR明記</strong>
        <span>広告と注意点を分けて掲載</span>
      </div>
    </div>
  </section>

  <section class="trust-strip" aria-label="ブログの特徴">
    <div>
      <strong>無料相談</strong>
      <span>相談料0円の窓口を比較</span>
    </div>
    <div>
      <strong>30代会社員</strong>
      <span>生活目線で判断</span>
    </div>
    <div>
      <strong>注意点も掲載</strong>
      <span>即決をすすめない構成</span>
    </div>
    <div>
      <strong>LINE導線</strong>
      <span>迷った内容を後で整理</span>
    </div>
  </section>

  <section class="home-section hoken-focus" id="hoken">
    <div class="section-copy">
      <p class="section-kicker">Insurance Guide</p>
      <h2>保険相談は「どこが良いか」より、<br />先に比べ方を決める。</h2>
      <p>
        参考サイトのような安心感は残しつつ、個人ブログとして「中立に整理する」「強引に売らない」雰囲気に寄せました。
        店舗・オンライン・FPとの相性など、申し込む前に見るべき観点から読めます。
      </p>
    </div>
    <div class="hoken-grid">
      {hokenPosts.map((post) => (
        <a class="hoken-card" href={`/blog/${post.id}/`}>
          <img src={post.data.heroImage ?? `/og/${post.id}.svg`} alt="" width="360" height="200" loading="lazy" />
          <span>{post.data.category}</span>
          <strong>{post.data.title}</strong>
        </a>
      ))}
    </div>
  </section>

  <section class="home-section issue-section" id="themes">
    <div class="section-headline">
      <p class="section-kicker">What You Can Read</p>
      <h2>今の悩みから選べる4テーマ</h2>
    </div>
    <div class="issue-grid">
      <a class="issue-card" href="/blog/hoken-soudan-muryou-hikaku/">
        <img src="/images/ren-insurance-consult.svg" alt="保険相談のイメージ" width="280" height="170" loading="lazy" />
        <span>保険相談</span>
        <strong>毎月の保険料や保障内容を見直したい</strong>
      </a>
      <a class="issue-card" href="/blog/nisa-hajimekata/">
        <img src="/images/ren-investment-desk.svg" alt="資産形成のイメージ" width="280" height="170" loading="lazy" />
        <span>資産形成</span>
        <strong>NISA・iDeCoを何から始めるか知りたい</strong>
      </a>
      <a class="issue-card" href="/blog/fukugyo-zeikin/">
        <img src="/images/ren-work-desk.svg" alt="副業と家計整理のイメージ" width="280" height="170" loading="lazy" />
        <span>副業・節税</span>
        <strong>会社員のまま収入の柱を増やしたい</strong>
      </a>
      <a class="issue-card" href="/blog/fx-kouza-hikaku/">
        <img src="/og/fx-kouza-hikaku.svg" alt="FX比較のイメージ" width="280" height="170" loading="lazy" />
        <span>FX・外貨</span>
        <strong>リスクを理解した上で口座を比較したい</strong>
      </a>
    </div>
  </section>

  <section class="home-section latest-section" id="articles">
    <div class="section-headline with-link">
      <div>
        <p class="section-kicker">Latest Articles</p>
        <h2>新着記事</h2>
      </div>
      <a href="/blog/">すべての記事を見る</a>
    </div>
    <div class="latest-grid">
      {featuredPosts.map((post) => {
        const tone = categoryTone[post.data.category] ?? 'tone-gray';
        const dateStr = post.data.pubDate.toLocaleDateString('ja-JP', { year: 'numeric', month: '2-digit', day: '2-digit' });
        return (
          <article class="latest-card">
            <a href={`/blog/${post.id}/`}>
              <img src={post.data.heroImage ?? `/thumbnails/${post.id}.svg`} alt="" width="320" height="190" loading="lazy" />
              <div class="latest-body">
                <span class={`category-pill ${tone}`}>{post.data.category}</span>
                <h3>{post.data.title}</h3>
                <p>{post.data.description}</p>
                <time datetime={post.data.pubDate.toISOString()}>{dateStr}</time>
              </div>
            </a>
          </article>
        );
      })}
    </div>
  </section>

  <section class="home-final">
    <div>
      <p class="section-kicker">Before You Decide</p>
      <h2>申し込む前に、条件と注意点を一緒に確認する。</h2>
      <p>無料相談・口座開設・カード申込は、先に比較軸を決めるだけで失敗しにくくなります。</p>
    </div>
    <a class="home-btn home-btn-primary" href="/blog/">比較記事から読む</a>
  </section>
</BaseLayout>

<style>
  .home-hero {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(360px, 0.9fr);
    gap: 44px;
    align-items: center;
    min-height: 560px;
    padding: 44px 0 28px;
  }
  .home-eyebrow,
  .section-kicker {
    margin: 0 0 12px;
    color: #18714f;
    font-size: 0.78rem;
    font-weight: 900;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }
  .home-hero h1 {
    margin: 0;
    color: #17352a;
    font-size: clamp(2.15rem, 4.5vw, 4.25rem);
    line-height: 1.18;
    letter-spacing: 0;
  }
  .home-lead {
    max-width: 640px;
    margin: 22px 0 0;
    color: #41564e;
    font-size: 1.02rem;
    line-height: 2;
  }
  .home-actions { display: flex; flex-wrap: wrap; gap: 12px; margin-top: 28px; }
  .home-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    padding: 0 22px;
    border-radius: 8px;
    font-weight: 900;
    text-decoration: none;
    transition: transform .15s, box-shadow .15s, background .15s;
  }
  .home-btn:hover { transform: translateY(-1px); text-decoration: none; }
  .home-btn-primary { background: #0f8a5f; color: #fff; box-shadow: 0 10px 24px rgba(15, 138, 95, .22); }
  .home-btn-secondary { background: #fff; color: #174638; border: 1px solid #b9d9cd; }
  .home-note { margin: 14px 0 0; color: #73827d; font-size: 0.78rem; line-height: 1.7; }
  .home-hero-visual { position: relative; }
  .home-hero-visual img {
    width: 100%;
    height: auto;
    border-radius: 18px;
    border: 1px solid #d7e7df;
    box-shadow: 0 26px 70px rgba(42, 71, 59, .14);
    background: #fff;
  }
  .home-proof-card {
    position: absolute;
    display: grid;
    gap: 2px;
    min-width: 170px;
    padding: 13px 16px;
    border-radius: 8px;
    background: rgba(255,255,255,.94);
    border: 1px solid #d7e7df;
    box-shadow: 0 14px 35px rgba(30, 70, 52, .16);
  }
  .home-proof-card strong { color: #123f31; font-size: 0.95rem; }
  .home-proof-card span { color: #62746d; font-size: 0.76rem; }
  .home-proof-card-a { left: -18px; bottom: 60px; }
  .home-proof-card-b { right: -14px; top: 58px; }

  .trust-strip {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    overflow: hidden;
    border: 1px solid #d7e7df;
    border-radius: 12px;
    background: #d7e7df;
    margin: 10px 0 56px;
  }
  .trust-strip div { background: #fff; padding: 20px 18px; }
  .trust-strip strong { display: block; color: #123f31; font-size: 1.12rem; }
  .trust-strip span { display: block; color: #66756f; font-size: 0.82rem; margin-top: 4px; }

  .home-section { padding: 58px 0; }
  .section-copy { max-width: 720px; margin-bottom: 26px; }
  .section-copy h2,
  .section-headline h2,
  .home-final h2 {
    margin: 0;
    color: #17352a;
    font-size: clamp(1.65rem, 3vw, 2.45rem);
    line-height: 1.35;
  }
  .section-copy p:not(.section-kicker),
  .home-final p:not(.section-kicker) { color: #53675f; line-height: 1.9; }
  .hoken-focus {
    margin-inline: calc(50% - 50vw);
    padding-inline: max(28px, calc(50vw - 590px));
    background: linear-gradient(180deg, #f2fbf5 0%, #ffffff 100%);
    border-top: 1px solid #dceee4;
    border-bottom: 1px solid #dceee4;
  }
  .hoken-grid,
  .latest-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 18px; }
  .hoken-card,
  .latest-card a,
  .issue-card {
    display: block;
    height: 100%;
    background: #fff;
    border: 1px solid #dce8e2;
    border-radius: 10px;
    overflow: hidden;
    color: inherit;
    text-decoration: none;
    box-shadow: 0 10px 30px rgba(42, 71, 59, .06);
    transition: transform .15s, box-shadow .15s;
  }
  .hoken-card:hover,
  .latest-card a:hover,
  .issue-card:hover { transform: translateY(-2px); box-shadow: 0 16px 40px rgba(42, 71, 59, .11); text-decoration: none; }
  .hoken-card img,
  .latest-card img,
  .issue-card img { width: 100%; aspect-ratio: 16/9; object-fit: cover; background: #edf7f1; }
  .hoken-card span,
  .issue-card span { display: inline-flex; margin: 15px 16px 8px; color: #0f8a5f; font-size: .78rem; font-weight: 900; }
  .hoken-card strong,
  .issue-card strong { display: block; padding: 0 16px 18px; color: #17352a; line-height: 1.55; }

  .section-headline { text-align: center; margin-bottom: 28px; }
  .section-headline.with-link { display: flex; align-items: end; justify-content: space-between; text-align: left; gap: 16px; }
  .section-headline.with-link a { color: #0f8a5f; font-weight: 900; }
  .issue-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; }
  .latest-card { list-style: none; }
  .latest-body { padding: 16px; }
  .category-pill { display: inline-flex; border-radius: 999px; padding: 3px 10px; font-size: .72rem; font-weight: 900; }
  .tone-green { background: #dff5e9; color: #0e6a49; }
  .tone-blue { background: #e0efff; color: #1d5e95; }
  .tone-amber { background: #fff0c2; color: #8a5b00; }
  .tone-yellow { background: #fff7d8; color: #856000; }
  .tone-red { background: #ffe3de; color: #9c3425; }
  .tone-gray { background: #edf1ef; color: #54615c; }
  .latest-body h3 { margin: 10px 0 8px; color: #17352a; font-size: 1rem; line-height: 1.55; }
  .latest-body p {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    min-height: 3.4em;
    margin: 0 0 12px;
    color: #64736d;
    font-size: .86rem;
    line-height: 1.7;
  }
  .latest-body time { color: #8b9994; font-size: .76rem; }
  .home-final {
    margin: 58px 0 20px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 22px;
    padding: 32px;
    border-radius: 12px;
    background: #17352a;
    color: #fff;
  }
  .home-final .section-kicker { color: #f7cf62; }
  .home-final h2 { color: #fff; }
  .home-final p:not(.section-kicker) { color: #d9e9e2; margin-bottom: 0; }

  @media (max-width: 900px) {
    .home-hero { grid-template-columns: 1fr; min-height: auto; }
    .home-hero-visual { max-width: 620px; }
    .trust-strip { grid-template-columns: repeat(2, 1fr); }
    .hoken-grid, .latest-grid { grid-template-columns: repeat(2, 1fr); }
    .issue-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 620px) {
    .home-hero { padding-top: 24px; gap: 28px; }
    .home-actions, .home-btn { width: 100%; }
    .home-proof-card { position: static; margin-top: 10px; }
    .trust-strip, .hoken-grid, .latest-grid, .issue-grid { grid-template-columns: 1fr; }
    .section-headline.with-link, .home-final { display: block; }
    .section-headline.with-link a { display: inline-block; margin-top: 10px; }
    .home-final .home-btn { margin-top: 20px; }
  }
</style>
