---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const mustReadSlugs = [
  'hoken-soudan-muryou-hikaku',
  'hoken-minaoshi-30dai-kaisha-in',
  'fx-kouza-hikaku',
  'dmm-fx-review',
  'nisa-hajimekata',
  'fukugyo-zeikin',
];

const rankingSlugs = [
  'hoken-soudan-muryou-hikaku',
  'dmm-fx-review',
  'fx-kouza-hikaku',
  'hoken-minaoshi-fp-soudan',
  'nisa-hajimekata',
];

const postBySlug = new Map(allPosts.map((post) => [post.id, post]));
const mustReadPosts = mustReadSlugs.map((slug) => postBySlug.get(slug)).filter(Boolean);
const rankingPosts = rankingSlugs.map((slug) => postBySlug.get(slug)).filter(Boolean);
const latestPosts = allPosts.slice(0, 8);

const categoryTone: Record<string, string> = {
  '保険': 'cat-green',
  '保険相談': 'cat-green',
  'FX・外貨': 'cat-red',
  'NISA・投資': 'cat-blue',
  '投資・資産運用': 'cat-blue',
  '副業・節税': 'cat-amber',
  'お得情報': 'cat-yellow',
  'クレジットカード': 'cat-yellow',
  '家計・節約': 'cat-green',
};

const categories = [
  { label: '保険相談', href: '/blog/category/hoken/', count: allPosts.filter((p) => p.data.category.includes('保険')).length },
  { label: 'FX・外貨', href: '/blog/category/fx/', count: allPosts.filter((p) => p.data.category === 'FX・外貨').length },
  { label: 'NISA・投資', href: '/blog/category/nisa/', count: allPosts.filter((p) => p.data.category.includes('投資') || p.data.category.includes('NISA')).length },
  { label: '副業・節税', href: '/blog/category/fukugyo/', count: allPosts.filter((p) => p.data.category === '副業・節税').length },
  { label: '家計・節約', href: '/blog/category/kakei/', count: allPosts.filter((p) => p.data.category === '家計・節約').length },
];

const primary = postBySlug.get('hoken-soudan-muryou-hikaku') ?? allPosts[0];
---

<BaseLayout
  title="田中蓮のマネーブログ"
  description="保険相談・FX・NISA・副業を、30代会社員の目線で比較する収益ブログ。申し込み前に条件・注意点・向き不向きを整理できます。"
  image="/og/hoken-soudan-muryou-hikaku.svg"
  wide={true}
>
  <section class="wp-hero">
    <div>
      <p class="wp-kicker">30代会社員向けの金融・保険アフィリエイトブログ</p>
      <h1>保険相談・FX・NISAを<br />申し込む前に比較するブログ</h1>
      <p class="wp-lead">
        公式サイトを見る前に、条件・注意点・向いている人を整理。
        収益導線は置きつつ、即決させない比較型の記事で信頼を取りにいきます。
      </p>
      <div class="wp-hero-actions">
        <a class="wp-btn primary" href="/blog/hoken-soudan-muryou-hikaku/">無料保険相談を比較する</a>
        <a class="wp-btn ghost" href="/blog/fx-kouza-hikaku/">FX口座を比較する</a>
      </div>
    </div>
    <div class="wp-hero-panel">
      <p>まず読むべき記事</p>
      <a href={`/blog/${primary.id}/`}>
        <img src={primary.data.heroImage ?? `/og/${primary.id}.svg`} alt="" width="420" height="236" />
        <strong>{primary.data.title}</strong>
        <span>{primary.data.description}</span>
      </a>
    </div>
  </section>

  <div class="wp-layout">
    <main class="wp-main">
      <section class="wp-section">
        <div class="wp-section-head">
          <p>START HERE</p>
          <h2>まず読むべき記事</h2>
        </div>
        <div class="featured-grid">
          {mustReadPosts.map((post) => {
            const tone = categoryTone[post.data.category] ?? 'cat-gray';
            return (
              <article class="featured-card">
                <a href={`/blog/${post.id}/`}>
                  <img src={post.data.heroImage ?? `/thumbnails/${post.id}.svg`} alt="" width="360" height="210" loading="lazy" />
                  <div class="featured-body">
                    <span class={`cat ${tone}`}>{post.data.category}</span>
                    <h3>{post.data.title}</h3>
                    <p>{post.data.description}</p>
                  </div>
                </a>
              </article>
            );
          })}
        </div>
      </section>

      <section class="wp-section">
        <div class="wp-section-head">
          <p>RANKING</p>
          <h2>収益導線に近い人気記事</h2>
        </div>
        <div class="ranking-list">
          {rankingPosts.map((post, index) => (
            <article class="ranking-item">
              <a href={`/blog/${post.id}/`}>
                <span class="rank-num">{index + 1}</span>
                <img src={post.data.heroImage ?? `/thumbnails/${post.id}.svg`} alt="" width="132" height="82" loading="lazy" />
                <div>
                  <span class={`cat ${categoryTone[post.data.category] ?? 'cat-gray'}`}>{post.data.category}</span>
                  <h3>{post.data.title}</h3>
                </div>
              </a>
            </article>
          ))}
        </div>
      </section>

      <section class="wp-section cta-box">
        <div>
          <p class="wp-kicker">LINE FUNNEL</p>
          <h2>記事で迷った人をLINEへ回収する</h2>
          <p>保険・FX・NISAのどれから見るべきか、登録後にテーマ別で整理できます。売り込みより先に、比較軸を渡す導線です。</p>
        </div>
        <a class="wp-btn line" href="/line/x-profile-main/">LINEで受け取る</a>
      </section>

      <section class="wp-section">
        <div class="wp-section-head">
          <p>NEW POSTS</p>
          <h2>新着記事</h2>
        </div>
        <div class="post-list">
          {latestPosts.map((post) => {
            const dateStr = post.data.pubDate.toLocaleDateString('ja-JP', { year: 'numeric', month: '2-digit', day: '2-digit' });
            return (
              <article class="post-row">
                <a href={`/blog/${post.id}/`}>
                  <img src={post.data.heroImage ?? `/thumbnails/${post.id}.svg`} alt="" width="176" height="104" loading="lazy" />
                  <div>
                    <span class={`cat ${categoryTone[post.data.category] ?? 'cat-gray'}`}>{post.data.category}</span>
                    <h3>{post.data.title}</h3>
                    <p>{post.data.description}</p>
                    <time datetime={post.data.pubDate.toISOString()}>{dateStr}</time>
                  </div>
                </a>
              </article>
            );
          })}
        </div>
      </section>
    </main>

    <aside class="wp-sidebar">
      <section class="side-card profile">
        <div class="avatar">蓮</div>
        <h2>田中 蓮</h2>
        <p>30代IT会社員。保険・FX・NISA・副業を、会社員目線で比較。広告導線はPRとして明記し、注意点もセットで整理します。</p>
        <a href="/about/">プロフィールを見る</a>
      </section>

      <section class="side-card">
        <h2>カテゴリー</h2>
        <ul class="category-list">
          {categories.map((category) => (
            <li>
              <a href={category.href}>
                <span>{category.label}</span>
                <em>{category.count}</em>
              </a>
            </li>
          ))}
        </ul>
      </section>

      <section class="side-card side-ranking">
        <h2>よく読まれる記事</h2>
        {rankingPosts.slice(0, 4).map((post, index) => (
          <a href={`/blog/${post.id}/`}>
            <span>{index + 1}</span>
            <strong>{post.data.title}</strong>
          </a>
        ))}
      </section>

      <section class="side-card side-cta">
        <p>無料</p>
        <h2>保険・FX・NISAの比較軸をLINEで整理</h2>
        <a href="/line/x-profile-main/">LINEで受け取る</a>
      </section>
    </aside>
  </div>
</BaseLayout>

<style>
  :global(body) {
    background: #f5f6f7;
  }
  .wp-hero {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 420px;
    gap: 32px;
    align-items: center;
    margin: 12px 0 28px;
    padding: 34px;
    background: #fff;
    border: 1px solid #e5e7eb;
    border-radius: 8px;
  }
  .wp-kicker,
  .wp-section-head p {
    margin: 0 0 10px;
    color: #d97706;
    font-size: .78rem;
    font-weight: 900;
    letter-spacing: .08em;
  }
  .wp-hero h1 {
    margin: 0;
    color: #111827;
    font-size: clamp(2.05rem, 4vw, 3.45rem);
    line-height: 1.22;
    letter-spacing: 0;
  }
  .wp-lead {
    max-width: 720px;
    margin: 18px 0 0;
    color: #4b5563;
    font-size: 1rem;
    line-height: 2;
  }
  .wp-hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 24px;
  }
  .wp-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 46px;
    padding: 0 22px;
    border-radius: 6px;
    font-weight: 900;
    text-decoration: none;
  }
  .wp-btn:hover { text-decoration: none; }
  .wp-btn.primary { background: #ef8f00; color: #fff; box-shadow: 0 8px 18px rgba(239,143,0,.22); }
  .wp-btn.ghost { background: #fff; color: #111827; border: 1px solid #d1d5db; }
  .wp-btn.line { background: #06c755; color: #fff; }
  .wp-hero-panel {
    border: 1px solid #e5e7eb;
    border-radius: 8px;
    background: #fafafa;
    padding: 14px;
  }
  .wp-hero-panel > p {
    margin: 0 0 10px;
    font-size: .82rem;
    font-weight: 900;
    color: #111827;
  }
  .wp-hero-panel a {
    display: block;
    color: inherit;
    text-decoration: none;
  }
  .wp-hero-panel img,
  .featured-card img,
  .post-row img,
  .ranking-item img {
    width: 100%;
    object-fit: cover;
    background: #eef2f7;
  }
  .wp-hero-panel img {
    aspect-ratio: 16/9;
    border-radius: 6px;
    border: 1px solid #e5e7eb;
  }
  .wp-hero-panel strong {
    display: block;
    margin-top: 12px;
    color: #111827;
    line-height: 1.55;
  }
  .wp-hero-panel span {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin-top: 6px;
    color: #6b7280;
    font-size: .86rem;
    line-height: 1.7;
  }
  .wp-layout {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 320px;
    gap: 28px;
    align-items: start;
  }
  .wp-section,
  .side-card {
    background: #fff;
    border: 1px solid #e5e7eb;
    border-radius: 8px;
  }
  .wp-section {
    margin-bottom: 24px;
    padding: 24px;
  }
  .wp-section-head {
    margin-bottom: 18px;
    border-bottom: 2px solid #f3f4f6;
    padding-bottom: 12px;
  }
  .wp-section-head h2,
  .cta-box h2,
  .side-card h2 {
    margin: 0;
    color: #111827;
    font-size: 1.35rem;
    line-height: 1.45;
  }
  .featured-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 18px;
  }
  .featured-card,
  .ranking-item,
  .post-row {
    border: 1px solid #e5e7eb;
    border-radius: 8px;
    overflow: hidden;
    background: #fff;
  }
  .featured-card a,
  .ranking-item a,
  .post-row a {
    display: block;
    color: inherit;
    text-decoration: none;
  }
  .featured-card img {
    aspect-ratio: 16/9;
  }
  .featured-body {
    padding: 14px;
  }
  .cat {
    display: inline-flex;
    border-radius: 999px;
    padding: 3px 9px;
    font-size: .72rem;
    font-weight: 900;
  }
  .cat-green { background: #dcfce7; color: #166534; }
  .cat-red { background: #fee2e2; color: #991b1b; }
  .cat-blue { background: #dbeafe; color: #1d4ed8; }
  .cat-amber { background: #fef3c7; color: #92400e; }
  .cat-yellow { background: #fef9c3; color: #854d0e; }
  .cat-gray { background: #f3f4f6; color: #374151; }
  .featured-card h3,
  .ranking-item h3,
  .post-row h3 {
    margin: 9px 0 7px;
    color: #111827;
    font-size: 1rem;
    line-height: 1.55;
  }
  .featured-card p,
  .post-row p,
  .cta-box p {
    color: #6b7280;
    font-size: .88rem;
    line-height: 1.75;
  }
  .featured-card p,
  .post-row p {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin: 0;
  }
  .ranking-list {
    display: grid;
    gap: 12px;
  }
  .ranking-item a {
    display: grid;
    grid-template-columns: 42px 132px minmax(0, 1fr);
    gap: 14px;
    align-items: center;
    padding: 12px;
  }
  .rank-num {
    display: grid;
    place-items: center;
    width: 34px;
    height: 34px;
    border-radius: 50%;
    background: #ef8f00;
    color: #fff;
    font-weight: 900;
  }
  .ranking-item img {
    width: 132px;
    height: 82px;
    border-radius: 6px;
  }
  .cta-box {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    background: #fff8e8;
    border-color: #f7d48b;
  }
  .post-list {
    display: grid;
    gap: 14px;
  }
  .post-row a {
    display: grid;
    grid-template-columns: 176px minmax(0, 1fr);
    gap: 16px;
    padding: 12px;
  }
  .post-row img {
    width: 176px;
    height: 104px;
    border-radius: 6px;
  }
  .post-row time {
    display: inline-block;
    margin-top: 8px;
    color: #9ca3af;
    font-size: .76rem;
  }
  .wp-sidebar {
    position: sticky;
    top: 82px;
    display: grid;
    gap: 18px;
  }
  .side-card {
    padding: 20px;
  }
  .profile {
    text-align: center;
  }
  .avatar {
    display: grid;
    place-items: center;
    width: 72px;
    height: 72px;
    margin: 0 auto 12px;
    border-radius: 50%;
    background: #111827;
    color: #fff;
    font-weight: 900;
    font-size: 1.4rem;
  }
  .profile p {
    color: #6b7280;
    font-size: .88rem;
    line-height: 1.8;
    text-align: left;
  }
  .profile a,
  .side-cta a {
    display: block;
    margin-top: 14px;
    padding: 11px 14px;
    border-radius: 6px;
    background: #111827;
    color: #fff;
    font-weight: 900;
    text-decoration: none;
  }
  .category-list {
    list-style: none;
    margin: 14px 0 0;
    padding: 0;
  }
  .category-list li + li {
    border-top: 1px solid #f3f4f6;
  }
  .category-list a {
    display: flex;
    justify-content: space-between;
    padding: 12px 0;
    color: #111827;
    text-decoration: none;
    font-weight: 800;
  }
  .category-list em {
    color: #9ca3af;
    font-style: normal;
  }
  .side-ranking {
    display: grid;
    gap: 12px;
  }
  .side-ranking a {
    display: grid;
    grid-template-columns: 28px minmax(0, 1fr);
    gap: 10px;
    color: #111827;
    text-decoration: none;
  }
  .side-ranking span {
    display: grid;
    place-items: center;
    width: 24px;
    height: 24px;
    border-radius: 50%;
    background: #ef8f00;
    color: #fff;
    font-size: .78rem;
    font-weight: 900;
  }
  .side-ranking strong {
    font-size: .88rem;
    line-height: 1.55;
  }
  .side-cta {
    background: #ecfdf5;
    border-color: #bbf7d0;
  }
  .side-cta p {
    display: inline-flex;
    margin: 0 0 8px;
    padding: 2px 9px;
    border-radius: 999px;
    background: #06c755;
    color: #fff;
    font-size: .72rem;
    font-weight: 900;
  }
  .side-cta a {
    background: #06c755;
  }
  @media (max-width: 980px) {
    .wp-hero,
    .wp-layout {
      grid-template-columns: 1fr;
    }
    .wp-sidebar {
      position: static;
    }
  }
  @media (max-width: 640px) {
    .wp-hero,
    .wp-section {
      padding: 18px;
    }
    .featured-grid,
    .post-row a,
    .ranking-item a {
      grid-template-columns: 1fr;
    }
    .ranking-item img,
    .post-row img {
      width: 100%;
      height: auto;
      aspect-ratio: 16/9;
    }
    .cta-box {
      display: block;
    }
    .cta-box .wp-btn {
      width: 100%;
      margin-top: 12px;
    }
  }
</style>
