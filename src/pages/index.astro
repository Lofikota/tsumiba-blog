---
import { getCollection } from 'astro:content';
const siteUrl = 'https://ren-money.com';

const websiteJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "田中蓮のマネーブログ",
  "url": siteUrl,
  "description": "借金200万→副業月20万→資産500万。お金の知識で人生を立て直した体験談ベースのメディア。NISA・副業・節税・FXを初心者向けに解説。",
  "publisher": {
    "@type": "Person",
    "name": "田中蓮",
    "url": `${siteUrl}/about/`
  },
  "potentialAction": {
    "@type": "SearchAction",
    "target": { "@type": "EntryPoint", "urlTemplate": `${siteUrl}/blog/?q={search_term_string}` },
    "query-input": "required name=search_term_string"
  }
});

const personJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "田中蓮",
  "url": `${siteUrl}/about/`,
  "description": "32歳IT会社員。借金200万円から副業・投資で資産500万円を達成。35歳FIREを目指して発信中。",
  "knowsAbout": ["FX", "NISA", "副業", "節税", "投資", "保険"],
  "mainEntityOfPage": `${siteUrl}/about/`
});
const allPosts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
type CatStyle = { cls: string; bg: string };
const catStyle: Record<string, CatStyle> = {
  'NISA・投資': { cls: 'cat-invest',  bg: 'linear-gradient(135deg,#DBEAFE,#93C5FD)' },
  '副業・節税': { cls: 'cat-income',  bg: 'linear-gradient(135deg,#D4EDDA,#86EFAC)' },
  'お得情報':   { cls: 'cat-savings', bg: 'linear-gradient(135deg,#FEF3C7,#FDE68A)' },
  'FX・外貨':   { cls: 'cat-debt',    bg: 'linear-gradient(135deg,#FFE4E6,#FCA5A5)' },
};
---
<!doctype html>
<html lang="ja">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width,initial-scale=1"/>
  <title>田中蓮のマネーブログ | 副業・NISA・節税でFIREを目指す32歳のリアル体験談。</title>
  <meta name="description" content="借金200万→副業月20万→資産500万。お金の知識で人生を立て直した体験談ベースのメディア。NISA・副業・節税を初心者向けにわかりやすく解説。"/>
  <meta name="robots" content="index,follow"/>
  <link rel="canonical" href={`${siteUrl}/`}/>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700;900&family=Noto+Serif+JP:wght@700;900&display=swap" rel="stylesheet"/>

  <style is:global>
  /* ═══════════════════════════════════════
     DESIGN TOKENS — 田中蓮のマネーブログ (Blue)
  ═══════════════════════════════════════ */
  :root {
    --c-blue:     #2563EB;
    --c-blue-d:   #1D4ED8;
    --c-blue-dd:  #1E3A8A;
    --c-blue-50:  #EFF6FF;
    --c-blue-100: #DBEAFE;
    --c-ink:      #1F2937;
    --c-gray:     #6B7280;
    --c-gray-l:   #F3F4F6;
    --c-yellow:   #FBBF24;
    --c-green:    #16A34A;
    --c-red:      #DC2626;
    --c-white:    #FFFFFF;
    --c-border:   #E5E7EB;
    --sh-card:    0 2px 8px rgba(0,0,0,.08), 0 0 0 1px rgba(0,0,0,.04);
    --r-md:       10px;
    --r-pill:     999px;
    --sans: "Noto Sans JP", "Hiragino Kaku Gothic ProN", sans-serif;
    --serif: "Noto Serif JP", "Hiragino Mincho ProN", serif;
  }

  /* ── Reset ── */
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }
  body {
    font-family: var(--sans);
    color: var(--c-ink);
    background: var(--c-white);
    font-size: 15px;
    line-height: 1.75;
    -webkit-font-smoothing: antialiased;
    overflow-x: hidden;
  }
  img { max-width: 100%; display: block; }
  a   { color: inherit; text-decoration: none; }
  button { font-family: inherit; cursor: pointer; border: none; background: none; }

  /* ── Layout ── */
  .container        { max-width: 1080px; margin: 0 auto; padding: 0 28px; }
  .container--narrow{ max-width: 780px;  margin: 0 auto; padding: 0 28px; }
  .section          { padding: 64px 0; }
  .section--tint    { background: var(--c-blue-50); }
  .section--white   { background: var(--c-white); }

  /* ── Section heading ── */
  .section-label {
    display: inline-block;
    font-size: 11px; font-weight: 700; letter-spacing: .16em;
    text-transform: uppercase; color: var(--c-blue);
    margin-bottom: 8px;
  }
  .section-title {
    font-size: clamp(20px, 3vw, 28px);
    font-weight: 900; line-height: 1.4;
    color: var(--c-ink);
    margin-bottom: 10px;
  }
  .section-sub { font-size: 13.5px; color: var(--c-gray); line-height: 1.8; }
  .section-head { text-align: center; margin-bottom: 40px; }

  /* ── Buttons ── */
  .btn {
    display: inline-flex; align-items: center; justify-content: center; gap: 8px;
    padding: 14px 26px; border-radius: var(--r-md);
    font-weight: 700; font-size: 15px; letter-spacing: .02em;
    transition: filter .15s, transform .1s;
    white-space: nowrap;
  }
  .btn:hover { filter: brightness(1.08); transform: translateY(-1px); }
  .btn-primary { background: var(--c-blue); color: #fff; }
  .btn-outline  {
    background: transparent; color: #fff;
    border: 2px solid rgba(255,255,255,.6);
  }
  .btn-outline:hover { background: rgba(255,255,255,.12); }
  .btn-lg { padding: 16px 32px; font-size: 16px; border-radius: 12px; }
  .arrow  { font-size: 18px; }

  /* ═══════════════════════════════════════
     ANNOUNCE BAR
  ═══════════════════════════════════════ */
  .announce-bar {
    background: var(--c-blue-100);
    border-bottom: 1px solid #BFDBFE;
    padding: 9px 24px;
    font-size: 11.5px; color: #1E40AF;
    text-align: center; font-weight: 500;
  }

  /* ═══════════════════════════════════════
     HEADER
  ═══════════════════════════════════════ */
  .site-header {
    background: var(--c-white);
    border-bottom: 1px solid var(--c-border);
    position: sticky; top: 0; z-index: 60;
    box-shadow: 0 1px 4px rgba(0,0,0,.06);
  }
  .header-inner {
    display: flex; align-items: center;
    justify-content: space-between;
    height: 60px;
  }
  .brand { display: inline-flex; align-items: center; gap: 9px; text-decoration: none; }
  .brand-text { font-weight: 700; font-size: 15px; color: var(--c-ink); letter-spacing: .02em; }
  .nav { display: flex; gap: 24px; }
  .nav-link { font-size: 13px; font-weight: 500; color: var(--c-ink); opacity: .7; transition: opacity .15s; }
  .nav-link:hover { opacity: 1; color: var(--c-blue); }

  /* ═══════════════════════════════════════
     HERO
  ═══════════════════════════════════════ */
  .hero {
    background:
      radial-gradient(circle at 18% 18%, rgba(59,130,246,.28) 0, rgba(59,130,246,0) 34%),
      linear-gradient(160deg, #1a3a7a 0%, #2563EB 100%);
    color: #fff;
    overflow: hidden;
    padding: 48px 0 60px;
    position: relative;
  }
  .hero::before {
    content: '';
    position: absolute; inset: 0;
    background-image: radial-gradient(circle, rgba(255,255,255,.05) 1px, transparent 1px);
    background-size: 28px 28px;
    pointer-events: none;
  }
  .hero-inner {
    position: relative;
    display: grid;
    grid-template-columns: 1.05fr .95fr;
    gap: 40px;
    align-items: center;
  }
  .hero-eyebrow {
    font-size: 11px; font-weight: 700; letter-spacing: .18em;
    text-transform: uppercase; color: var(--c-yellow);
    margin-bottom: 20px;
    text-shadow: 0 1px 12px rgba(0,0,0,.18);
    animation: fadeUp .5s ease forwards;
  }
  .hero-h1 {
    font-size: clamp(30px, 4vw, 48px);
    font-weight: 900; line-height: 1.3;
    margin-bottom: 20px;
    max-width: 680px;
    text-shadow: 0 2px 18px rgba(0,0,0,.22);
    animation: fadeUp .6s ease .1s both;
  }
  .hero-h1 strong {
    color: #FBBF24;
    text-shadow: 0 2px 16px rgba(0,0,0,.28);
  }
  .hero-lead {
    font-size: 15px; line-height: 1.95; color: rgba(255,255,255,.94);
    margin-bottom: 28px;
    text-shadow: 0 1px 10px rgba(0,0,0,.18);
    animation: fadeUp .6s ease .2s both;
  }
  .hero-disclaimer { display: block; font-size: 11px; color: rgba(255,255,255,.78); margin-top: 8px; }
  .hero-cta-row { display: flex; gap: 14px; flex-wrap: wrap; margin-bottom: 32px; animation: fadeUp .6s ease .3s both; }
  .hero .btn-primary {
    background: #fff;
    color: #163D91;
    box-shadow: 0 4px 0 rgba(15,23,42,.26), 0 10px 28px rgba(15,23,42,.18);
  }
  .hero .btn-outline {
    background: rgba(15,23,42,.14);
    border-color: rgba(255,255,255,.78);
    box-shadow: inset 0 0 0 1px rgba(255,255,255,.16);
  }
  .hero-stats {
    display: flex; gap: 0;
    border-top: 1px solid rgba(255,255,255,.34);
    padding-top: 24px;
    animation: fadeUp .6s ease .4s both;
  }
  .hero-stat {
    flex: 1; text-align: center; padding: 0 16px;
    border-right: 1px solid rgba(255,255,255,.30);
  }
  .hero-stat:last-child { border-right: none; }
  .hero-stat-num   { display: block; font-size: 26px; font-weight: 900; color: var(--c-yellow); }
  .hero-stat-label { display: block; font-size: 11px; color: rgba(255,255,255,.86); line-height: 1.5; margin-top: 3px; }

  .hero-art {
    background: rgba(18,54,139,.72);
    border: 1px solid rgba(255,255,255,.34);
    border-radius: 16px;
    padding: 28px 24px;
    backdrop-filter: blur(2px);
    box-shadow: 0 24px 60px rgba(15,23,42,.22), inset 0 1px 0 rgba(255,255,255,.14);
    animation: fadeUp .7s ease .2s both;
  }
  .hero-tl-heading {
    font-size: 10px; font-weight: 700; letter-spacing: .18em;
    text-transform: uppercase; color: rgba(255,255,255,.72);
    margin-bottom: 18px;
  }
  /* vertical timeline layout */
  .hero-tl-row { display: flex; gap: 14px; }
  .hero-tl-left { display: flex; flex-direction: column; align-items: center; flex-shrink: 0; }
  .hero-tl-icon {
    width: 42px; height: 42px; border-radius: 50%; flex-shrink: 0;
    display: flex; align-items: center; justify-content: center;
  }
  .hero-tl-icon--red   { background: rgba(239,68,68,.18);  border: 1.5px solid rgba(239,68,68,.55);  color: #FCA5A5; }
  .hero-tl-icon--amber { background: rgba(251,191,36,.15); border: 1.5px solid rgba(251,191,36,.55); color: #FCD34D; }
  .hero-tl-icon--green { background: rgba(34,197,94,.18);  border: 1.5px solid rgba(34,197,94,.55);  color: #86EFAC; }
  .hero-tl-connector { width: 2px; flex: 1; min-height: 12px; background: rgba(255,255,255,.22); margin: 4px 0; }
  .hero-tl-body { padding: 3px 0 16px; }
  .hero-tl-year  { font-size: 10.5px; color: rgba(255,255,255,.70); letter-spacing: .06em; font-weight: 700; }
  .hero-tl-num   { font-size: 23px; font-weight: 900; color: var(--c-yellow); line-height: 1.1; margin: 2px 0 3px; }
  .hero-tl-desc  { font-size: 12px; color: rgba(255,255,255,.86); }
  /* mini sparkline */
  .hero-sparkline { margin-top: 2px; padding-top: 14px; border-top: 1px solid rgba(255,255,255,.20); }
  .hero-spark-lbl { font-size: 9px; color: rgba(255,255,255,.58); letter-spacing: .14em; margin-bottom: 8px; }
  .hero-spark-years { display: flex; justify-content: space-between; font-size: 9px; color: rgba(255,255,255,.62); margin-top: 4px; padding: 0 2px; }
  .hero-tl-footer {
    margin-top: 12px; padding-top: 12px;
    border-top: 1px solid rgba(255,255,255,.20);
    font-size: 12px; font-weight: 700; color: var(--c-yellow);
    text-align: center; letter-spacing: .04em;
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ═══════════════════════════════════════
     SUB-BANNER
  ═══════════════════════════════════════ */
  .subbanner {
    margin: -28px auto 0;
    background: var(--c-white);
    border-radius: 12px;
    border: 1px solid var(--c-blue-100);
    box-shadow: var(--sh-card);
    padding: 18px 22px;
    display: flex; align-items: center; justify-content: space-between;
    gap: 20px;
    position: relative; z-index: 5;
  }
  .sb-left  { display: flex; align-items: center; gap: 16px; }
  .sb-icon  {
    width: 52px; height: 52px; border-radius: 10px;
    background: var(--c-blue-50);
    display: flex; align-items: center; justify-content: center; flex-shrink: 0;
  }
  .sb-title { font-size: 15px; font-weight: 700; color: var(--c-ink); }
  .sb-sub   { font-size: 12px; color: var(--c-gray); margin-top: 2px; }
  .sb-link  {
    display: inline-flex; align-items: center; gap: 6px;
    background: var(--c-blue); color: #fff;
    padding: 10px 16px; border-radius: var(--r-md);
    font-weight: 700; font-size: 13px; white-space: nowrap; flex-shrink: 0;
  }
  .sb-link:hover { background: var(--c-blue-d); }

  /* ═══════════════════════════════════════
     PROBLEM SECTION
  ═══════════════════════════════════════ */
  .problem-grid {
    display: grid; grid-template-columns: repeat(3,1fr); gap: 16px;
    margin-top: 24px;
  }
  .problem-card {
    background: var(--c-white); border: 1px solid var(--c-border);
    border-radius: 12px; padding: 24px 20px;
    border-top: 3px solid var(--c-blue);
  }
  .problem-num { font-size: 11px; font-weight: 700; color: var(--c-blue); letter-spacing: .1em; margin-bottom: 8px; }
  .problem-icon { font-size: 28px; margin-bottom: 10px; }
  .problem-title { font-size: 15px; font-weight: 700; line-height: 1.5; margin-bottom: 8px; }
  .problem-body  { font-size: 12.5px; color: var(--c-gray); line-height: 1.7; }

  /* ═══════════════════════════════════════
     MANGA / 4コマ
  ═══════════════════════════════════════ */
  .manga-img-wrap { margin-top: 28px; border-radius: 12px; overflow: hidden; box-shadow: var(--sh-card); }
  .manga-strip-img { width: 100%; height: auto; display: block; }

  /* ═══════════════════════════════════════
     ACHIEVEMENT BAR
  ═══════════════════════════════════════ */
  .achievement-bar {
    background: var(--c-blue-dd); color: #fff; padding: 28px 0;
  }
  .achievement-inner {
    display: flex; justify-content: space-around; align-items: center;
    flex-wrap: wrap; gap: 16px;
  }
  .achievement-item { text-align: center; }
  .achievement-num   { display: block; font-size: 26px; font-weight: 900; color: var(--c-yellow); }
  .achievement-label { display: block; font-size: 11px; opacity: .75; margin-top: 3px; line-height: 1.5; }

  /* ═══════════════════════════════════════
     THEMES (4 cards)
  ═══════════════════════════════════════ */
  .themes-grid {
    display: grid; grid-template-columns: repeat(2,1fr); gap: 16px;
    margin-top: 24px;
  }
  .theme-card {
    background: var(--c-white); border: 1px solid var(--c-border);
    border-radius: 12px; padding: 22px 22px 22px 80px;
    position: relative; min-height: 100px;
    transition: box-shadow .15s;
  }
  .theme-card:hover { box-shadow: var(--sh-card); }
  .theme-icon-wrap {
    position: absolute; left: 20px; top: 22px;
    width: 44px; height: 44px;
    background: var(--c-blue-50); border-radius: 10px;
    display: flex; align-items: center; justify-content: center;
  }
  .theme-title { font-size: 15px; font-weight: 700; margin-bottom: 6px; }
  .theme-body  { font-size: 12.5px; color: var(--c-gray); line-height: 1.7; }

  /* ═══════════════════════════════════════
     LINE CTA BANNER
  ═══════════════════════════════════════ */
  .line-banner {
    background: #06c755;
    color: #fff;
    border-radius: 12px;
    padding: 18px 22px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 40px;
    box-shadow: 0 4px 16px rgba(6,199,85,0.22);
  }
  .line-banner-left { display: flex; align-items: center; gap: 14px; }
  .line-banner-icon {
    width: 46px; height: 46px;
    background: rgba(255,255,255,0.2);
    border-radius: 12px;
    display: flex; align-items: center; justify-content: center; flex-shrink: 0;
  }
  .line-banner-title { font-size: 15px; font-weight: 700; margin: 0 0 3px; }
  .line-banner-sub   { font-size: 12px; opacity: 0.9; margin: 0; }
  .line-banner-btn {
    background: #fff; color: #059952;
    font-weight: 800; font-size: 13px;
    padding: 10px 18px; border-radius: 8px;
    white-space: nowrap; flex-shrink: 0;
    transition: opacity 0.15s;
  }
  .line-banner-btn:hover { opacity: 0.88; text-decoration: none; }
  @media (max-width: 640px) {
    .line-banner { flex-direction: column; align-items: flex-start; }
    .line-banner-btn { width: 100%; text-align: center; }
  }

  /* ═══════════════════════════════════════
     ARTICLES
  ═══════════════════════════════════════ */
  .articles-grid {
    display: grid; grid-template-columns: repeat(3,1fr); gap: 18px;
    margin-top: 24px;
  }
  .article-card {
    background: var(--c-white); border: 1px solid var(--c-border);
    border-radius: 10px; overflow: hidden;
    transition: transform .15s, box-shadow .15s;
  }
  .article-card:hover { transform: translateY(-2px); box-shadow: var(--sh-card); }
  .article-thumb {
    aspect-ratio: 16/10;
    display: flex; align-items: center; justify-content: center;
  }
  .article-body { padding: 14px 16px 16px; }
  .article-cat  { font-size: 11px; font-weight: 700; padding: 3px 10px; border-radius: 4px; }
  .cat-invest  { background: #DBEAFE; color: #1E40AF; }
  .cat-income  { background: #D1FAE5; color: #065F46; }
  .cat-savings { background: #FEF3C7; color: #92400E; }
  .cat-debt    { background: #FEE2E2; color: #991B1B; }
  .article-title {
    font-size: 14px; font-weight: 700; margin: 8px 0 10px;
    line-height: 1.55; color: var(--c-ink);
  }
  .article-desc { font-size: 12px; color: var(--c-gray); line-height: 1.65; margin: 6px 0 8px; }
  .article-meta { display: inline-flex; align-items: center; gap: 4px; font-size: 11px; color: var(--c-gray); }

  /* ═══════════════════════════════════════
     REASONS
  ═══════════════════════════════════════ */
  .reasons-grid {
    display: grid; grid-template-columns: repeat(4,1fr); gap: 16px;
    margin-top: 24px;
  }
  .reason-card {
    background: var(--c-white); border: 1px solid var(--c-blue-100);
    border-radius: 12px; padding: 20px 16px;
    text-align: center; display: flex; flex-direction: column; align-items: center;
  }
  .reason-badge {
    display: inline-block; background: var(--c-blue); color: #fff;
    font-size: 11px; font-weight: 700;
    padding: 4px 12px; border-radius: var(--r-pill); margin-bottom: 12px;
  }
  .reason-icon-wrap {
    width: 64px; height: 64px; border-radius: 50%;
    background: var(--c-blue-50);
    display: flex; align-items: center; justify-content: center;
    margin-bottom: 10px; overflow: hidden;
  }
  .reason-text { font-size: 12px; line-height: 1.7; color: var(--c-ink); text-align: center; }

  /* ═══════════════════════════════════════
     COMPARE TABLE
  ═══════════════════════════════════════ */
  .compare-wrap {
    border-radius: 12px; overflow: hidden;
    border: 1px solid var(--c-border); margin-top: 24px;
  }
  .compare-table { width: 100%; border-collapse: collapse; font-size: 13px; }
  .compare-table thead { background: var(--c-blue); color: #fff; }
  .compare-table th { padding: 13px 14px; font-weight: 700; text-align: center; }
  .compare-table th:first-child { text-align: left; }
  .compare-table td { padding: 12px 14px; border-bottom: 1px solid var(--c-border); vertical-align: middle; }
  .compare-table tr:last-child td { border-bottom: none; }
  .compare-table td:first-child { font-weight: 700; background: var(--c-blue-50); color: var(--c-ink); }
  .compare-table td:not(:first-child) { text-align: center; }
  .highlight-cell { color: var(--c-blue); font-weight: 700; }
  .badge-top {
    display: inline-block; background: #F59E0B; color: #fff;
    font-size: 9px; font-weight: 800; padding: 1px 5px; border-radius: 3px;
    margin-left: 4px; vertical-align: middle; letter-spacing: .03em;
  }
  .btn-compare {
    display: inline-flex; align-items: center; justify-content: center;
    background: var(--c-blue); color: #fff;
    padding: 7px 12px; border-radius: 6px;
    font-size: 12px; font-weight: 700; width: 100%;
    transition: background .15s;
  }
  .btn-compare:hover { background: var(--c-blue-d); }

