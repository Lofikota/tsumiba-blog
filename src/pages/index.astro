  ═══════════════════════════════════════ */
  .finalcta {
    background: linear-gradient(180deg, #1E3A8A 0%, #2563EB 100%);
    color: #fff; padding: 64px 28px; text-align: center;
  }
  .finalcta-eyebrow {
    display: inline-block; font-size: 11px; font-weight: 700;
    letter-spacing: .18em; color: var(--c-yellow);
    text-transform: uppercase; margin-bottom: 16px;
  }
  .finalcta-h { font-size: clamp(22px,3.5vw,32px); font-weight: 900; margin-bottom: 10px; }
  .finalcta-sub { font-size: 14px; opacity: .85; margin-bottom: 28px; }
  .finalcta-row { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }
  .btn-ghost { background: rgba(255,255,255,.1); color: #fff; border: 2px solid rgba(255,255,255,.5); }
  .btn-ghost:hover { background: rgba(255,255,255,.2); }
  .btn-sage  { background: #1E6B45; color: #fff; }
  .btn-sage:hover { background: #166035; }
  .btn-navy  { background: var(--c-blue-dd); color: #fff; }
  .btn-navy:hover { background: #172554; }

  /* ═══════════════════════════════════════
     FOOTER
  ═══════════════════════════════════════ */
  .footer { background: #0F1A3A; color: #C7D2FE; padding-top: 40px; }
  .footer-grid {
    display: grid; grid-template-columns: repeat(4,1fr); gap: 24px;
    padding-bottom: 28px;
  }
  .footer-h { color: #fff; font-weight: 700; font-size: 13px; margin-bottom: 10px; }
  .footer-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 6px; font-size: 12px; }
  .footer-list a:hover { color: #fff; }
  .footer-bottom {
    border-top: 1px solid rgba(255,255,255,.1); padding: 16px 0; font-size: 11px;
  }
  .footer-bottom-inner { display: flex; align-items: center; justify-content: space-between; }
  .footer-brand { display: flex; align-items: center; gap: 8px; color: #fff; font-weight: 700; font-size: 13px; }
  .footer-copy  { color: #9CA3AF; }

  /* Sticky CTA */
  .sticky-cta {
    position: fixed; bottom: 16px; left: 50%; transform: translateX(-50%);
    z-index: 100; opacity: 0; pointer-events: none;
