---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection, type CollectionEntry } from 'astro:content';
import { CATEGORIES } from '../data/categories';
import { getAffiliatePath } from '../data/affiliateLinks';

// 稼働中アフィリエイトリンク(status:'affiliate')のみ掲載。承認が増えたらここに追加する。
const recommendedAccounts = [
  {
    slug: 'jfx',
    tag: '短期・スキャルピング向け',
    name: 'JFX MATRIX TRADER',
    point: '約定力とスプレッドの狭さに定評。1,000通貨から取引でき、短期売買を試したい人に向く口座です。',
    specs: ['最小1,000通貨〜', '高機能ツール MATRIX TRADER', '平日サポート'],
    reviewHref: '/blog/jfx-review/',
  },
  {
    slug: 'fxtf',
    tag: 'MT4・裁量トレード向け',
    name: 'FXTF',
    point: '世界標準ツールMT4が使える数少ない国内口座。少額から自動売買やカスタム分析をしたい人に向きます。',
    specs: ['最小1,000通貨〜', 'MT4対応', '少額から始めやすい'],
    reviewHref: '/blog/fxtf-review/',
  },
  {
    slug: 'central-tanshi-fx',
    tag: '高金利スワップ・中長期向け',
    name: 'セントラル短資FX',
    point: '老舗の短資会社グループ。高金利通貨のスワップや「みらいチャート」など、中長期でじっくり運用したい人に向きます。',
    specs: ['最小1,000通貨〜', '取引手数料0円', 'みらいチャート搭載'],
    reviewHref: '/blog/fx-kouza-hikaku/',
  },
];

const allPosts = (await getCollection('blog', (e: CollectionEntry<'blog'>) => !e.data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const postBySlug = new Map(allPosts.map((post) => [post.id, post]));

const pickPosts = (slugs: string[]) => slugs.map((slug) => postBySlug.get(slug)).filter((post): post is typeof allPosts[number] => Boolean(post));

const moneyRoutePosts = pickPosts([
  'fx-kouza-hikaku',
  'jfx-review',
  'fxtf-review',
  'dmm-fx-review',
  'fx-shoshinsha-guide',
  'fx-small-start-guide',
]);

const rankingPosts = pickPosts([
  'jfx-review',
  'fxtf-review',
  'dmm-fx-review',
  'fx-shoshinsha-guide',
  'fx-small-start-guide',
]);

const latestPosts = allPosts.filter((post) => post.data.category === 'FX・外貨' || post.id.includes('fx')).slice(0, 10);
const primary = postBySlug.get('fx-kouza-hikaku') ?? latestPosts[0] ?? allPosts[0];

const categoryTone: Record<string, string> = {
  'FX・外貨': 'tone-fx',
};

const countBySlugs = (slugs: string[]) => slugs.filter((slug) => postBySlug.has(slug)).length;

const categoryNav = [
  { name: 'FX口座比較', lead: 'JFX・FXTFを優先比較', icon: 'FX', href: `/blog/category/${CATEGORIES['FX口座比較'].slug}/`, count: countBySlugs(CATEGORIES['FX口座比較'].matchSlugs ?? []) },
  { name: 'FX初心者ガイド', lead: '仕組みと始め方を確認', icon: '入', href: `/blog/category/${CATEGORIES['FX初心者ガイド'].slug}/`, count: countBySlugs(CATEGORIES['FX初心者ガイド'].matchSlugs ?? []) },
  { name: 'JFX', lead: '短期売買との相性を確認', icon: 'J', href: `/blog/category/${CATEGORIES['JFX'].slug}/`, count: countBySlugs(CATEGORIES['JFX'].matchSlugs ?? []) },
  { name: 'FXTF', lead: '少額取引とツールを確認', icon: 'F', href: `/blog/category/${CATEGORIES['FXTF'].slug}/`, count: countBySlugs(CATEGORIES['FXTF'].matchSlugs ?? []) },
  { name: 'DMM FX', lead: 'リンク確認中の参考情報', icon: 'D', href: `/blog/category/${CATEGORIES['DMM FX'].slug}/`, count: countBySlugs(CATEGORIES['DMM FX'].matchSlugs ?? []) },
  { name: 'FXリスク管理', lead: '損失・税金・会社員の注意点', icon: '守', href: `/blog/category/${CATEGORIES['FXリスク管理'].slug}/`, count: countBySlugs(CATEGORIES['FXリスク管理'].matchSlugs ?? []) },
];

const conversionBoxes = [
  {
    label: 'FX口座比較',
    title: 'まずJFX・FXTFを比べたい',
    body: 'JFX、FXTFを優先し、DMM FXはリンク確認中の参考情報として整理。',
    href: '/blog/fx-kouza-hikaku/',
  },
  {
    label: 'JFX',
    title: '取引機能を重視したい',
    body: 'JFXのMT4対応、約定力、短期売買との相性を確認。',
    href: '/blog/jfx-review/',
  },
  {
    label: 'LINE',
    title: '自分に合う順番で読みたい',
    body: 'FX口座比較、初心者ガイド、リスク管理の記事を迷わず読める順番で案内。',
    href: '/line/x-profile-main/',
  },
];

const formatDate = (date: Date) => date.toLocaleDateString('ja-JP', { year: 'numeric', month: '2-digit', day: '2-digit' });
const imageFor = (post: typeof allPosts[number]) => post.data.heroImage ?? `/og/${post.id}.svg`;
---

<BaseLayout
  title="会社員向けFX口座比較ブログ"
  description="JFX・FXTFを優先し、DMM FXはリンク確認中の参考情報として、スプレッド、取引単位、ツール、リスク、向いている人を会社員目線で整理するFX特化ブログです。"
  image="/og/fx-kouza-hikaku.svg"
  wide={true}
>
  <section class="site-hero">
    <div class="hero-copy">
      <p class="eyebrow">会社員向けFX口座比較ブログ</p>
      <h1>JFX・FXTFを<br />申し込む前に比較。</h1>
      <p class="hero-lead">
        スプレッド、取引単位、ツール、リスク、向いている人を整理。
        会社員がFX口座を選ぶ前に、条件と注意点を落ち着いて確認できるブログです。
      </p>
      <div class="hero-buttons">
        <a class="btn btn-main" href="/blog/fx-kouza-hikaku/">FX口座を比較する</a>
        <a class="btn btn-sub" href="/blog/jfx-review/">JFXのレビューを見る</a>
      </div>
      <ul class="trust-row" aria-label="ブログの方針">
        <li>PR表記あり</li>
        <li>注意点も記載</li>
        <li>30代会社員目線</li>
      </ul>
    </div>

    <a class="hero-feature" href={`/blog/${primary.id}/`}>
      <span class="feature-label">最初に読むなら</span>
      <img src={imageFor(primary)} alt="" width="620" height="360" />
      <div class="feature-body">
        <span class={`cat ${categoryTone[primary.data.category] ?? 'tone-gray'}`}>{primary.data.category}</span>
        <h2>{primary.data.title}</h2>
        <p>{primary.data.description}</p>
      </div>
    </a>
  </section>

  <section class="pick-band" aria-label="タイプ別おすすめFX口座">
    <div class="pick-head">
      <p>PICK UP <span class="pr-badge">PR</span></p>
      <h2>タイプ別・いま開けるFX口座</h2>
      <span class="pick-note">編集部が実際の取引条件で比較。あなたの取引スタイルに合う口座から確認できます。</span>
    </div>
    <div class="pick-grid">
      {recommendedAccounts.map((acc) => (
        <div class="pick-card">
          <span class="pick-tag">{acc.tag}</span>
          <h3>{acc.name}</h3>
          <p class="pick-point">{acc.point}</p>
          <ul class="pick-specs">
            {acc.specs.map((spec) => <li>{spec}</li>)}
          </ul>
          <div class="pick-actions">
            <a class="pick-cta" href={getAffiliatePath(acc.slug)} target="_blank" rel="nofollow sponsored noopener">公式サイトで口座開設</a>
            <a class="pick-review" href={acc.reviewHref}>レビューを読む</a>
          </div>
        </div>
      ))}
    </div>
    <p class="pick-risk">FXには元本割れや預け入れた資金を上回る損失が発生するリスクがあります。取引条件は各社公式サイトで最新情報をご確認ください。</p>
  </section>

  <nav class="category-strip" aria-label="主要カテゴリ">
    {categoryNav.map((category) => (
      <a href={category.href}>
        <span>{category.icon}</span>
        <strong>{category.name}</strong>
        <em>{category.lead}</em>
      </a>
    ))}
  </nav>

  <div class="page-grid">
    <main class="content-stack">
      <section class="section-block" id="articles">
        <div class="section-title">
          <p>START HERE</p>
          <h2>まず読むべきFX記事</h2>
        </div>
        <div class="lead-grid">
          {moneyRoutePosts.map((post, index) => (
            <article class:list={['lead-card', index === 0 && 'lead-card-large']}>
              <a href={`/blog/${post.id}/`}>
                <img src={imageFor(post)} alt="" width="420" height="236" loading={index === 0 ? undefined : 'lazy'} />
                <div class="lead-card-body">
                  <span class={`cat ${categoryTone[post.data.category] ?? 'tone-gray'}`}>{post.data.category}</span>
                  <h3>{post.data.title}</h3>
                  <p>{post.data.description}</p>
                </div>
              </a>
            </article>
          ))}
        </div>
      </section>

      <section class="section-block">
        <div class="section-title">
          <p>CONVERSION ROUTE</p>
          <h2>申し込み前の迷い別入口</h2>
        </div>
        <div class="route-grid">
          {conversionBoxes.map((box) => (
            <a class="route-card" href={box.href}>
              <span>{box.label}</span>
              <strong>{box.title}</strong>
              <p>{box.body}</p>
            </a>
          ))}
        </div>
      </section>

      <section class="section-block">
        <div class="section-title">
          <p>RANKING</p>
          <h2>FX口座・初心者記事ランキング</h2>
        </div>
        <div class="ranking-list">
          {rankingPosts.map((post, index) => (
            <article class="ranking-item">
              <a href={`/blog/${post.id}/`}>
                <span class="rank">{index + 1}</span>
                <img src={imageFor(post)} alt="" width="168" height="96" loading="lazy" />
                <div>
                  <span class={`cat ${categoryTone[post.data.category] ?? 'tone-gray'}`}>{post.data.category}</span>
                  <h3>{post.data.title}</h3>
                  <p>{post.data.description}</p>
                </div>
              </a>
            </article>
          ))}
        </div>
      </section>

      <section class="line-band">
        <div>
          <p>無料LINE</p>
          <h2>FX口座選びで迷ったら</h2>
          <span>JFX・FXTFの比較軸と、初心者が申し込み前に見るべきリスクを整理して送ります。DMM FXはリンク確認後に再開します。</span>
        </div>
        <a href="/line/x-profile-main/">LINEでFX比較軸を受け取る</a>
      </section>

      <section class="section-block">
        <div class="section-title">
          <p>NEW POSTS</p>
          <h2>新着記事</h2>
        </div>
        <div class="new-list">
          {latestPosts.map((post) => (
            <article class="new-row">
              <a href={`/blog/${post.id}/`}>
                <img src={imageFor(post)} alt="" width="190" height="108" loading="lazy" />
                <div>
                  <span class={`cat ${categoryTone[post.data.category] ?? 'tone-gray'}`}>{post.data.category}</span>
                  <h3>{post.data.title}</h3>
                  <p>{post.data.description}</p>
                  <time datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate)}</time>
                </div>
              </a>
            </article>
          ))}
        </div>
      </section>
    </main>

    <aside class="sidebar">
      <section class="side-card profile-card">
        <div class="profile-top">
          <div class="profile-photo">FX</div>
          <div>
            <p>運営</p>
            <h2>FX口座比較ナビ 編集部</h2>
          </div>
        </div>
        <p class="profile-text">
          国内・海外FX口座の条件・ツール・スプレッド・リスクを、会社員目線で比較・整理する編集部です。広告導線はPRとして明記し、初心者が申し込み前に確認すべき注意点までまとめます。
        </p>
        <a href="/about/">このサイトについて</a>
      </section>

      <section class="side-card">
        <h2>カテゴリー</h2>
        <div class="side-category-list">
          {categoryNav.map((category) => (
            <a href={category.href}>
              <span>{category.name}</span>
              <em>{category.count}</em>
            </a>
          ))}
        </div>
      </section>

      <section class="side-card hot-card">
        <h2>今の主導線</h2>
        <ol>
          <li><a href="/blog/fx-kouza-hikaku/">FX口座比較を見る</a></li>
          <li><a href="/blog/jfx-review/">JFXの条件を見る</a></li>
          <li><a href="/blog/fxtf-review/">FXTFの条件を見る</a></li>
          <li><a href="/blog/fx-shoshinsha-guide/">FX初心者ガイドを見る</a></li>
        </ol>
      </section>

      <section class="side-card side-ranking">
        <h2>人気記事</h2>
        {rankingPosts.slice(0, 4).map((post, index) => (
          <a href={`/blog/${post.id}/`}>
            <span>{index + 1}</span>
            <strong>{post.data.title}</strong>
          </a>
        ))}
      </section>

      <section class="side-card side-line">
        <p>無料</p>
        <h2>FX比較で迷う人向け</h2>
        <span>JFX・FXTFの比較、リスク管理を読む順番で整理します。</span>
        <a href="/line/x-profile-main/">LINEでFX比較軸を受け取る</a>
      </section>
    </aside>
  </div>
</BaseLayout>

<style>
  :global(body) {
    background:
      linear-gradient(180deg, #ffffff 0, #ffffff 280px, #ffffff 100%);
    color: #1a1a1a;
  }
  .site-hero {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 430px;
    gap: 28px;
    align-items: stretch;
    margin: 10px 0 22px;
  }
  .hero-copy,
  .hero-feature,
  .section-block,
  .side-card,
  .category-strip,
  .line-band {
    border: 1px solid #e5e7eb;
    background: #ffffff;
    box-shadow: 0 14px 34px rgba(0,0,0,.06);
  }
  .hero-copy {
    padding: clamp(26px, 4vw, 46px);
    border-radius: 6px;
    background:
      linear-gradient(135deg, rgba(255,255,255,.94), rgba(255,250,239,.92)),
      radial-gradient(circle at top right, rgba(37,99,235,.12), transparent 42%);
  }
  .eyebrow,
  .section-title p,
  .line-band p {
    margin: 0 0 10px;
    color: #2563eb;
    font-size: .76rem;
    font-weight: 900;
    letter-spacing: .08em;
  }
  .hero-copy h1 {
    margin: 0;
    color: #1a1a1a;
    font-size: clamp(2.25rem, 4.8vw, 4rem);
    line-height: 1.18;
    letter-spacing: 0;
  }
  .hero-lead {
    max-width: 710px;
    margin: 20px 0 0;
    color: #4b5563;
    font-size: 1rem;
    line-height: 2;
  }
  .hero-buttons {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 26px;
  }
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    padding: 0 22px;
    border-radius: 4px;
    font-weight: 900;
    text-decoration: none;
  }
  .btn:hover { text-decoration: none; }
  .btn-main {
    background: #2563eb;
    color: #fff;
    box-shadow: 0 10px 20px rgba(37,99,235,.24);
  }
  .btn-sub {
    background: #1a1a1a;
    color: #fff;
  }
  .trust-row {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin: 22px 0 0;
    padding: 0;
    list-style: none;
  }
  .trust-row li {
    border: 1px solid #e5e7eb;
    background: #eff6ff;
    color: #4b5563;
    border-radius: 999px;
    padding: 4px 10px;
    font-size: .78rem;
    font-weight: 800;
  }
  .hero-feature {
    display: flex;
    flex-direction: column;
    overflow: hidden;
    border-radius: 6px;
    color: inherit;
    text-decoration: none;
  }
  .hero-feature:hover,
  .lead-card a:hover,
  .ranking-item a:hover,
  .new-row a:hover,
  .route-card:hover {
    text-decoration: none;
    transform: translateY(-2px);
  }
  .feature-label {
    display: block;
    padding: 12px 16px;
    background: #1a1a1a;
    color: #fff;
    font-size: .82rem;
    font-weight: 900;
  }
  .hero-feature img,
  .lead-card img,
  .ranking-item img,
  .new-row img {
    width: 100%;
    object-fit: cover;
    background: #f3f4f6;
  }
  .hero-feature img {
    aspect-ratio: 16/9;
  }
  .feature-body {
    padding: 18px;
  }
  .feature-body h2,
  .lead-card h3,
  .ranking-item h3,
  .new-row h3,
  .section-title h2,
  .line-band h2,
  .side-card h2 {
    margin: 0;
    color: #1a1a1a;
    letter-spacing: 0;
  }
  .feature-body h2 {
    margin-top: 10px;
    font-size: 1.12rem;
    line-height: 1.55;
  }
  .feature-body p,
  .lead-card p,
  .ranking-item p,
  .new-row p,
  .route-card p,
  .line-band span,
  .profile-text,
  .side-line span {
    color: #6b7280;
    line-height: 1.75;
  }
  .feature-body p {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin: 8px 0 0;
    font-size: .9rem;
  }
  .pick-band {
    margin: 0 0 26px;
    padding: 24px;
    border: 1px solid #e5e7eb;
    border-radius: 6px;
    background: #ffffff;
    box-shadow: 0 14px 34px rgba(0,0,0,.06);
  }
  .pick-head p {
    display: flex;
    align-items: center;
    gap: 8px;
    margin: 0 0 6px;
    color: #2563eb;
    font-size: .76rem;
    font-weight: 900;
    letter-spacing: .08em;
  }
  .pr-badge {
    display: inline-flex;
    align-items: center;
    padding: 1px 7px;
    border-radius: 999px;
    background: #eff6ff;
    color: #1d4ed8;
    font-size: .66rem;
    letter-spacing: .04em;
  }
  .pick-head h2 {
    margin: 0;
    color: #1a1a1a;
    font-size: 1.45rem;
    line-height: 1.45;
  }
  .pick-note {
    display: block;
    margin-top: 8px;
    color: #6b7280;
    font-size: .9rem;
    line-height: 1.7;
  }
  .pick-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 16px;
    margin-top: 18px;
  }
  .pick-card {
    display: flex;
    flex-direction: column;
    padding: 20px;
    border: 1px solid #e5e7eb;
    border-left: 4px solid #2563eb;
    border-radius: 6px;
    background: #fff;
  }
  .pick-tag {
    align-self: flex-start;
    margin-bottom: 10px;
    padding: 3px 11px;
    border-radius: 999px;
    background: #eff6ff;
    color: #1d4ed8;
    font-size: .74rem;
    font-weight: 900;
  }
  .pick-card h3 {
    margin: 0;
    color: #1a1a1a;
    font-size: 1.2rem;
    line-height: 1.4;
  }
  .pick-point {
    margin: 10px 0 0;
    color: #4b5563;
    font-size: .9rem;
    line-height: 1.8;
  }
  .pick-specs {
    margin: 14px 0 0;
    padding: 0;
    list-style: none;
    display: grid;
    gap: 6px;
  }
  .pick-specs li {
    position: relative;
    padding-left: 20px;
    color: #374151;
    font-size: .86rem;
    font-weight: 700;
  }
  .pick-specs li::before {
    content: '✓';
    position: absolute;
    left: 0;
    color: #2563eb;
    font-weight: 900;
  }
  .pick-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 18px;
  }
  .pick-cta {
    flex: 1 1 auto;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    padding: 0 18px;
    border-radius: 4px;
    background: #2563eb;
    color: #fff;
    font-weight: 900;
    text-decoration: none;
    box-shadow: 0 10px 20px rgba(37,99,235,.24);
  }
  .pick-cta:hover { text-decoration: none; transform: translateY(-2px); }
  .pick-review {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    padding: 0 16px;
    border-radius: 4px;
    border: 1px solid #d1d5db;
    color: #1a1a1a;
    font-weight: 900;
    text-decoration: none;
  }
  .pick-risk {
    margin: 16px 0 0;
    color: #9ca3af;
    font-size: .76rem;
    line-height: 1.7;
  }
  .category-strip {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1px;
    margin-bottom: 26px;
    overflow: hidden;
    border-radius: 6px;
    background: #e5e7eb;
  }
  .category-strip a {
    display: grid;
