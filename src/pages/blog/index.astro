---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const posts = allPosts.filter((post) => post.data.category === 'FX・外貨' || post.id.includes('fx') || ['dmm-fx-review', 'jfx-review', 'fxtf-review', 'matsui-fx-review'].includes(post.id));

const catColors: Record<string, { bg: string; text: string }> = {
  'FX・外貨':   { bg: '#FEE2E2', text: '#991B1B' },
};
---

<BaseLayout
  title="FX記事一覧"
  description="DMM FX・JFX・FXTF・松井証券FXなど、FX口座比較と初心者向けリスク管理の記事を読めます。"
>
  <div style="margin-bottom:1.5rem;display:flex;align-items:baseline;justify-content:space-between;gap:1rem;">
    <h1 style="font-size:1.8rem;font-weight:900;margin:0;color:#17352a;">FX記事一覧</h1>
    <p style="font-size:0.875rem;color:var(--color-text-muted);margin:0;">{posts.length}件</p>
  </div>

  <div style="display:flex;flex-direction:column;gap:0.875rem;">
    {posts.map(post => {
      const cat = catColors[post.data.category] ?? { bg: '#E5E7EB', text: '#374151' };
      const dateStr = post.data.pubDate.toLocaleDateString('ja-JP', { year: 'numeric', month: 'long', day: 'numeric' });
      const ogSrc = `/thumbnails/${post.id}.svg`;
      return (
        <a
          href={`/blog/${post.id}/`}
          style="display:flex;gap:1rem;align-items:flex-start;padding:1rem 1.25rem;border:1px solid var(--color-border);border-radius:12px;text-decoration:none;color:inherit;background:#fff;transition:box-shadow .15s,transform .15s;"
          onmouseover="this.style.boxShadow='0 4px 16px rgba(0,0,0,.08)';this.style.transform='translateY(-2px)'"
          onmouseout="this.style.boxShadow='none';this.style.transform='translateY(0)'"
        >
          <img
            src={post.data.heroImage ?? ogSrc}
            alt=""
            aria-hidden="true"
            width="96"
            height="64"
            loading="lazy"
            style="width:112px;height:72px;object-fit:cover;border-radius:8px;flex-shrink:0;background:#f2fbf5;"
          />
          <div style="min-width:0;flex:1;">
            <div style="margin-bottom:0.3rem;">
              <span style={`background:${cat.bg};color:${cat.text};font-size:0.72rem;font-weight:700;padding:0.15rem 0.55rem;border-radius:4px;`}>
                {post.data.category}
              </span>
            </div>
            <h2 style="font-size:1rem;font-weight:800;margin:0 0 0.3rem;line-height:1.5;color:#17352a;">{post.data.title}</h2>
            <p style="font-size:0.8rem;color:#6B7280;margin:0 0 0.4rem;line-height:1.55;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;">{post.data.description}</p>
            <span style="font-size:0.72rem;color:#9CA3AF;">{dateStr}</span>
          </div>
        </a>
      );
    })}
  </div>
</BaseLayout>
