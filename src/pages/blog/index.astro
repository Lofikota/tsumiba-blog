---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { getLineAddUrl } from '../../data/lineLinks';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const lineAddUrl = getLineAddUrl('blog-main');

const catColors: Record<string, { bg: string; text: string }> = {
  'NISA・投資': { bg: '#DBEAFE', text: '#1E40AF' },
  '副業・節税': { bg: '#D1FAE5', text: '#065F46' },
  'お得情報':   { bg: '#FEF3C7', text: '#92400E' },
  'FX・外貨':   { bg: '#FEE2E2', text: '#991B1B' },
};
---

<BaseLayout
  title="記事一覧"
  description="副業・NISA・節税・FX・クレカなど、お金に関する実体験ベースの記事を読めます。"
>
  <section style="margin-bottom:1.5rem;padding:1.25rem 1.25rem 1.15rem;border-radius:16px;background:linear-gradient(135deg,#0f172a 0%,#1e293b 55%,#0f172a 100%);color:#fff;border:1px solid rgba(148,163,184,.25);box-shadow:0 16px 40px rgba(15,23,42,.18);">
    <div style="font-size:0.75rem;font-weight:700;color:#67e8f9;letter-spacing:0.08em;text-transform:uppercase;margin-bottom:0.45rem;">Official LINE</div>
    <h1 style="font-size:1.5rem;font-weight:800;line-height:1.35;margin:0 0 0.55rem;">記事を読んだあと、1分で次の順番が決まるLINE</h1>
    <p style="font-size:0.95rem;line-height:1.8;color:#cbd5e1;margin:0 0 1rem;max-width:760px;">記事だけで終わらせず、悩み別に整理した続きだけを受け取れます。ブログ流入は <code>ref=blog-main</code> で計測します。</p>
    <div style="display:flex;flex-wrap:wrap;gap:0.7rem;align-items:center;">
      <a href={lineAddUrl} style="display:inline-flex;align-items:center;justify-content:center;padding:0.9rem 1.25rem;border-radius:999px;background:#06c755;color:#fff;font-weight:800;text-decoration:none;">1分で診断を始める</a>
      <span style="font-size:0.86rem;color:#cbd5e1;">登録直後に、今いちばん近い悩みを1つだけ選べます。</span>
    </div>
  </section>

  <div style="margin-bottom:1rem;display:flex;align-items:baseline;justify-content:space-between;gap:1rem;">
    <h2 style="font-size:1.5rem;font-weight:700;margin:0;">記事一覧</h2>
    <p style="font-size:0.875rem;color:var(--color-text-muted);margin:0;">{posts.length}件の記事</p>
  </div>

  <div style="display:flex;flex-direction:column;gap:1rem;">
    {posts.map(post => {
      const cat = catColors[post.data.category] ?? { bg: '#E5E7EB', text: '#374151' };
      const dateStr = post.data.pubDate.toLocaleDateString('ja-JP', { year: 'numeric', month: 'long', day: 'numeric' });
      return (
      <a
          href={`/blog/${post.id}/`}
          style="display:block;padding:1.25rem 1.5rem;border:1px solid var(--color-border);border-radius:12px;text-decoration:none;color:inherit;transition:transform .15s, box-shadow .15s;background:#fff;"
          onfocus="this.style.boxShadow='0 2px 12px rgba(0,0,0,.08)';this.style.transform='translateY(-1px)'"
          onmouseover="this.style.boxShadow='0 2px 12px rgba(0,0,0,.08)'"
          onmouseout="this.style.boxShadow='none';this.style.transform='translateY(0)'"
        >
          <div style="margin-bottom:0.4rem;">
            <span style={`background:${cat.bg};color:${cat.text};font-size:0.75rem;font-weight:700;padding:0.2rem 0.6rem;border-radius:4px;`}>
              {post.data.category}
            </span>
          </div>
          <h2 style="font-size:1rem;font-weight:700;margin:0 0 0.4rem;line-height:1.5;color:#1F2937;">{post.data.title}</h2>
          <p style="font-size:0.8rem;color:#6B7280;margin:0 0 0.5rem;line-height:1.6;">{post.data.description}</p>
          <span style="font-size:0.75rem;color:#9CA3AF;">{dateStr}</span>
        </a>
      );
    })}
  </div>
</BaseLayout>
