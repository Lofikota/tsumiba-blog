---
import BaseLayout from '../layouts/BaseLayout.astro';

const personJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "田中蓮",
  "url": "https://ren-money.com/about/",
  "description": "30代IT会社員。FX口座の条件、ツール、スプレッド、リスクを会社員目線で比較しています。",
  "knowsAbout": ["FX", "FX口座比較", "DMM FX", "JFX", "FXTF", "FXリスク管理"],
  "hasCredential": [
    { "@type": "EducationalOccupationalCredential", "credentialCategory": "FX口座比較メディア運営" },
    { "@type": "EducationalOccupationalCredential", "credentialCategory": "金融広告のPR表記・リスク表記確認" }
  ],
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": "https://ren-money.com/about/"
  }
});
---

<BaseLayout title="田中蓮のプロフィール｜会社員向けFX口座比較ブログ" description="田中蓮のプロフィール。30代IT会社員。FX口座の条件・ツール・スプレッド・リスクを会社員目線で比較しています。">
  <script is:inline type="application/ld+json" set:html={personJsonLd}></script>
  <h1 style="font-size:1.5rem;font-weight:700;margin-bottom:1.5rem;">このブログについて</h1>

  <div class="prose">
    <div class="box-blue">
      <strong>田中蓮（30代・IT会社員）</strong><br />
      FX口座の条件・ツール・スプレッド・リスクを、会社員目線で比較しています。
    </div>

    <h2>このブログを始めたきっかけ</h2>
    <p>FX口座は、公式サイトだけを見るとキャンペーンや機能の違いが分かりにくく、初心者ほど「どこを比較すればいいのか」で迷いやすいと感じています。</p>

    <p>このブログでは、DMM FX・JFX・FXTF・松井証券FXなどを申し込む前に、条件、ツール、スプレッド、取引単位、リスクを落ち着いて確認できるよう整理します。</p>

    <h2>発信している内容</h2>
    <ul>
      <li><strong>FX口座比較</strong>：DMM FX・JFX・FXTF・松井証券FXの条件整理</li>
      <li><strong>FX初心者ガイド</strong>：少額スタート、取引単位、レバレッジの基本</li>
      <li><strong>会社員のFXリスク管理</strong>：損失リスク、税金、勤務先への注意点</li>
    </ul>

    <div class="box-yellow">
      <strong>【免責事項】</strong>
      当ブログの情報は個人の体験・調査に基づくものです。投資判断は必ずご自身でご確認ください。
    </div>

    <h2>運営者情報</h2>
    <table>
      <tbody>
        <tr><th>サイト名</th><td>田中蓮のマネーブログ</td></tr>
        <tr><th>運営者</th><td>工藤光汰</td></tr>
        <tr><th>住所</th><td>〒983-0005 宮城県仙台市宮城野区福室2-5-3-403</td></tr>
        <tr><th>お問い合わせ</th><td>yoshikou888@gmail.com</td></tr>
      </tbody>
    </table>
    <p style="font-size:0.85rem;color:#666;">※「田中蓮」はコンテンツ上のペルソナです。本サイトの運営・広告収益・法的責任はすべて上記運営者に帰属します。</p>
  </div>
</BaseLayout>
