---
import BaseLayout from '../layouts/BaseLayout.astro';

const personJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "田中蓮",
  "url": "https://ren-money.com/about/",
  "description": "32歳IT会社員。宮城県出身・東京在住。借金200万円から副業・投資で資産500万円を達成。35歳FIREを目指して発信中。",
  "knowsAbout": ["FX", "NISA", "副業", "節税", "保険", "確定申告", "iDeCo", "投資"],
  "hasCredential": [
    { "@type": "EducationalOccupationalCredential", "credentialCategory": "副業収入月20万円達成" },
    { "@type": "EducationalOccupationalCredential", "credentialCategory": "資産500万円形成" }
  ],
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": "https://ren-money.com/about/"
  }
});
---

<BaseLayout title="田中蓮のプロフィール｜借金200万から資産500万を達成した32歳のリアルな軌跡" description="田中蓮のプロフィール。32歳IT会社員、借金200万円→副業月20万→資産500万円達成。FX・NISA・副業・節税を実体験ベースで発信しています。">
  <script is:inline type="application/ld+json" set:html={personJsonLd}></script>
  <h1 style="font-size:1.5rem;font-weight:700;margin-bottom:1.5rem;">このブログについて</h1>

  <div class="prose">
    <div class="box-blue">
      <strong>田中蓮（32歳・IT会社員）</strong><br />
      宮城県出身。東京在住。副業と投資で35歳FIREを目指しています。
    </div>

    <h2>このブログを始めたきっかけ</h2>
    <p>20代後半、気づいたら借金が200万円を超えていました。奨学金・カードローン・分割払い。
    「このまま働き続けるだけの人生でいいのか」と思い、副業と投資の勉強を始めました。</p>

    <p>3年かけて副業で月20万円、資産500万円を達成。完璧ではないけど、少しずつ前進できています。</p>

    <h2>発信している内容</h2>
    <ul>
      <li><strong>NISA・投資</strong>：口座の選び方・積立設定・実際の運用状況</li>
      <li><strong>副業・節税</strong>：実際にやってみた副業・確定申告・節税の方法</li>
      <li><strong>お得情報</strong>：クレカ・ポイ活・キャンペーンの活用術</li>
    </ul>

    <div class="box-yellow">
      <strong>【免責事項】</strong>
      当ブログの情報は個人の体験・調査に基づくものです。投資判断は必ずご自身でご確認ください。
    </div>

    <h2>運営者情報</h2>
    <table>
      <tbody>
        <tr><th>サイト名</th><td>田中蓮のマネーブログ</td></tr>
        <tr><th>運営者</th><td>工藤光汰</td></tr>
        <tr><th>住所</th><td>〒983-0005 宮城県仙台市宮城野区福室2-5-3-403</td></tr>
        <tr><th>お問い合わせ</th><td>yoshikou888@gmail.com</td></tr>
      </tbody>
    </table>
    <p style="font-size:0.85rem;color:#666;">※「田中蓮」はコンテンツ上のペルソナです。本サイトの運営・広告収益・法的責任はすべて上記運営者に帰属します。</p>
  </div>
</BaseLayout>
