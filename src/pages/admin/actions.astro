---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="ブログ管理アクション"
  description="下書き生成と下書き公開を管理画面から実行します。"
  robots="noindex,nofollow"
  wide
>
  <section class="action-hero">
    <div>
      <p>NO TERMINAL OPERATIONS</p>
      <h1>管理アクション</h1>
      <span>ターミナルを使わず、GitHub Actionsを起動します。</span>
    </div>
  </section>

  <section class="action-panel">
    <label for="admin-token">管理トークン</label>
    <input id="admin-token" type="password" placeholder="CloudflareのADMIN_ACTION_TOKEN" autocomplete="off" />
    <button id="save-admin-token" type="button">保存</button>
    <p id="admin-action-status" role="status">初回だけ管理トークンを入力してください。保存先はこのブラウザのsessionStorageだけです。</p>
  </section>

  <section class="action-grid">
    <article>
      <h2>下書きを今すぐ生成</h2>
      <p>毎朝10:00の自動生成を待たずに、pendingキューから1本だけ下書きを作ります。</p>
      <button class="admin-action-button" data-admin-action="generate-draft" type="button">下書き生成を開始</button>
    </article>

    <article>
      <h2>下書きを公開</h2>
      <p>管理画面に表示されたslugを入れて、下書きを公開記事へ昇格します。</p>
      <input id="publish-slug" type="text" placeholder="例: nisa-ideco-docchi" />
      <button class="admin-action-button publish" data-admin-action="publish-draft" type="button">このslugを公開</button>
    </article>
  </section>

  <p class="back-link"><a href="/admin/">ブログ管理へ戻る</a></p>

  <style>
    .action-hero{background:#111827;color:#f8fafc;border-radius:8px;padding:1.5rem;margin-bottom:1rem}.action-hero p{margin:0 0 .35rem;color:#f59e0b;font-size:.72rem;font-weight:800;letter-spacing:.12em}.action-hero h1{margin:0 0 .45rem;font-size:2rem;letter-spacing:0}.action-hero span{color:#cbd5e1}.action-panel,.action-grid article{background:#fff;border:1px solid #d8dee9;border-radius:8px;box-shadow:0 1px 2px rgba(15,23,42,.05)}.action-panel{display:grid;grid-template-columns:auto minmax(180px,1fr)auto;gap:.6rem;align-items:center;padding:.9rem;margin-bottom:1rem}.action-panel label{font-size:.82rem;font-weight:800;color:#334155}.action-panel input,.action-grid input{border:1px solid #cbd5e1;border-radius:6px;padding:.6rem .7rem;font:inherit}.action-panel button,.admin-action-button{border:0;border-radius:6px;background:#0f172a;color:#fff;padding:.62rem .9rem;font:inherit;font-size:.84rem;font-weight:800;cursor:pointer}.action-panel p{grid-column:1/-1;margin:0;color:#64748b;font-size:.8rem}.action-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:1rem}.action-grid article{display:grid;gap:.65rem;padding:1rem;align-content:start}.action-grid h2{margin:0;color:#0f172a;font-size:1.05rem}.action-grid p{margin:0;color:#475569;font-size:.88rem;line-height:1.7}.admin-action-button{background:#2563eb;width:fit-content}.admin-action-button.publish{background:#16a34a}.admin-action-button:disabled{opacity:.55;cursor:wait}.back-link{margin-top:1rem;font-size:.86rem}@media(max-width:760px){.action-grid,.action-panel{grid-template-columns:1fr}.action-hero h1{font-size:1.55rem}}
  </style>

  <script>
    const tokenInput = document.querySelector('#admin-token');
    const slugInput = document.querySelector('#publish-slug');
    const saveButton = document.querySelector('#save-admin-token');
    const statusEl = document.querySelector('#admin-action-status');
    const savedToken = window.sessionStorage.getItem('ren_blog_admin_token') || '';
    if (tokenInput instanceof HTMLInputElement) tokenInput.value = savedToken;

    function setStatus(message, isError = false) {
      if (!(statusEl instanceof HTMLElement)) return;
      statusEl.textContent = message;
      statusEl.style.color = isError ? '#991b1b' : '#64748b';
    }

    saveButton?.addEventListener('click', () => {
      if (!(tokenInput instanceof HTMLInputElement)) return;
      window.sessionStorage.setItem('ren_blog_admin_token', tokenInput.value.trim());
      setStatus('管理トークンを保存しました。');
    });

    async function runAdminAction(button) {
      if (!(button instanceof HTMLButtonElement)) return;
      const token = tokenInput instanceof HTMLInputElement ? tokenInput.value.trim() : '';
      if (!token) {
        setStatus('管理トークンを入力してください。', true);
        return;
      }
      window.sessionStorage.setItem('ren_blog_admin_token', token);
      const action = button.dataset.adminAction;
      const slug = action === 'publish-draft' && slugInput instanceof HTMLInputElement ? slugInput.value.trim() : undefined;
      if (action === 'publish-draft' && !slug) {
        setStatus('公開するslugを入力してください。', true);
        return;
      }
      button.disabled = true;
      setStatus(action === 'publish-draft' ? `${slug} の公開処理を開始しています...` : '下書き生成を開始しています...');
      try {
        const res = await fetch('/api/admin-action', {
          method: 'POST',
          headers: { 'content-type': 'application/json', 'x-admin-token': token },
          body: JSON.stringify({ action, slug }),
        });
        const data = await res.json();
        if (!res.ok || !data.ok) throw new Error(data.message || '実行に失敗しました');
        setStatus('GitHub Actionsを起動しました。数分後に /admin/ を更新してください。');
      } catch (error) {
        setStatus(error instanceof Error ? error.message : '実行に失敗しました', true);
      } finally {
        button.disabled = false;
      }
    }

    document.querySelectorAll('[data-admin-action]').forEach((button) => {
      button.addEventListener('click', () => runAdminAction(button));
    });
  </script>
</BaseLayout>
