---
import { readFile } from 'node:fs/promises';
import { existsSync } from 'node:fs';
import { dirname, join, resolve } from 'node:path';
import { fileURLToPath } from 'node:url';
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { affiliateLinks } from '../../data/affiliateLinks';
import keywordQueue from '../../../data/keyword-queue.json';
import draftIndex from '../../../data/article-drafts/index.json';

type DraftEntry = {
  slug: string;
  keyword: string;
  type: string;
  category: string;
  channel: string;
  priority: number | null;
  charCount: number;
  status: 'draft' | 'published';
  draftedAt: string;
  draftPath: string;
  reportPath: string;
  warnings?: string[];
};

type QueueItem = {
  slug: string;
  keyword: string;
  type: string;
  category: string;
  status: string;
  priority?: number;
  channel?: string;
};

const pageDir = dirname(fileURLToPath(import.meta.url));
const root = resolve(pageDir, '../../..');
const drafts = draftIndex as DraftEntry[];
const activeDrafts = drafts.filter((draft) => draft.status === 'draft');
const queueItems = keywordQueue as QueueItem[];
const pendingQueue = queueItems.filter((item) => item.status === 'pending');
const draftQueue = queueItems.filter((item) => item.status === 'draft');
const posts = await getCollection('blog');
const affiliateReady = affiliateLinks.filter((link) => link.status === 'affiliate').length;
const affiliatePending = affiliateLinks.filter((link) => link.status === 'pending').length;
const affiliateByCategory = affiliateLinks.reduce<Record<string, typeof affiliateLinks>>((acc, link) => {
  acc[link.category] = acc[link.category] ?? [];
  acc[link.category].push(link);
  return acc;
}, {});

async function readExcerpt(draft: DraftEntry): Promise<string> {
  const filePath = join(root, draft.draftPath);
  if (!existsSync(filePath)) return '下書きファイルが見つかりません。';
  const raw = await readFile(filePath, 'utf-8');
  return raw
    .replace(/^---[\s\S]*?---\n/, '')
    .replace(/^import .+$/gm, '')
    .replace(/[#*>`]/g, '')
    .trim()
    .slice(0, 260);
}

const draftRows = await Promise.all(activeDrafts.map(async (draft) => ({
  ...draft,
  excerpt: await readExcerpt(draft),
})));

function dateLabel(value: string | undefined): string {
  if (!value) return '-';
  const date = new Date(value);
  if (Number.isNaN(date.valueOf())) return '-';
  return date.toLocaleString('ja-JP', {
    timeZone: 'Asia/Tokyo',
    month: '2-digit',
    day: '2-digit',
    hour: '2-digit',
    minute: '2-digit',
  });
}
---

<BaseLayout
  title="ブログ管理"
  description="収益化記事の下書き、公開待ち、ASPリンク、次の制作キューを確認する管理画面です。"
  robots="noindex,nofollow"
  wide
>
  <section class="admin-hero">
    <div>
      <p class="admin-kicker">MANUAL PUBLISH CONTROL</p>
      <h1>ブログ管理</h1>
      <p>毎日生成された記事をここで確認し、稼げる導線だけを手動で公開します。</p>
    </div>
    <div class="admin-command">
      <span>管理アクション</span>
      <button class="admin-action-button" data-admin-action="generate-draft" type="button">下書きを今すぐ生成</button>
      <small>初回だけ下の管理トークンを入力</small>
    </div>
  </section>

  <section class="admin-auth">
    <label for="admin-token">管理トークン</label>
    <input id="admin-token" type="password" placeholder="CloudflareのADMIN_ACTION_TOKEN" autocomplete="off" />
    <button id="save-admin-token" type="button">保存</button>
    <p id="admin-action-status" role="status">ボタン操作はGitHub Actionsを起動します。秘密情報はこのブラウザ内だけに保存します。</p>
  </section>

  <section class="admin-stats" aria-label="運営状況">
    <article>
      <span>下書き</span>
      <strong>{activeDrafts.length}</strong>
      <small>手動公開待ち</small>
    </article>
    <article>
      <span>公開記事</span>
      <strong>{posts.length}</strong>
      <small>ブログ掲載中</small>
    </article>
    <article>
      <span>ASP承認済み</span>
      <strong>{affiliateReady}</strong>
      <small>送客可能</small>
    </article>
    <article>
      <span>ASP承認待ち</span>
      <strong>{affiliatePending}</strong>
      <small>差替待ち</small>
    </article>
  </section>

  <section class="admin-section">
    <div class="section-head">
      <div>
        <p>DRAFT INBOX</p>
        <h2>公開待ち下書き</h2>
      </div>
      <span>{activeDrafts.length}件</span>
    </div>

    {draftRows.length > 0 ? (
      <div class="draft-list">
        {draftRows.map((draft) => (
          <article class="draft-card">
            <div class="draft-main">
              <div class="draft-topline">
                <span>{draft.category}</span>
                <span>{draft.channel}</span>
                <span>{dateLabel(draft.draftedAt)}</span>
              </div>
              <h3>{draft.keyword}</h3>
              <p>{draft.excerpt}</p>
              {draft.warnings && draft.warnings.length > 0 && (
                <div class="draft-warning">
                  {draft.warnings.map((warning) => <span>{warning}</span>)}
                </div>
              )}
            </div>
            <div class="draft-side">
              <strong>{draft.charCount.toLocaleString()}字</strong>
              <a href={`/admin/drafts/${draft.slug}/`}>下書きを読む</a>
              <button class="admin-action-button publish" data-admin-action="publish-draft" data-slug={draft.slug} type="button">この下書きを公開</button>
              <code>npm run draft:publish -- {draft.slug}</code>
            </div>
          </article>
        ))}
      </div>
    ) : (
      <div class="empty-state">
        <h3>まだ下書きはありません</h3>
        <p>次の pending キューから下書きを作るには、ローカルまたはGitHub Actionsで下書き生成を実行します。</p>
        <code>cd /Users/kudokota/Affiliate/ren-blog- && npm run draft:generate</code>
      </div>
    )}
  </section>

  <section class="admin-grid">
    <div class="admin-panel">
      <div class="section-head compact">
        <div>
          <p>NEXT QUEUE</p>
          <h2>次に作る記事</h2>
        </div>
        <span>{pendingQueue.length}件</span>
      </div>
      <div class="queue-list">
        {pendingQueue.map((item) => (
          <article>
            <strong>{item.keyword}</strong>
            <span>{item.slug}</span>
            <small>{item.category} / {item.channel ?? 'manual'} / priority {item.priority ?? '-'}</small>
          </article>
        ))}
      </div>
    </div>

    <div class="admin-panel">
      <div class="section-head compact">
        <div>
          <p>WHY THIS EXISTS</p>
          <h2>この画面の目的</h2>
        </div>
      </div>
      <ul class="purpose-list">
        <li>自動生成は公開ではなく、下書き保存で止める。</li>
        <li>人間がASP導線、リスク表記、読者の悩みを確認してから公開する。</li>
        <li>公開判断はPVではなく、LINE登録とASPクリックに近い記事を優先する。</li>
        <li>承認済み案件へ送れる記事を先に公開し、pending案件は差替待ちにする。</li>
      </ul>
    </div>
  </section>

  {draftQueue.length > 0 && (
    <section class="admin-section">
      <div class="section-head">
        <div>
          <p>QUEUE STATUS</p>
          <h2>キュー上の下書き</h2>
        </div>
      </div>
      <div class="queue-list wide">
        {draftQueue.map((item) => (
          <article>
            <strong>{item.keyword}</strong>
            <span>{item.slug}</span>
            <small>{item.category} / draft</small>
          </article>
        ))}
      </div>
    </section>
  )}

  <section class="admin-section">
    <div class="section-head">
      <div>
        <p>AFFILIATE LINKS</p>
        <h2>ASPリンク台帳</h2>
      </div>
      <span>{affiliateLinks.length}件</span>
    </div>

    <div class="affiliate-groups">
      {Object.entries(affiliateByCategory).map(([category, links]) => (
        <div class="affiliate-group">
          <h3>{category}</h3>
          <div class="affiliate-list">
            {links.map((link) => (
              <a href={`/go/${link.slug}/`} class={`affiliate-item ${link.status}`}>
                <div>
                  <strong>{link.name}</strong>
                  <span>{link.provider}</span>
                </div>
                <em>{link.status}</em>
              </a>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

  <p class="admin-footnote">
    旧一覧画面: <a href="/admin/blog/">記事・ASPリンク一覧</a>
  </p>

  <style>
    .admin-hero {
      display: grid;
      grid-template-columns: minmax(0, 1fr) 320px;
      gap: 1rem;
      align-items: stretch;
      background: #111827;
      color: #f9fafb;
      border-radius: 8px;
      padding: 1.5rem;
