      font-size: 0.78rem;
      line-height: 1.55;
    }
    .admin-stats {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 0.75rem;
      margin-bottom: 1rem;
    }
    .admin-stats article,
    .admin-section,
    .admin-panel {
      background: #fff;
      border: 1px solid #d8dee9;
      border-radius: 8px;
      box-shadow: 0 1px 2px rgba(15,23,42,.05);
    }
    .admin-stats article {
      padding: 1rem;
    }
    .admin-stats span,
    .admin-stats small {
      display: block;
      color: #64748b;
      font-size: 0.78rem;
    }
    .admin-stats strong {
      display: block;
      color: #0f172a;
      font-size: 1.8rem;
      line-height: 1.2;
      margin: 0.1rem 0;
    }
    .admin-section {
      padding: 1rem;
      margin-bottom: 1rem;
    }
    .section-head {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 1rem;
      margin-bottom: 0.85rem;
    }
    .section-head.compact {
      margin-bottom: 0.7rem;
    }
    .section-head p,
    .section-head span {
      margin: 0;
      color: #64748b;
      font-size: 0.72rem;
      font-weight: 800;
      letter-spacing: .08em;
    }
    .section-head h2 {
      margin: 0;
      color: #0f172a;
      font-size: 1rem;
      line-height: 1.35;
    }
    .draft-list {
      display: grid;
      gap: 0.75rem;
    }
    .draft-card {
      display: grid;
      grid-template-columns: minmax(0, 1fr) 220px;
      gap: 1rem;
      border: 1px solid #e2e8f0;
      border-radius: 8px;
      padding: 1rem;
      background: #f8fafc;
    }
    .draft-topline {
      display: flex;
      flex-wrap: wrap;
      gap: 0.4rem;
      margin-bottom: 0.45rem;
    }
    .draft-topline span {
      border-radius: 999px;
      background: #e0f2fe;
      color: #075985;
      padding: 0.12rem 0.5rem;
      font-size: 0.7rem;
      font-weight: 800;
    }
    .draft-main h3 {
      margin: 0 0 0.4rem;
      color: #0f172a;
      font-size: 1.05rem;
      line-height: 1.5;
    }
    .draft-main p {
      margin: 0;
      color: #475569;
      font-size: 0.88rem;
      line-height: 1.75;
    }
    .draft-side {
      display: grid;
      align-content: start;
      gap: 0.6rem;
    }
    .draft-side strong {
      color: #0f172a;
      font-size: 1.2rem;
    }
    .draft-side a {
      display: inline-flex;
      justify-content: center;
      border-radius: 6px;
      background: #2563eb;
      color: #fff;
      padding: 0.55rem 0.75rem;
      text-decoration: none;
      font-weight: 800;
      font-size: 0.84rem;
    }
    .draft-warning {
      display: grid;
      gap: 0.25rem;
      margin-top: 0.75rem;
    }
    .draft-warning span {
      color: #92400e;
      background: #fef3c7;
      border-radius: 6px;
      padding: 0.35rem 0.45rem;
      font-size: 0.75rem;
      line-height: 1.5;
    }
    .empty-state {
      border: 1px dashed #cbd5e1;
      border-radius: 8px;
      padding: 1rem;
      background: #f8fafc;
    }
    .empty-state h3,
    .empty-state p {
      margin: 0 0 0.6rem;
    }
    .admin-grid {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
      gap: 1rem;
      margin-bottom: 1rem;
    }
    .admin-panel {
      padding: 1rem;
    }
    .queue-list {
      display: grid;
      gap: 0.55rem;
      max-height: 420px;
      overflow: auto;
    }
    .queue-list.wide {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
    .queue-list article {
      display: grid;
      gap: 0.1rem;
      border: 1px solid #e2e8f0;
      border-radius: 8px;
      padding: 0.7rem;
      background: #f8fafc;
    }
    .queue-list strong {
      color: #0f172a;
      font-size: 0.86rem;
      line-height: 1.45;
    }
    .queue-list span,
    .queue-list small {
      color: #64748b;
      font-size: 0.76rem;
    }
    .purpose-list {
      display: grid;
      gap: 0.45rem;
      padding-left: 1.1rem;
      color: #334155;
      font-size: 0.88rem;
      line-height: 1.7;
    }
    .affiliate-groups {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 0.85rem;
    }
    .affiliate-group {
      border: 1px solid #e2e8f0;
      border-radius: 8px;
      background: #f8fafc;
      padding: 0.75rem;
    }
    .affiliate-group h3 {
      margin: 0 0 0.55rem;
      color: #0f172a;
      font-size: 0.92rem;
      line-height: 1.35;
    }
    .affiliate-list {
      display: grid;
      gap: 0.4rem;
    }
    .affiliate-item {
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto;
      gap: 0.75rem;
      align-items: center;
      border: 1px solid #e2e8f0;
      border-left-width: 4px;
      border-radius: 8px;
      background: #fff;
      padding: 0.65rem;
      color: #334155;
      text-decoration: none;
    }
    .affiliate-item.affiliate {
      border-left-color: #16a34a;
    }
    .affiliate-item.pending {
      border-left-color: #d97706;
    }
    .affiliate-item.official {
      border-left-color: #2563eb;
    }
    .affiliate-item:hover {
      border-color: #94a3b8;
      border-left-color: inherit;
      text-decoration: none;
    }
    .affiliate-item strong,
    .affiliate-item span {
      display: block;
    }
    .affiliate-item strong {
      color: #0f172a;
      font-size: 0.85rem;
      line-height: 1.45;
    }
    .affiliate-item span {
      color: #64748b;
      font-size: 0.74rem;
      line-height: 1.5;
    }
    .affiliate-item em {
      border-radius: 999px;
      background: #e2e8f0;
      color: #334155;
      padding: 0.14rem 0.48rem;
      font-style: normal;
      font-size: 0.68rem;
      font-weight: 800;
    }
    .admin-footnote {
      margin: 0;
      color: #64748b;
      font-size: 0.82rem;
    }
    @media (max-width: 860px) {
      .admin-hero,
      .admin-stats,
      .admin-grid,
      .draft-card,
      .queue-list.wide,
      .affiliate-groups,
      .admin-auth {
        grid-template-columns: 1fr;
      }
      .admin-hero h1 {
        font-size: 1.55rem;
      }
    }
  </style>
  <script>
    const tokenInput = document.querySelector('#admin-token');
    const saveButton = document.querySelector('#save-admin-token');
    const statusEl = document.querySelector('#admin-action-status');
    const savedToken = window.sessionStorage.getItem('ren_blog_admin_token') || '';
    if (tokenInput instanceof HTMLInputElement) tokenInput.value = savedToken;

    function setStatus(message, isError = false) {
      if (!(statusEl instanceof HTMLElement)) return;
      statusEl.textContent = message;
      statusEl.style.color = isError ? '#991b1b' : '#64748b';
    }

    saveButton?.addEventListener('click', () => {
      if (!(tokenInput instanceof HTMLInputElement)) return;
      window.sessionStorage.setItem('ren_blog_admin_token', tokenInput.value.trim());
      setStatus('管理トークンをこのブラウザに保存しました。');
    });

    async function runAdminAction(button) {
      if (!(button instanceof HTMLButtonElement)) return;
      const token = tokenInput instanceof HTMLInputElement ? tokenInput.value.trim() : '';
      if (!token) {
        setStatus('管理トークンを入力してください。', true);
        return;
      }
      window.sessionStorage.setItem('ren_blog_admin_token', token);

      const action = button.dataset.adminAction;
      const slug = button.dataset.slug;
      button.disabled = true;
      setStatus(action === 'publish-draft' ? `${slug} の公開処理を開始しています...` : '下書き生成を開始しています...');

      try {
        const res = await fetch('/api/admin-action', {
          method: 'POST',
          headers: {
            'content-type': 'application/json',
            'x-admin-token': token,
          },
          body: JSON.stringify({ action, slug }),
        });
        const data = await res.json();
        if (!res.ok || !data.ok) throw new Error(data.message || '実行に失敗しました');
        setStatus('GitHub Actionsを起動しました。数分後にこのページを更新してください。');
      } catch (error) {
        setStatus(error instanceof Error ? error.message : '実行に失敗しました', true);
      } finally {
        button.disabled = false;
      }
    }

    document.querySelectorAll('[data-admin-action]').forEach((button) => {
      button.addEventListener('click', () => runAdminAction(button));
    });
  </script>
</BaseLayout>
