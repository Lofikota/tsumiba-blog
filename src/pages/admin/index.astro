      margin: 0 0 0.45rem;
      letter-spacing: 0;
    }
    .admin-hero p {
      color: #cbd5e1;
      margin: 0;
    }
    .admin-command {
      display: grid;
      align-content: center;
      gap: 0.5rem;
      border: 1px solid rgba(255,255,255,.18);
      border-radius: 8px;
      padding: 1rem;
      background: rgba(255,255,255,.06);
    }
    .admin-command span {
      color: #cbd5e1;
      font-size: 0.8rem;
    }
    .admin-command small {
      color: #94a3b8;
      font-size: 0.72rem;
    }
    .admin-action-button {
      display: inline-flex;
      justify-content: center;
      align-items: center;
      width: 100%;
      border: 0;
      border-radius: 6px;
      background: #2563eb;
      color: #fff;
      padding: 0.65rem 0.85rem;
      font: inherit;
      font-size: 0.86rem;
      font-weight: 800;
      cursor: pointer;
    }
    .admin-action-button:hover {
      background: #1d4ed8;
    }
    .admin-action-button.publish {
      background: #16a34a;
    }
    .admin-action-button.publish:hover {
      background: #15803d;
    }
    .admin-action-button:disabled {
      opacity: 0.55;
      cursor: wait;
    }
    .admin-auth {
      display: grid;
      grid-template-columns: auto minmax(180px, 1fr) auto;
      gap: 0.6rem;
      align-items: center;
      background: #fff;
      border: 1px solid #d8dee9;
      border-radius: 8px;
      padding: 0.8rem;
      margin-bottom: 1rem;
      box-shadow: 0 1px 2px rgba(15,23,42,.05);
    }
    .admin-auth label {
      color: #334155;
      font-size: 0.8rem;
      font-weight: 800;
    }
    .admin-auth input {
      min-width: 0;
      border: 1px solid #cbd5e1;
      border-radius: 6px;
