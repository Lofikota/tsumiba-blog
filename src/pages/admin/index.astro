---
// 管理画面の入口は「記事一覧」。/admin/ にアクセスしたら記事一覧へ送る。
const target = '/admin/articles/';
---
<!doctype html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta http-equiv="refresh" content={`0; url=${target}`} />
  <meta name="robots" content="noindex,nofollow" />
  <link rel="canonical" href={target} />
  <title>記事一覧へ移動します…</title>
  <script is:inline define:vars={{ target }}>window.location.replace(target);</script>
</head>
<body style="font-family:sans-serif;padding:2rem;color:#1a1a1a;">
  <p><a href={target}>記事一覧へ移動</a></p>
</body>
</html>
