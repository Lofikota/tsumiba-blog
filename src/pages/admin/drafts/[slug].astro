---
import { readFile } from 'node:fs/promises';
import { join, resolve } from 'node:path';
import { dirname } from 'node:path';
import { fileURLToPath } from 'node:url';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import draftIndex from '../../../../data/article-drafts/index.json';

type DraftEntry = {
  slug: string;
  keyword: string;
  status: string;
  draftPath: string;
  charCount: number;
  draftedAt: string;
  warnings?: string[];
};

export async function getStaticPaths() {
  return (draftIndex as DraftEntry[])
    .filter((draft) => draft.status === 'draft')
    .map((draft) => ({ params: { slug: draft.slug }, props: { draft } }));
}

const { draft } = Astro.props as { draft: DraftEntry };
const pageDir = dirname(fileURLToPath(import.meta.url));
const root = resolve(pageDir, '../../../..');
const content = await readFile(join(root, draft.draftPath), 'utf-8');
---

<BaseLayout
  title={`下書き確認: ${draft.slug}`}
  description="記事下書きの全文確認ページです。"
  robots="noindex,nofollow"
  wide
>
  <section class="draft-detail-head">
    <div>
      <a href="/admin/">← 管理画面へ戻る</a>
      <h1>{draft.keyword}</h1>
      <p>{draft.slug} / {draft.charCount.toLocaleString()}字</p>
    </div>
    <code>npm run draft:publish -- {draft.slug}</code>
  </section>

  {draft.warnings && draft.warnings.length > 0 && (
    <section class="draft-warnings">
      {draft.warnings.map((warning) => <p>{warning}</p>)}
    </section>
  )}

  <section class="draft-body">
    <pre>{content}</pre>
  </section>

  <style>
    .draft-detail-head {
      display: grid;
      grid-template-columns: minmax(0, 1fr) 340px;
      gap: 1rem;
      align-items: start;
      background: #111827;
      color: #f8fafc;
      border-radius: 8px;
      padding: 1.25rem;
      margin-bottom: 1rem;
    }
    .draft-detail-head a {
      display: inline-block;
      color: #bfdbfe;
      margin-bottom: 0.6rem;
      font-size: 0.85rem;
    }
    .draft-detail-head h1 {
      margin: 0 0 0.35rem;
      font-size: 1.45rem;
      line-height: 1.45;
      letter-spacing: 0;
    }
    .draft-detail-head p {
      margin: 0;
      color: #cbd5e1;
      font-size: 0.86rem;
    }
    code {
      display: block;
      background: #0f172a;
      color: #f8fafc;
      border-radius: 6px;
      padding: 0.55rem 0.65rem;
      overflow-wrap: anywhere;
      white-space: normal;
      font-size: 0.8rem;
      line-height: 1.6;
    }
    .draft-warnings {
      display: grid;
      gap: 0.45rem;
      background: #fffbeb;
      border: 1px solid #fde68a;
      border-radius: 8px;
      padding: 0.85rem;
      margin-bottom: 1rem;
    }
    .draft-warnings p {
      margin: 0;
      color: #92400e;
      font-size: 0.84rem;
      line-height: 1.7;
    }
    .draft-body {
      background: #fff;
      border: 1px solid #d8dee9;
      border-radius: 8px;
      overflow: auto;
    }
    .draft-body pre {
      margin: 0;
      padding: 1rem;
      white-space: pre-wrap;
      overflow-wrap: anywhere;
      color: #0f172a;
      font-size: 0.86rem;
      line-height: 1.75;
      font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    }
    @media (max-width: 820px) {
      .draft-detail-head {
        grid-template-columns: 1fr;
      }
    }
  </style>
</BaseLayout>
