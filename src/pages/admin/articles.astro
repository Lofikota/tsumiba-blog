---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import AdminNav from '../../components/AdminNav.astro';

const posts = await getCollection('blog');
const sorted = posts.sort((a, b) => {
  const ad = (a.data.updatedDate ?? a.data.pubDate).getTime();
  const bd = (b.data.updatedDate ?? b.data.pubDate).getTime();
  return bd - ad;
});

const publishedCount = sorted.filter(p => !p.data.draft).length;
const draftCount = sorted.filter(p => p.data.draft).length;

function fmt(d: Date | string | undefined) {
  if (!d) return '-';
  return new Date(d).toLocaleDateString('ja-JP', { year: 'numeric', month: '2-digit', day: '2-digit' });
}
const thumb = (post: typeof sorted[number]) => post.data.heroImage ?? `/og/${post.id}.svg`;
---

<BaseLayout
  title="記事 | ren-money.com 管理"
  description="書いた記事の一覧と編集"
  robots="noindex,nofollow"
  wide
>
  <AdminNav active="article-editor" />

  <section class="articles-wrap">
    <div class="articles-header">
      <div>
        <h1>記事</h1>
        <p class="subtitle">書いた記事を選んで、タイトル・本文・画像を編集できます。保存すると自動で公開（デプロイ）されます。</p>
      </div>
    </div>

    <details class="howto">
      <summary>📖 使い方（はじめての方はこちら）</summary>
      <ol class="howto-steps">
        <li><b>記事を選ぶ</b> — 下の一覧から編集したい記事の「編集」を押します。</li>
        <li><b>本文・画像を直す</b> — タイトルや本文をそのまま書き換えられます。トップ画像は左側の枠に画像を<b>ドラッグ&ドロップ</b>するだけで差し替え。本文中の画像はツールバーの🖼️ボタン、または画像を本文へドロップで挿入できます。</li>
        <li><b>保存して公開</b> — 右上の「保存して公開」を押すと自動で公開されます（数分でサイトに反映）。<code>Ctrl</code>(Mac は <code>⌘</code>)+<code>S</code> でも保存できます。</li>
      </ol>
      <p class="howto-note">※ 最初の1回だけ「合言葉（管理トークン）」のログインが必要です。一度入れればこのブラウザが覚えるので、次回からは不要です。</p>
    </details>

    <div class="toolbar">
      <div class="filters" role="tablist">
        <button class="filter active" data-filter="all" type="button">すべて <span class="cnt">{sorted.length}</span></button>
        <button class="filter" data-filter="published" type="button">公開中 <span class="cnt">{publishedCount}</span></button>
        <button class="filter" data-filter="draft" type="button">下書き <span class="cnt">{draftCount}</span></button>
      </div>
      <input id="search" type="search" placeholder="タイトル・スラッグで検索..." autocomplete="off" />
    </div>

    <div id="card-list" class="card-list">
      {sorted.map(post => (
        <article
          class="card"
          data-title={post.data.title.toLowerCase()}
          data-slug={post.id}
          data-status={post.data.draft ? 'draft' : 'published'}
        >
          <a class="card-thumb" href={`/admin/edit/${post.id}/`}>
            <img src={thumb(post)} alt="" loading="lazy" width="160" height="90" />
          </a>
          <div class="card-body">
            <div class="card-meta">
              <span class="category-badge">{post.data.category}</span>
              {post.data.draft
                ? <span class="status draft">下書き</span>
                : <span class="status published">公開中</span>}
            </div>
            <a class="card-title" href={`/admin/edit/${post.id}/`}>{post.data.title}</a>
            <p class="card-slug">{post.id}</p>
          </div>
          <div class="card-side">
            <span class="card-date">更新 {fmt(post.data.updatedDate ?? post.data.pubDate)}</span>
            <div class="card-actions">
              <a href={`/admin/edit/${post.id}/`} class="btn-edit">編集</a>
              <a href={`/blog/${post.id}/`} target="_blank" rel="noopener" class="btn-preview">表示</a>
            </div>
          </div>
        </article>
      ))}
    </div>

    <p id="empty-msg" class="empty-msg" style="display:none">該当する記事がありません。</p>
  </section>

  <script>
    const searchInput = document.getElementById('search') as HTMLInputElement;
    const list = document.getElementById('card-list');
    const emptyMsg = document.getElementById('empty-msg');
    const filters = Array.from(document.querySelectorAll<HTMLButtonElement>('.filter'));
    let activeFilter = 'all';

    function apply() {
      const q = (searchInput?.value || '').toLowerCase();
      let visible = 0;
      list?.querySelectorAll<HTMLElement>('.card').forEach(card => {
        const title = card.dataset.title || '';
        const slug = card.dataset.slug || '';
        const status = card.dataset.status || '';
        const matchText = !q || title.includes(q) || slug.includes(q);
        const matchFilter = activeFilter === 'all' || status === activeFilter;
        const show = matchText && matchFilter;
        card.style.display = show ? '' : 'none';
        if (show) visible++;
      });
      if (emptyMsg) emptyMsg.style.display = visible === 0 ? 'block' : 'none';
    }

    searchInput?.addEventListener('input', apply);
    filters.forEach(btn => btn.addEventListener('click', () => {
      filters.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      activeFilter = btn.dataset.filter || 'all';
      apply();
    }));
  </script>

  <style>
    .articles-wrap { max-width: 920px; margin: 0 auto; }
    .articles-header { margin-bottom: 1.25rem; }
    h1 { margin: 0 0 .3rem; font-size: 1.6rem; color: #0f172a; }
    .subtitle { margin: 0; color: #64748b; font-size: .86rem; max-width: 620px; line-height: 1.6; }

    .howto { background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 10px; padding: .85rem 1.1rem; margin-bottom: 1rem; }
    .howto summary { cursor: pointer; font-size: .88rem; font-weight: 700; color: #0f172a; list-style: none; }
    .howto summary::-webkit-details-marker { display: none; }
    .howto summary::before { content: '▶ '; font-size: .7rem; color: #2563eb; }
    .howto[open] summary::before { content: '▼ '; }
    .howto-steps { margin: .9rem 0 0; padding-left: 1.3rem; display: flex; flex-direction: column; gap: .55rem; }
    .howto-steps li { color: #475569; font-size: .85rem; line-height: 1.7; }
    .howto-steps b { color: #0f172a; }
    .howto-steps code { background: #e2e8f0; color: #334155; padding: .1rem .35rem; border-radius: 4px; font-size: .78rem; }
    .howto-note { margin: .8rem 0 0; padding-top: .7rem; border-top: 1px dashed #e2e8f0; color: #64748b; font-size: .8rem; line-height: 1.6; }

    .toolbar { display: flex; align-items: center; justify-content: space-between; gap: 1rem; margin-bottom: 1rem; flex-wrap: wrap; }
    .filters { display: flex; gap: .35rem; }
    .filter { display: inline-flex; align-items: center; gap: .4rem; background: #f1f5f9; border: 1px solid #e2e8f0; color: #475569; border-radius: 999px; padding: .4rem .9rem; font-size: .82rem; font-weight: 700; cursor: pointer; transition: all .15s; }
    .filter:hover { background: #e2e8f0; }
    .filter.active { background: #0f172a; color: #fff; border-color: #0f172a; }
    .filter .cnt { font-size: .72rem; opacity: .8; }
    #search { flex: 1; min-width: 200px; max-width: 320px; padding: .5rem .85rem; border: 1px solid #cbd5e1; border-radius: 8px; font-size: .88rem; outline: none; }
    #search:focus { border-color: #2563eb; box-shadow: 0 0 0 3px rgba(37,99,235,.1); }

    .card-list { display: flex; flex-direction: column; gap: .65rem; }
    .card { display: grid; grid-template-columns: 160px 1fr auto; gap: 1rem; align-items: center; background: #fff; border: 1px solid #e2e8f0; border-radius: 12px; padding: .75rem; transition: box-shadow .15s, transform .15s; }
    .card:hover { box-shadow: 0 4px 16px rgba(15,23,42,.08); transform: translateY(-1px); }

    .card-thumb { display: block; border-radius: 8px; overflow: hidden; background: #f1f5f9; }
    .card-thumb img { display: block; width: 160px; height: 90px; object-fit: cover; }

    .card-body { min-width: 0; }
    .card-meta { display: flex; gap: .4rem; margin-bottom: .35rem; }
    .category-badge { background: #e0f2fe; color: #0369a1; border-radius: 999px; padding: .18rem .55rem; font-size: .7rem; font-weight: 700; white-space: nowrap; }
    .status { border-radius: 999px; padding: .18rem .55rem; font-size: .7rem; font-weight: 700; }
    .status.published { background: #eff6ff; color: #1d4ed8; }
    .status.draft { background: #fef9c3; color: #92400e; }
    .card-title { display: block; color: #0f172a; font-size: .98rem; font-weight: 700; line-height: 1.45; text-decoration: none; }
    .card-title:hover { color: #2563eb; }
    .card-slug { margin: .2rem 0 0; color: #94a3b8; font-size: .74rem; font-family: monospace; }

    .card-side { display: flex; flex-direction: column; align-items: flex-end; gap: .5rem; white-space: nowrap; }
    .card-date { color: #64748b; font-size: .76rem; }
    .card-actions { display: flex; gap: .35rem; }
    .btn-edit, .btn-preview { display: inline-block; border-radius: 6px; padding: .3rem .8rem; font-size: .78rem; font-weight: 700; text-decoration: none; }
    .btn-edit { background: #2563eb; color: #fff; }
    .btn-edit:hover { background: #1d4ed8; }
    .btn-preview { background: #f1f5f9; color: #475569; border: 1px solid #e2e8f0; }
    .btn-preview:hover { background: #e2e8f0; }

    .empty-msg { text-align: center; color: #94a3b8; padding: 2.5rem; font-size: .9rem; }

    @media (max-width: 640px) {
      .card { grid-template-columns: 96px 1fr; }
      .card-thumb img { width: 96px; height: 60px; }
      .card-side { grid-column: 1 / -1; flex-direction: row; align-items: center; justify-content: space-between; }
    }
  </style>
</BaseLayout>
