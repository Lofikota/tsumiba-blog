---
import { readFile, readdir } from 'node:fs/promises';
import { existsSync } from 'node:fs';
import { dirname, join, resolve } from 'node:path';
import { fileURLToPath } from 'node:url';
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { affiliateLinks } from '../../data/affiliateLinks';
import keywordQueue from '../../../data/keyword-queue.json';

type QueueItem = {
  slug: string;
  keyword: string;
  type: string;
  category: string;
  notes?: string;
  status: string;
  priority?: number;
  channel?: string;
  publishedAt?: string;
};

type WorkflowStatus = {
  label: '公開OK' | '保留' | '未確認';
  tone: 'ok' | 'hold' | 'missing';
  reason: string;
};

const pageDir = dirname(fileURLToPath(import.meta.url));
const affiliateRoot = resolve(pageDir, '../../../..');
const workflowRoot = join(affiliateRoot, '記事制作');

const posts = (await getCollection('blog')).sort(
  (a, b) => (b.data.updatedDate ?? b.data.pubDate).valueOf() - (a.data.updatedDate ?? a.data.pubDate).valueOf()
);

async function loadWorkflowStatus(slug: string): Promise<WorkflowStatus> {
  const reviewPath = join(workflowRoot, slug, '07-human-review.md');
  if (!existsSync(reviewPath)) {
    return { label: '未確認', tone: 'missing', reason: '07-human-review.md なし' };
  }

  const raw = await readFile(reviewPath, 'utf8');
  const match = raw.match(/公開判定:\s*([^\n]+)/);
  const decision = match?.[1]?.trim() ?? '';
  if (decision.includes('公開OK')) {
    return { label: '公開OK', tone: 'ok', reason: '人間監修ログあり' };
  }
  if (decision.includes('保留')) {
    return { label: '保留', tone: 'hold', reason: '公開判定が保留' };
  }
  return { label: '未確認', tone: 'missing', reason: '公開判定が未記入' };
}

async function listWorkflowSlugs(): Promise<string[]> {
  if (!existsSync(workflowRoot)) return [];
  const entries = await readdir(workflowRoot, { withFileTypes: true });
  return entries.filter((entry) => entry.isDirectory() && !entry.name.startsWith('_')).map((entry) => entry.name);
}

function dateLabel(date: Date | string | undefined): string {
  if (!date) return '-';
  const value = typeof date === 'string' ? new Date(date) : date;
  if (Number.isNaN(value.valueOf())) return '-';
  return value.toLocaleDateString('ja-JP', { year: 'numeric', month: '2-digit', day: '2-digit' });
}

function extractGoSlugs(body: string | undefined): string[] {
  if (!body) return [];
  const slugs = new Set<string>();
  for (const match of body.matchAll(/(?:href=["']\/go\/|product=["'])([a-z0-9-]+)/g)) {
    slugs.add(match[1]);
  }
  return [...slugs].sort();
}

const queueItems = keywordQueue as QueueItem[];
const queueBySlug = new Map(queueItems.map((item) => [item.slug, item]));
const affiliateBySlug = new Map(affiliateLinks.map((link) => [link.slug, link]));
const workflowSlugs = await listWorkflowSlugs();
const workflowSlugSet = new Set(workflowSlugs);
const workflowStatuses = new Map(
  await Promise.all(posts.map(async (post) => [post.id, await loadWorkflowStatus(post.id)] as const))
);

const articleRows = posts.map((post) => {
  const goSlugs = extractGoSlugs(post.body);
  const links = goSlugs.map((slug) => affiliateBySlug.get(slug)).filter(Boolean);
  const missingLinks = goSlugs.filter((slug) => !affiliateBySlug.has(slug));
  const queue = queueBySlug.get(post.id);
  const workflow = workflowStatuses.get(post.id) ?? { label: '未確認', tone: 'missing', reason: '未確認' };

  return {
    slug: post.id,
    title: post.data.title,
    category: post.data.category,
    type: post.data.articleType ?? queue?.type ?? '未分類',
    updatedAt: post.data.updatedDate ?? post.data.pubDate,
    queueStatus: queue?.status ?? 'queueなし',
    channel: queue?.channel ?? 'manual',
    workflow,
    links,
    missingLinks,
    needsAction: workflow.tone !== 'ok' || links.some((link) => link?.status === 'pending') || missingLinks.length > 0,
  };
});

const pendingQueue = queueItems.filter((item) => item.status === 'pending');
const publishedQueue = queueItems.filter((item) => item.status === 'published');
const workflowOnly = workflowSlugs.filter((slug) => !posts.some((post) => post.id === slug));
const affiliateStats = {
  affiliate: affiliateLinks.filter((link) => link.status === 'affiliate').length,
  pending: affiliateLinks.filter((link) => link.status === 'pending').length,
  official: affiliateLinks.filter((link) => link.status === 'official').length,
};
const categoryCounts = articleRows.reduce<Record<string, number>>((acc, row) => {
  acc[row.category] = (acc[row.category] ?? 0) + 1;
  return acc;
}, {});
const actionRows = articleRows.filter((row) => row.needsAction);
const publishedWithoutWorkflow = articleRows.filter((row) => !workflowSlugSet.has(row.slug));

const primaryNextActions = [
  `${actionRows.length}本の記事に、監修保留・ASP pending・未定義リンクのいずれかがあります。`,
  `${pendingQueue.length}件のキューが未着手です。次の記事候補は ${pendingQueue[0]?.slug ?? 'なし'} です。`,
  `${affiliateStats.pending}件のASPリンクが pending です。承認後は affiliateLinks.ts の status と URL を差し替えます。`,
];
---

<BaseLayout
  title="ブログ運営ダッシュボード"
  description="記事更新状況、制作工程、ASPリンク、未着手キューを一覧で確認する管理画面です。"
  robots="noindex,nofollow"
  wide
>
  <section class="ops-hero">
    <div>
      <p class="ops-kicker">REN BLOG OPERATIONS</p>
      <h1>ブログ運営ダッシュボード</h1>
      <p>記事・制作工程・ASPリンク・次の更新候補を1枚で確認するための管理画面です。</p>
    </div>
    <div class="ops-hero-panel">
      <span>次に見る場所</span>
      <strong>{actionRows.length > 0 ? '要対応記事' : '未着手キュー'}</strong>
      <a href={actionRows.length > 0 ? '#actions' : '#queue'}>{actionRows.length > 0 ? '詰まりを見る' : '次の記事を見る'}</a>
    </div>
  </section>

  <section class="ops-stats" aria-label="ブログ運営サマリー">
    <article>
      <span>公開記事</span>
      <strong>{posts.length}</strong>
      <small>queue published {publishedQueue.length}</small>
    </article>
    <article>
      <span>要対応</span>
      <strong>{actionRows.length}</strong>
      <small>監修・ASP・リンク</small>
    </article>
    <article>
      <span>未着手キュー</span>
      <strong>{pendingQueue.length}</strong>
      <small>次の制作候補</small>
    </article>
    <article>
      <span>ASP pending</span>
      <strong>{affiliateStats.pending}</strong>
      <small>承認待ち/差替待ち</small>
    </article>
  </section>

  <section class="ops-grid">
    <div class="ops-panel">
      <div class="ops-panel-head">
        <h2>今日の確認</h2>
        <span>{dateLabel(new Date())}</span>
      </div>
      <ul class="ops-checks">
        {primaryNextActions.map((action) => <li>{action}</li>)}
      </ul>
    </div>

    <div class="ops-panel">
      <div class="ops-panel-head">
        <h2>カテゴリ別</h2>
        <span>{Object.keys(categoryCounts).length}カテゴリ</span>
      </div>
      <div class="ops-bars">
        {Object.entries(categoryCounts).map(([category, count]) => (
          <div>
            <span>{category}</span>
            <meter min="0" max={posts.length} value={count}>{count}</meter>
            <strong>{count}</strong>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section id="actions" class="ops-section">
    <div class="ops-section-head">
      <div>
        <p>PRIORITY</p>
        <h2>要対応記事</h2>
      </div>
      <span>{actionRows.length}件</span>
    </div>

    <div class="ops-table-wrap">
      <table class="ops-table">
        <thead>
          <tr>
            <th>記事</th>
            <th>更新</th>
            <th>制作工程</th>
            <th>ASPリンク</th>
            <th>次の確認</th>
          </tr>
        </thead>
        <tbody>
          {actionRows.map((row) => (
            <tr>
              <td>
                <a href={`/blog/${row.slug}/`} class="ops-title">{row.title}</a>
                <span class="ops-meta">{row.slug} / {row.category}</span>
              </td>
              <td>{dateLabel(row.updatedAt)}</td>
              <td><span class={`ops-pill ${row.workflow.tone}`}>{row.workflow.label}</span></td>
              <td>
                <div class="ops-link-stack">
                  {row.links.length === 0 && row.missingLinks.length === 0 && <span class="ops-muted">CTAなし</span>}
                  {row.links.map((link) => link && (
                    <span class={`ops-link-pill ${link.status}`}>
                      {link.name} / {link.status}
                    </span>
                  ))}
                  {row.missingLinks.map((slug) => <span class="ops-link-pill missing">{slug} 未定義</span>)}
                </div>
              </td>
              <td>{row.workflow.reason}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

  <section class="ops-section">
    <div class="ops-section-head">
      <div>
        <p>ARTICLES</p>
        <h2>記事更新マップ</h2>
      </div>
      <span>{articleRows.length}本</span>
    </div>

    <div class="ops-table-wrap">
      <table class="ops-table compact">
        <thead>
          <tr>
            <th>記事</th>
            <th>分類</th>
            <th>導線</th>
            <th>キュー</th>
            <th>監修</th>
            <th>ASP</th>
          </tr>
        </thead>
        <tbody>
          {articleRows.map((row) => (
            <tr>
              <td>
                <a href={`/blog/${row.slug}/`} class="ops-title">{row.title}</a>
                <span class="ops-meta">{row.slug} / 更新 {dateLabel(row.updatedAt)}</span>
              </td>
              <td>{row.category}</td>
              <td>{row.channel}</td>
              <td>{row.queueStatus}</td>
              <td><span class={`ops-pill ${row.workflow.tone}`}>{row.workflow.label}</span></td>
              <td>
                {row.links.length > 0
                  ? `${row.links.filter((link) => link?.status === 'affiliate').length}/${row.links.length} 承認`
                  : row.missingLinks.length > 0 ? '未定義あり' : 'なし'}
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

  <section id="queue" class="ops-grid">
    <div class="ops-panel">
      <div class="ops-panel-head">
        <h2>未着手キュー</h2>
        <span>{pendingQueue.length}件</span>
      </div>
      <div class="ops-queue">
        {pendingQueue.map((item) => (
          <article>
            <strong>{item.slug}</strong>
            <span>{item.keyword}</span>
            <small>{item.category} / {item.channel ?? 'manual'} / priority {item.priority ?? '-'}</small>
          </article>
        ))}
      </div>
    </div>

    <div class="ops-panel">
      <div class="ops-panel-head">
        <h2>ASPリンク台帳</h2>
        <span>{affiliateLinks.length}件</span>
      </div>
      <div class="ops-affiliates">
        {affiliateLinks.map((link) => (
          <a href={`/go/${link.slug}/`} class={`ops-affiliate ${link.status}`}>
            <strong>{link.name}</strong>
            <span>{link.category} / {link.provider}</span>
            <small>{link.status}</small>
          </a>
        ))}
      </div>
    </div>
  </section>

  {(publishedWithoutWorkflow.length > 0 || workflowOnly.length > 0) && (
    <section class="ops-section">
      <div class="ops-section-head">
        <div>
          <p>DATA CHECK</p>
          <h2>台帳のズレ</h2>
        </div>
      </div>
      <div class="ops-warnings">
        {publishedWithoutWorkflow.length > 0 && (
          <p>記事はあるが `記事制作/&lt;slug&gt;/07-human-review.md` がない: {publishedWithoutWorkflow.map((row) => row.slug).join(', ')}</p>
        )}
        {workflowOnly.length > 0 && (
          <p>制作工程はあるが公開記事がない: {workflowOnly.join(', ')}</p>
        )}
      </div>
    </section>
  )}

  <style>
    .ops-hero {
      display: grid;
      grid-template-columns: minmax(0, 1fr) 280px;
      gap: 1rem;
      align-items: stretch;
      margin-bottom: 1rem;
      background: #101820;
      color: #f8fafc;
      border-radius: 8px;
      padding: 1.5rem;
      border: 1px solid #0f172a;
    }
    .ops-kicker {
      color: #f2b84b;
      font-size: 0.72rem;
      font-weight: 800;
      letter-spacing: 0.12em;
      margin-bottom: 0.35rem;
    }
    .ops-hero h1 {
      font-size: 1.9rem;
      line-height: 1.25;
      margin: 0 0 0.5rem;
      letter-spacing: 0;
    }
    .ops-hero p {
      max-width: 680px;
      color: #cbd5e1;
      margin: 0;
      line-height: 1.75;
    }
    .ops-hero-panel {
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      gap: 0.75rem;
      border: 1px solid rgba(248, 250, 252, 0.18);
      border-radius: 8px;
      padding: 1rem;
      background: rgba(255, 255, 255, 0.06);
    }
    .ops-hero-panel span,
    .ops-hero-panel a {
      color: #cbd5e1;
      font-size: 0.82rem;
    }
    .ops-hero-panel strong {
      font-size: 1.35rem;
      color: #fff;
    }
    .ops-stats {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 0.75rem;
      margin-bottom: 1rem;
    }
    .ops-stats article,
    .ops-panel,
    .ops-section {
      background: #fff;
      border: 1px solid #d8dee9;
      border-radius: 8px;
      box-shadow: 0 1px 2px rgba(15, 23, 42, 0.05);
    }
    .ops-stats article {
      padding: 1rem;
    }
    .ops-stats span,
    .ops-stats small,
    .ops-meta,
    .ops-muted {
      color: #64748b;
      font-size: 0.78rem;
    }
    .ops-stats strong {
      display: block;
      color: #0f172a;
      font-size: 1.75rem;
      line-height: 1.2;
      margin: 0.15rem 0;
    }
    .ops-grid {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
      gap: 1rem;
      margin-bottom: 1rem;
    }
    .ops-panel {
      padding: 1rem;
    }
    .ops-panel-head,
    .ops-section-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
      margin-bottom: 0.85rem;
    }
    .ops-panel-head h2,
    .ops-section-head h2 {
      font-size: 1rem;
      line-height: 1.3;
      margin: 0;
      color: #0f172a;
    }
    .ops-panel-head span,
    .ops-section-head span,
    .ops-section-head p {
      color: #64748b;
      font-size: 0.76rem;
      font-weight: 700;
      letter-spacing: 0.05em;
      margin: 0;
    }
    .ops-checks {
      display: grid;
      gap: 0.6rem;
      padding-left: 1.1rem;
      color: #334155;
      font-size: 0.92rem;
      line-height: 1.65;
    }
    .ops-bars {
      display: grid;
      gap: 0.6rem;
    }
    .ops-bars div {
      display: grid;
      grid-template-columns: minmax(110px, 1fr) 2fr 2rem;
      gap: 0.7rem;
      align-items: center;
      font-size: 0.82rem;
      color: #334155;
    }
    .ops-bars meter {
      width: 100%;
      height: 0.7rem;
    }
    .ops-section {
      padding: 1rem;
      margin-bottom: 1rem;
    }
    .ops-table-wrap {
      overflow-x: auto;
      border: 1px solid #e2e8f0;
      border-radius: 8px;
    }
    .ops-table {
      width: 100%;
      border-collapse: collapse;
      min-width: 820px;
      font-size: 0.84rem;
    }
    .ops-table.compact {
      min-width: 980px;
    }
    .ops-table th,
    .ops-table td {
      padding: 0.75rem;
      border-bottom: 1px solid #e2e8f0;
      text-align: left;
      vertical-align: top;
    }
    .ops-table th {
      background: #f8fafc;
      color: #475569;
      font-size: 0.72rem;
      letter-spacing: 0.06em;
      text-transform: uppercase;
    }
    .ops-title {
      display: block;
      color: #0f172a;
      font-weight: 800;
      line-height: 1.5;
      margin-bottom: 0.2rem;
    }
    .ops-pill,
    .ops-link-pill {
      display: inline-flex;
      align-items: center;
      width: fit-content;
      border-radius: 999px;
      padding: 0.16rem 0.55rem;
      font-size: 0.72rem;
      font-weight: 800;
      white-space: nowrap;
    }
    .ops-pill.ok,
    .ops-link-pill.affiliate {
      background: #dcfce7;
      color: #166534;
    }
    .ops-pill.hold,
    .ops-link-pill.pending {
      background: #fef3c7;
      color: #92400e;
    }
    .ops-pill.missing,
    .ops-link-pill.missing {
      background: #fee2e2;
      color: #991b1b;
    }
    .ops-link-pill.official {
      background: #dbeafe;
      color: #1e40af;
    }
    .ops-link-stack {
      display: flex;
      flex-wrap: wrap;
      gap: 0.3rem;
      max-width: 340px;
    }
    .ops-queue,
    .ops-affiliates {
      display: grid;
      gap: 0.55rem;
      max-height: 480px;
      overflow: auto;
      padding-right: 0.25rem;
    }
    .ops-queue article,
    .ops-affiliate {
      display: grid;
      gap: 0.15rem;
      padding: 0.7rem 0.75rem;
      border: 1px solid #e2e8f0;
      border-radius: 8px;
      background: #f8fafc;
      color: #334155;
    }
    .ops-affiliate:hover {
      text-decoration: none;
      border-color: #94a3b8;
    }
    .ops-queue strong,
    .ops-affiliate strong {
      color: #0f172a;
      font-size: 0.88rem;
      line-height: 1.45;
    }
    .ops-queue span,
    .ops-affiliate span {
      font-size: 0.78rem;
      color: #475569;
      line-height: 1.5;
    }
    .ops-queue small,
    .ops-affiliate small {
      color: #64748b;
      font-size: 0.72rem;
    }
    .ops-affiliate.affiliate {
      border-left: 4px solid #16a34a;
    }
    .ops-affiliate.pending {
      border-left: 4px solid #d97706;
    }
    .ops-affiliate.official {
      border-left: 4px solid #2563eb;
    }
    .ops-warnings {
      display: grid;
      gap: 0.5rem;
      color: #7f1d1d;
      background: #fff7ed;
      border: 1px solid #fed7aa;
      border-radius: 8px;
      padding: 0.85rem;
      font-size: 0.86rem;
      line-height: 1.7;
    }
    @media (max-width: 820px) {
      .ops-hero,
      .ops-grid,
      .ops-stats {
        grid-template-columns: 1fr;
      }
      .ops-hero {
        padding: 1.15rem;
      }
      .ops-hero h1 {
        font-size: 1.5rem;
      }
    }
  </style>
</BaseLayout>
