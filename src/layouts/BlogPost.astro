---
import BaseLayout from './BaseLayout.astro';
import { getLineAddUrl, getLineRef, getLineRefForArticle } from '../data/lineLinks';
import { getArticleFaqs } from '../data/articleFaqs';
import { CATEGORIES } from '../data/categories';
import RelatedPosts from '../components/RelatedPosts.astro';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  heroImage?: string;
  category: string;
  affiliate?: boolean;
  headings?: { depth: number; slug: string; text: string }[];
  articleType?: 'review' | 'guide' | 'comparison' | 'news';
  rating?: number;
}

const { title, description, pubDate, updatedDate, heroImage, category, affiliate = true, headings = [], articleType, rating } = Astro.props;
const slug = Astro.url.pathname.replace(/^\/blog\//, '').replace(/\/$/, '');
const catInfo = CATEGORIES[category];
const ogImage = heroImage ?? `/og/${slug}.svg`;
const lineRef = getLineRef(getLineRefForArticle(slug, category));
const adSourceRef = Astro.url.searchParams.get('ref')?.trim();
const resolvedLineRef = lineRef ? lineRef.ref : 'blog-main';
const lineAddUrl = getLineAddUrl(adSourceRef ? `${resolvedLineRef}__${adSourceRef}` : resolvedLineRef);
const SITE_URL = 'https://ren-money.com';
const AUTHOR = { '@type': 'Person', name: '田中蓮', url: `${SITE_URL}/about/` };

// BreadcrumbList スキーマ
const breadcrumbJsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'ホーム',   item: SITE_URL + '/' },
    ...(catInfo ? [{ '@type': 'ListItem', position: 2, name: category, item: `${SITE_URL}/blog/category/${catInfo.slug}/` }] : []),
    { '@type': 'ListItem', position: catInfo ? 3 : 2, name: title, item: `${SITE_URL}/blog/${slug}/` },
  ],
});

// Article スキーマ（全記事共通）
const articleJsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': articleType === 'review' ? 'Review' : 'Article',
  headline: title,
  description,
  image: heroImage ? [heroImage] : [`${SITE_URL}/og/${slug}.svg`, `${SITE_URL}/thumbnails/${slug}.svg`],
  datePublished: pubDate.toISOString(),
  dateModified: (updatedDate ?? pubDate).toISOString(),
  author: AUTHOR,
  publisher: {
    '@type': 'Organization',
    name: 'ren-money.com',
    logo: { '@type': 'ImageObject', url: `${SITE_URL}/favicon.svg` },
  },
  url: `${SITE_URL}/blog/${slug}/`,
  ...(articleType === 'review' && rating ? {
    reviewRating: {
      '@type': 'Rating',
      ratingValue: rating,
      bestRating: 5,
      worstRating: 1,
    },
    itemReviewed: { '@type': 'FinancialProduct', name: title.replace(/のレビュー|評判.*$/, '').trim() },
  } : {}),
});

const faqItems = getArticleFaqs(slug);
const faqJsonLd = faqItems.length > 0 ? JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.answer,
    },
  })),
}) : null;

const dateStr = pubDate.toLocaleDateString('ja-JP', { year: 'numeric', month: 'long', day: 'numeric' });
const updatedStr = updatedDate?.toLocaleDateString('ja-JP', { year: 'numeric', month: 'long', day: 'numeric' });

const tocHeadings = headings.filter(h => h.depth === 2);
---

<BaseLayout title={title} description={description} image={ogImage} article={true} pubDate={pubDate} updatedDate={updatedDate}>
  <article>
    <!-- パンくずリスト -->
    <nav aria-label="パンくずリスト" style="font-size:0.78rem;color:#9ca3af;margin-bottom:0.75rem;display:flex;gap:0.35rem;flex-wrap:wrap;align-items:center;">
      <a href="/" style="color:#6b7280;text-decoration:none;transition:color .15s;" onmouseover="this.style.color='#2563eb'" onmouseout="this.style.color='#6b7280'">ホーム</a>
      <span aria-hidden="true">›</span>
      <a href="/blog/" style="color:#6b7280;text-decoration:none;transition:color .15s;" onmouseover="this.style.color='#2563eb'" onmouseout="this.style.color='#6b7280'">記事一覧</a>
      {catInfo && <>
        <span aria-hidden="true">›</span>
        <a href={`/blog/category/${catInfo.slug}/`} style="color:#6b7280;text-decoration:none;transition:color .15s;" onmouseover="this.style.color='#2563eb'" onmouseout="this.style.color='#6b7280'">{category}</a>
      </>}
      <span aria-hidden="true">›</span>
      <span style="color:#1f2937;font-weight:500;">{title.length > 30 ? title.slice(0, 30) + '…' : title}</span>
    </nav>

    <div style="margin-bottom:0.5rem;">
      <span style="background:var(--color-primary-light);color:var(--color-primary);font-size:0.8rem;font-weight:700;padding:0.2rem 0.6rem;border-radius:4px;">{category}</span>
    </div>

    <h1 style="font-size:clamp(1.75rem, 4vw, 2.45rem);font-weight:900;line-height:1.35;margin-bottom:0.75rem;color:#17352a;">{title}</h1>

    <div style="font-size:0.8rem;color:var(--color-text-muted);margin-bottom:1.25rem;">
      <time datetime={pubDate.toISOString()}>公開：{dateStr}</time>
      {updatedDate && <span style="margin-left:0.75rem;"><time datetime={updatedDate.toISOString()}>更新：{updatedStr}</time></span>}
    </div>

    <img src={heroImage ?? ogImage} alt={title} decoding="async" fetchpriority="high" style="width:100%;aspect-ratio:16/9;object-fit:cover;border-radius:14px;margin-bottom:1.5rem;border:1px solid #d7e7df;background:#f2fbf5;box-shadow:0 14px 38px rgba(42,71,59,.08);" />

    {tocHeadings.length > 2 && (
      <nav class="toc" aria-label="目次">
        <p class="toc-title">この記事の目次</p>
        <ol class="toc-list">
          {tocHeadings.map((h, i) => (
            <li class="toc-item">
              <a href={`#${h.slug}`} class="toc-link">
                <span class="toc-num">{i + 1}</span>
                <span>{h.text}</span>
              </a>
            </li>
          ))}
        </ol>
      </nav>
    )}

    <div class="prose">
      <slot />
    </div>

    {faqItems.length > 0 && (
      <section class="article-faq" id="faq">
        <p class="article-faq-label">FAQ</p>
        <h2>この記事のよくある質問</h2>
        <div class="article-faq-list">
          {faqItems.map((item) => (
            <details class="article-faq-item">
              <summary>
                <span class="article-faq-q">Q</span>
                <span>{item.question}</span>
              </summary>
              <p>{item.answer}</p>
            </details>
          ))}
        </div>
      </section>
    )}

    <script is:inline type="application/ld+json" set:html={articleJsonLd} />
    {faqJsonLd && <script is:inline type="application/ld+json" set:html={faqJsonLd} />}
    <script is:inline type="application/ld+json" set:html={breadcrumbJsonLd} />

    <!-- 著者プロフィールボックス -->
    <aside class="author-box">
      <div class="author-box-avatar">
        <svg width="56" height="56" viewBox="0 0 120 120" aria-hidden="true">
          <defs><clipPath id="ab1"><circle cx="60" cy="60" r="56"/></clipPath></defs>
          <g clip-path="url(#ab1)">
            <rect width="120" height="120" fill="#EEF1F7"/>
            <rect x="50" y="62" width="20" height="20" fill="#F4D5BA"/>
            <path d="M30 92 Q60 80 90 92 L100 120 L20 120 Z" fill="#fff"/>
            <path d="M18 120 L30 86 Q42 94 42 110 L60 120 Z" fill="#0B1942"/>
            <path d="M102 120 L90 86 Q78 94 78 110 L60 120 Z" fill="#0B1942"/>
            <ellipse cx="60" cy="52" rx="22" ry="26" fill="#F4D5BA"/>
            <path d="M38 46 Q38 22 60 22 Q82 22 82 46 Q82 38 76 34 Q70 30 60 32 Q50 34 44 40 Q40 44 38 46Z" fill="#1A1A1A"/>
            <ellipse cx="51" cy="54" rx="2.2" ry="3" fill="#111"/>
            <ellipse cx="69" cy="54" rx="2.2" ry="3" fill="#111"/>
            <path d="M55 66 Q60 70 65 66" stroke="#9B5A4A" stroke-width="1.8" stroke-linecap="round" fill="none"/>
          </g>
        </svg>
      </div>
      <div class="author-box-body">
        <p class="author-box-label">この記事を書いた人</p>
        <p class="author-box-name">田中 蓮</p>
        <p class="author-box-bio">32歳のIT会社員。借金200万円からFX・副業・NISA で資産500万円を達成。35歳FIREを目指して情報発信中。体験ベースで初心者にわかりやすく解説します。</p>
      </div>
    </aside>

    <RelatedPosts currentSlug={slug} category={category} />

    <section class="line-cta">
      <h2>{lineRef ? lineRef.headline : '気になった内容をLINEで整理する'}</h2>
      <p>{lineRef ? lineRef.description : '登録後に4択から1つ選ぶと、悩みに合わせた情報をまとめて受け取れます。不要なときはすぐ解除できます。'}</p>
      <a class="line-cta-button" href={lineAddUrl} rel="noopener noreferrer"
         data-google-event="line_click"
         data-google-category="lead"
         data-google-label={resolvedLineRef}>LINEで受け取る（無料）</a>
    </section>

    <div class="disclaimer">
      <strong>【免責事項】</strong>
      当記事は情報提供を目的としており、特定の金融商品・サービスへの投資・申し込みを推奨するものではありません。
      投資にはリスクが伴い、元本を割り込む可能性があります。最終的な判断はご自身の責任でお願いします。
      掲載情報は作成時点のものであり、最新情報は各社公式サイトをご確認ください。
    </div>
  </article>
</BaseLayout>

<style>
  /* ── 目次 ── */
  .toc {
    margin: 1.5rem 0;
    padding: 1.1rem 1.25rem 1.25rem;
    background: #f2fbf5;
    border: 1px solid #d7e7df;
    border-radius: 10px;
  }
  .toc-title {
    font-size: 0.82rem;
    font-weight: 800;
    color: #0f8a5f;
    letter-spacing: 0.06em;
    margin: 0 0 0.85rem;
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }
  .toc-title::before {
    content: '';
    display: inline-block;
    width: 14px;
    height: 14px;
    background: #0f8a5f;
    border-radius: 3px;
    flex-shrink: 0;
  }
  .toc-list {
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .toc-item { margin: 0; }
  .toc-link {
    display: flex;
    align-items: baseline;
    gap: 0.6rem;
    font-size: 0.88rem;
    color: #174638;
    text-decoration: none;
    line-height: 1.55;
    padding: 0.3rem 0.5rem;
    border-radius: 5px;
    transition: background 0.15s;
  }
  .toc-link:hover {
    background: rgba(255,255,255,0.65);
    text-decoration: none;
  }
  .toc-num {
    flex-shrink: 0;
    width: 1.4rem;
    height: 1.4rem;
    background: #0f8a5f;
    color: #fff;
    border-radius: 50%;
    font-size: 0.7rem;
    font-weight: 800;
    display: flex;
    align-items: center;
    justify-content: center;
    line-height: 1;
  }

  /* ── LINE CTA ── */
  .article-faq {
    margin-top: 2.2rem;
    padding: 1.2rem 1.25rem;
    border: 1px solid #e5e7eb;
    border-radius: var(--radius);
    background: #fff;
  }
  .article-faq-label {
    margin: 0 0 0.35rem;
    font-size: 0.72rem;
    font-weight: 800;
    color: #64748b;
    letter-spacing: 0.08em;
  }
  .article-faq h2 {
    margin: 0 0 0.85rem;
    font-size: 1.15rem;
    line-height: 1.45;
  }
  .article-faq-list {
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
  }
  .article-faq-item {
    border: 1px solid #e5e7eb;
    border-radius: 8px;
    background: #f8fafc;
  }
  .article-faq-item summary {
    display: flex;
    align-items: baseline;
    gap: 0.65rem;
    padding: 0.85rem 0.9rem;
    cursor: pointer;
    font-size: 0.92rem;
    font-weight: 700;
    line-height: 1.55;
    color: #111827;
  }
  .article-faq-item summary::-webkit-details-marker { display: none; }
  .article-faq-q {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.45rem;
    height: 1.45rem;
    border-radius: 999px;
    background: #dbeafe;
    color: #1d4ed8;
    font-size: 0.75rem;
    font-weight: 900;
  }
  .article-faq-item p {
    margin: 0;
    padding: 0 0.9rem 0.9rem 3rem;
    color: var(--color-text-muted);
    font-size: 0.9rem;
    line-height: 1.75;
  }

  /* ── 著者プロフィールボックス ── */
  .author-box {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
    margin-top: 2.5rem;
    padding: 1.25rem;
    background: #f8fafc;
    border: 1px solid #e2e8f0;
    border-radius: 10px;
  }
  .author-box-avatar {
    flex-shrink: 0;
    width: 60px;
    height: 60px;
    border-radius: 50%;
    overflow: hidden;
    border: 2px solid #dff5e9;
  }
  .author-box-avatar svg { display: block; }
  .author-box-label {
    font-size: 0.72rem;
    font-weight: 700;
    color: #94a3b8;
    letter-spacing: 0.06em;
    margin: 0 0 0.2rem;
  }
  .author-box-name {
    font-size: 1rem;
    font-weight: 700;
    color: #1e293b;
    margin: 0 0 0.4rem;
  }
  .author-box-bio {
    font-size: 0.83rem;
    color: #64748b;
    line-height: 1.7;
    margin: 0;
  }

  .line-cta {
    margin-top: 2rem;
    padding: 1.2rem 1.25rem;
    border: 1px solid #d7e7df;
    border-radius: var(--radius);
    background: linear-gradient(180deg, #f2fbf5 0%, #ffffff 100%);
  }
  .line-cta h2 {
    font-size: 1.1rem;
    line-height: 1.4;
    margin-bottom: 0.5rem;
    color: var(--color-text);
  }
  .line-cta p {
    font-size: 0.9rem;
    line-height: 1.75;
    color: var(--color-text-muted);
    margin-bottom: 0.9rem;
  }
  .line-cta-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.85rem 1.25rem;
    border-radius: 10px;
    background: #06c755;
    color: #fff;
    font-weight: 800;
    text-decoration: none;
  }
</style>
