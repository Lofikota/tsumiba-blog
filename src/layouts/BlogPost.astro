---
import BaseLayout from './BaseLayout.astro';
import { getLineAddUrl, getLineRef, getLineRefForArticle } from '../data/lineLinks';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  heroImage?: string;
  category: string;
  affiliate?: boolean;
  headings?: { depth: number; slug: string; text: string }[];
}

const { title, description, pubDate, updatedDate, heroImage, category, affiliate = true, headings = [] } = Astro.props;
const slug = Astro.url.pathname.replace(/^\/blog\//, '').replace(/\/$/, '');
const ogImage = heroImage ?? `/og/${slug}.svg`;
const lineRef = getLineRef(getLineRefForArticle(slug, category));
const lineAddUrl = lineRef ? getLineAddUrl(lineRef.ref) : getLineAddUrl('blog-main');

const dateStr = pubDate.toLocaleDateString('ja-JP', { year: 'numeric', month: 'long', day: 'numeric' });
const updatedStr = updatedDate?.toLocaleDateString('ja-JP', { year: 'numeric', month: 'long', day: 'numeric' });

const tocHeadings = headings.filter(h => h.depth === 2);
---

<BaseLayout title={title} description={description} image={ogImage} article={true} pubDate={pubDate} updatedDate={updatedDate}>
  <article>
    <div style="margin-bottom:0.5rem;">
      <span style="background:var(--color-primary-light);color:var(--color-primary);font-size:0.8rem;font-weight:700;padding:0.2rem 0.6rem;border-radius:4px;">{category}</span>
    </div>

    <h1 style="font-size:1.6rem;font-weight:700;line-height:1.4;margin-bottom:0.75rem;">{title}</h1>

    <div style="font-size:0.8rem;color:var(--color-text-muted);margin-bottom:1.25rem;">
      <time datetime={pubDate.toISOString()}>公開：{dateStr}</time>
      {updatedDate && <span style="margin-left:0.75rem;"><time datetime={updatedDate.toISOString()}>更新：{updatedStr}</time></span>}
    </div>

    {heroImage && <img src={heroImage} alt={title} decoding="async" fetchpriority="high" style="width:100%;border-radius:var(--radius);margin-bottom:1.5rem;" />}

    {tocHeadings.length > 2 && (
      <nav class="toc" aria-label="目次">
        <p class="toc-title">この記事の内容</p>
        <ol class="toc-list">
          {tocHeadings.map((h, i) => (
            <li class="toc-item">
              <a href={`#${h.slug}`} class="toc-link">
                <span class="toc-num">{i + 1}</span>
                {h.text}
              </a>
            </li>
          ))}
        </ol>
      </nav>
    )}

    <div class="prose">
      <slot />
    </div>

    <section class="line-cta">
      <h2>気になった内容をLINEで整理する</h2>
      <p>{lineRef ? lineRef.description : '登録後に4択から1つ選ぶと、悩みに合わせた情報をまとめて受け取れます。不要なときはすぐ解除できます。'}</p>
      <a class="line-cta-button" href={lineAddUrl} rel="noopener noreferrer">LINEで受け取る（無料）</a>
    </section>

    <div class="disclaimer">
      <strong>【免責事項】</strong>
      当記事は情報提供を目的としており、特定の金融商品・サービスへの投資・申し込みを推奨するものではありません。
      投資にはリスクが伴い、元本を割り込む可能性があります。最終的な判断はご自身の責任でお願いします。
      掲載情報は作成時点のものであり、最新情報は各社公式サイトをご確認ください。
    </div>
  </article>
</BaseLayout>

<style>
  /* ── 目次 ── */
  .toc {
    margin: 1.5rem 0;
    padding: 1.1rem 1.25rem;
    background: #f8fafc;
    border: 1px solid #e2e8f0;
    border-radius: 10px;
  }
  .toc-title {
    font-size: 0.8rem;
    font-weight: 700;
    color: #64748b;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    margin: 0 0 0.75rem;
  }
  .toc-list {
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }
  .toc-item { margin: 0; }
  .toc-link {
    display: flex;
    align-items: baseline;
    gap: 0.6rem;
    font-size: 0.9rem;
    color: #1d4ed8;
    text-decoration: none;
    line-height: 1.5;
  }
  .toc-link:hover { text-decoration: underline; }
  .toc-num {
    flex-shrink: 0;
    width: 1.3rem;
    font-size: 0.75rem;
    font-weight: 700;
    color: #94a3b8;
  }

  /* ── LINE CTA ── */
  .line-cta {
    margin-top: 2rem;
    padding: 1.2rem 1.25rem;
    border: 1px solid #cfe2ff;
    border-radius: var(--radius);
    background: linear-gradient(180deg, #eff6ff 0%, #ffffff 100%);
  }
  .line-cta h2 {
    font-size: 1.1rem;
    line-height: 1.4;
    margin-bottom: 0.5rem;
    color: var(--color-text);
  }
  .line-cta p {
    font-size: 0.9rem;
    line-height: 1.75;
    color: var(--color-text-muted);
    margin-bottom: 0.9rem;
  }
  .line-cta-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.85rem 1.25rem;
    border-radius: 10px;
    background: #06c755;
    color: #fff;
    font-weight: 800;
    text-decoration: none;
  }
</style>
