---
import BaseLayout from './BaseLayout.astro';
import { getLineAddUrl, getLineRef, getLineRefForArticle } from '../data/lineLinks';
import { getArticleFaqs } from '../data/articleFaqs';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  heroImage?: string;
  category: string;
  affiliate?: boolean;
  headings?: { depth: number; slug: string; text: string }[];
  articleType?: 'review' | 'guide' | 'comparison' | 'news';
  rating?: number;
}

const { title, description, pubDate, updatedDate, heroImage, category, affiliate = true, headings = [], articleType, rating } = Astro.props;
const slug = Astro.url.pathname.replace(/^\/blog\//, '').replace(/\/$/, '');
const ogImage = heroImage ?? `/og/${slug}.svg`;
const lineRef = getLineRef(getLineRefForArticle(slug, category));
const adSourceRef = Astro.url.searchParams.get('ref')?.trim();
const resolvedLineRef = lineRef ? lineRef.ref : 'blog-main';
const lineAddUrl = getLineAddUrl(adSourceRef ? `${resolvedLineRef}__${adSourceRef}` : resolvedLineRef);
const SITE_URL = 'https://ren-money.com';
const AUTHOR = { '@type': 'Person', name: '田中蓮', url: `${SITE_URL}/about/` };

// Article スキーマ（全記事共通）
const articleJsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': articleType === 'review' ? 'Review' : 'Article',
  headline: title,
  description,
  image: heroImage ? [heroImage] : [`${SITE_URL}/og/${slug}.svg`],
  datePublished: pubDate.toISOString(),
  dateModified: (updatedDate ?? pubDate).toISOString(),
  author: AUTHOR,
  publisher: {
    '@type': 'Organization',
    name: 'ren-money.com',
    logo: { '@type': 'ImageObject', url: `${SITE_URL}/favicon.svg` },
  },
  url: `${SITE_URL}/blog/${slug}/`,
  ...(articleType === 'review' && rating ? {
    reviewRating: {
      '@type': 'Rating',
      ratingValue: rating,
      bestRating: 5,
      worstRating: 1,
    },
    itemReviewed: { '@type': 'FinancialProduct', name: title.replace(/のレビュー|評判.*$/, '').trim() },
  } : {}),
});

const faqItems = getArticleFaqs(slug);
const faqJsonLd = faqItems.length > 0 ? JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.answer,
    },
  })),
}) : null;

const dateStr = pubDate.toLocaleDateString('ja-JP', { year: 'numeric', month: 'long', day: 'numeric' });
const updatedStr = updatedDate?.toLocaleDateString('ja-JP', { year: 'numeric', month: 'long', day: 'numeric' });

const tocHeadings = headings.filter(h => h.depth === 2);
---

<BaseLayout title={title} description={description} image={ogImage} article={true} pubDate={pubDate} updatedDate={updatedDate}>
  <article>
    <div style="margin-bottom:0.5rem;">
      <span style="background:var(--color-primary-light);color:var(--color-primary);font-size:0.8rem;font-weight:700;padding:0.2rem 0.6rem;border-radius:4px;">{category}</span>
    </div>

    <h1 style="font-size:1.6rem;font-weight:700;line-height:1.4;margin-bottom:0.75rem;">{title}</h1>

    <div style="font-size:0.8rem;color:var(--color-text-muted);margin-bottom:1.25rem;">
      <time datetime={pubDate.toISOString()}>公開：{dateStr}</time>
      {updatedDate && <span style="margin-left:0.75rem;"><time datetime={updatedDate.toISOString()}>更新：{updatedStr}</time></span>}
    </div>

    {heroImage && <img src={heroImage} alt={title} decoding="async" fetchpriority="high" style="width:100%;border-radius:var(--radius);margin-bottom:1.5rem;" />}

    {tocHeadings.length > 2 && (
      <nav class="toc" aria-label="目次">
        <p class="toc-title">この記事の内容</p>
        <ol class="toc-list">
          {tocHeadings.map((h, i) => (
            <li class="toc-item">
              <a href={`#${h.slug}`} class="toc-link">
                <span class="toc-num">{i + 1}</span>
                {h.text}
              </a>
            </li>
          ))}
        </ol>
      </nav>
    )}

    <div class="prose">
      <slot />
    </div>

    {faqItems.length > 0 && (
      <section class="article-faq" id="faq">
        <p class="article-faq-label">FAQ</p>
        <h2>この記事のよくある質問</h2>
        <div class="article-faq-list">
          {faqItems.map((item) => (
            <details class="article-faq-item">
              <summary>
                <span class="article-faq-q">Q</span>
                <span>{item.question}</span>
              </summary>
              <p>{item.answer}</p>
            </details>
          ))}
        </div>
      </section>
    )}

    <script is:inline type="application/ld+json" set:html={articleJsonLd} />
    {faqJsonLd && <script is:inline type="application/ld+json" set:html={faqJsonLd} />}

    <section class="line-cta">
      <h2>{lineRef ? lineRef.headline : '気になった内容をLINEで整理する'}</h2>
      <p>{lineRef ? lineRef.description : '登録後に4択から1つ選ぶと、悩みに合わせた情報をまとめて受け取れます。不要なときはすぐ解除できます。'}</p>
      <a class="line-cta-button" href={lineAddUrl} rel="noopener noreferrer"
         data-google-event="line_click"
         data-google-category="lead"
         data-google-label={resolvedLineRef}>LINEで受け取る（無料）</a>
    </section>

    <div class="disclaimer">
      <strong>【免責事項】</strong>
      当記事は情報提供を目的としており、特定の金融商品・サービスへの投資・申し込みを推奨するものではありません。
      投資にはリスクが伴い、元本を割り込む可能性があります。最終的な判断はご自身の責任でお願いします。
      掲載情報は作成時点のものであり、最新情報は各社公式サイトをご確認ください。
    </div>
  </article>
</BaseLayout>

<style>
  /* ── 目次 ── */
  .toc {
    margin: 1.5rem 0;
    padding: 1.1rem 1.25rem;
    background: #f8fafc;
    border: 1px solid #e2e8f0;
    border-radius: 10px;
  }
  .toc-title {
    font-size: 0.8rem;
    font-weight: 700;
    color: #64748b;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    margin: 0 0 0.75rem;
  }
  .toc-list {
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }
  .toc-item { margin: 0; }
  .toc-link {
    display: flex;
    align-items: baseline;
    gap: 0.6rem;
    font-size: 0.9rem;
    color: #1d4ed8;
    text-decoration: none;
    line-height: 1.5;
  }
  .toc-link:hover { text-decoration: underline; }
  .toc-num {
    flex-shrink: 0;
    width: 1.3rem;
    font-size: 0.75rem;
    font-weight: 700;
    color: #94a3b8;
  }

  /* ── LINE CTA ── */
  .article-faq {
    margin-top: 2.2rem;
    padding: 1.2rem 1.25rem;
    border: 1px solid #e5e7eb;
    border-radius: var(--radius);
    background: #fff;
  }
  .article-faq-label {
    margin: 0 0 0.35rem;
    font-size: 0.72rem;
    font-weight: 800;
    color: #64748b;
    letter-spacing: 0.08em;
  }
  .article-faq h2 {
    margin: 0 0 0.85rem;
    font-size: 1.15rem;
    line-height: 1.45;
  }
  .article-faq-list {
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
  }
  .article-faq-item {
    border: 1px solid #e5e7eb;
    border-radius: 8px;
    background: #f8fafc;
  }
  .article-faq-item summary {
    display: flex;
    align-items: baseline;
    gap: 0.65rem;
    padding: 0.85rem 0.9rem;
    cursor: pointer;
    font-size: 0.92rem;
    font-weight: 700;
    line-height: 1.55;
    color: #111827;
  }
  .article-faq-item summary::-webkit-details-marker { display: none; }
  .article-faq-q {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.45rem;
    height: 1.45rem;
    border-radius: 999px;
    background: #dbeafe;
    color: #1d4ed8;
    font-size: 0.75rem;
    font-weight: 900;
  }
  .article-faq-item p {
    margin: 0;
    padding: 0 0.9rem 0.9rem 3rem;
    color: var(--color-text-muted);
    font-size: 0.9rem;
    line-height: 1.75;
  }

  .line-cta {
    margin-top: 2rem;
    padding: 1.2rem 1.25rem;
    border: 1px solid #cfe2ff;
    border-radius: var(--radius);
    background: linear-gradient(180deg, #eff6ff 0%, #ffffff 100%);
  }
  .line-cta h2 {
    font-size: 1.1rem;
    line-height: 1.4;
    margin-bottom: 0.5rem;
    color: var(--color-text);
  }
  .line-cta p {
    font-size: 0.9rem;
    line-height: 1.75;
    color: var(--color-text-muted);
    margin-bottom: 0.9rem;
  }
  .line-cta-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.85rem 1.25rem;
    border-radius: 10px;
    background: #06c755;
    color: #fff;
    font-weight: 800;
    text-decoration: none;
  }
</style>
