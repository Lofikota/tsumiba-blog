---
import BaseLayout from './BaseLayout.astro';
import { getArticleFaqs } from '../data/articleFaqs';
import { getNextRead } from '../data/nextRead';
import { CATEGORIES } from '../data/categories';
import RelatedPosts from '../components/RelatedPosts.astro';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  heroImage?: string;
  category: string;
  affiliate?: boolean;
  headings?: { depth: number; slug: string; text: string }[];
  articleType?: 'review' | 'guide' | 'comparison' | 'news';
  rating?: number;
}

const { title, description, pubDate, updatedDate, heroImage, category, affiliate = true, headings = [], articleType, rating } = Astro.props;
const slug = Astro.url.pathname.replace(/^\/blog\//, '').replace(/\/$/, '');
const catInfo = CATEGORIES[category];
const ogImage = heroImage ?? `/og/${slug}.svg`;
const SITE_URL = 'https://tsumiba.com';
const AUTHOR = { '@type': 'Organization', name: 'tsumiba編集部', url: `${SITE_URL}/about/` };

// BreadcrumbList スキーマ
const breadcrumbJsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'ホーム',   item: SITE_URL + '/' },
    ...(catInfo ? [{ '@type': 'ListItem', position: 2, name: category, item: `${SITE_URL}/blog/category/${catInfo.slug}/` }] : []),
    { '@type': 'ListItem', position: catInfo ? 3 : 2, name: title, item: `${SITE_URL}/blog/${slug}/` },
  ],
});

// Article スキーマ（全記事共通）
const articleJsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': articleType === 'review' ? 'Review' : 'Article',
  headline: title,
  description,
  image: heroImage ? [heroImage] : [`${SITE_URL}/og/${slug}.svg`, `${SITE_URL}/thumbnails/${slug}.svg`],
  datePublished: pubDate.toISOString(),
  dateModified: (updatedDate ?? pubDate).toISOString(),
  author: AUTHOR,
  publisher: {
    '@type': 'Organization',
    name: 'tsumiba.com',
    logo: { '@type': 'ImageObject', url: `${SITE_URL}/favicon.svg` },
  },
  url: `${SITE_URL}/blog/${slug}/`,
  ...(articleType === 'review' && rating ? {
    reviewRating: {
      '@type': 'Rating',
      ratingValue: rating,
      bestRating: 5,
      worstRating: 1,
    },
    itemReviewed: { '@type': 'FinancialProduct', name: title.replace(/のレビュー|評判.*$/, '').trim() },
  } : {}),
});

const faqItems = getArticleFaqs(slug);
const faqJsonLd = faqItems.length > 0 ? JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.answer,
    },
  })),
}) : null;

const dateStr = pubDate.toLocaleDateString('ja-JP', { year: 'numeric', month: 'long', day: 'numeric' });
const updatedStr = updatedDate?.toLocaleDateString('ja-JP', { year: 'numeric', month: 'long', day: 'numeric' });

const tocHeadings = headings.filter(h => h.depth === 2);

// モバイル追従CTA（FX記事のみ・控えめ）。サイト優先順位#1のDMM FXへ送客（FxPriorityCTAと整合）。
const stickyCta = category === 'FX・外貨' ? { href: '/go/dmm-fx/', text: 'DMM FXのキャンペーン条件を見る', label: 'sticky-dmm-fx' } : null;

// 「次に読む」1本指定（リベ大型 原則7）。7ステップの学習順序に沿って次の一歩へ送る。
const nextRead = getNextRead(slug);
---

<BaseLayout title={title} description={description} image={ogImage} article={true} pubDate={pubDate} updatedDate={updatedDate}>
  <article>
    <!-- パンくずリスト -->
    <nav aria-label="パンくずリスト" style="font-size:0.78rem;color:#9ca3af;margin-bottom:0.75rem;display:flex;gap:0.35rem;flex-wrap:wrap;align-items:center;">
      <a href="/" style="color:#6b7280;text-decoration:none;transition:color .15s;" onmouseover="this.style.color='#1B3A5B'" onmouseout="this.style.color='#6b7280'">ホーム</a>
      <span aria-hidden="true">›</span>
      <a href="/blog/" style="color:#6b7280;text-decoration:none;transition:color .15s;" onmouseover="this.style.color='#1B3A5B'" onmouseout="this.style.color='#6b7280'">記事一覧</a>
      {catInfo && <>
        <span aria-hidden="true">›</span>
        <a href={`/blog/category/${catInfo.slug}/`} style="color:#6b7280;text-decoration:none;transition:color .15s;" onmouseover="this.style.color='#1B3A5B'" onmouseout="this.style.color='#6b7280'">{category}</a>
      </>}
      <span aria-hidden="true">›</span>
      <span style="color:#1f2937;font-weight:500;">{title.length > 30 ? title.slice(0, 30) + '…' : title}</span>
    </nav>

    <div style="margin-bottom:0.5rem;">
      <span style="background:var(--color-primary-light);color:var(--color-primary);font-size:0.8rem;font-weight:700;padding:0.2rem 0.6rem;border-radius:4px;">{category}</span>
    </div>

    <h1 style="font-size:clamp(1.75rem, 4vw, 2.45rem);font-weight:900;line-height:1.35;margin-bottom:0.75rem;color:#1F2937;">{title}</h1>

    <div style="font-size:0.8rem;color:var(--color-text-muted);margin-bottom:1.25rem;">
      <time datetime={pubDate.toISOString()}>公開：{dateStr}</time>
      {updatedDate && <span style="margin-left:0.75rem;"><time datetime={updatedDate.toISOString()}>更新：{updatedStr}</time></span>}
    </div>

    <img src={heroImage ?? ogImage} alt={title} decoding="async" fetchpriority="high" style="width:100%;aspect-ratio:16/9;object-fit:cover;border-radius:14px;margin-bottom:1.5rem;border:1px solid #e5e7eb;background:#f6f7f9;box-shadow:0 14px 38px rgba(42,71,59,.08);" />

    {tocHeadings.length > 2 && (
      <nav class="toc" aria-label="目次">
        <p class="toc-title">この記事の目次</p>
        <ol class="toc-list">
          {tocHeadings.map((h, i) => (
            <li class="toc-item">
              <a href={`#${h.slug}`} class="toc-link">
                <span class="toc-num">{i + 1}</span>
                <span>{h.text}</span>
              </a>
            </li>
          ))}
        </ol>
      </nav>
    )}

    <div class="prose">
      <slot />
    </div>

    {faqItems.length > 0 && (
      <section class="article-faq" id="faq">
        <p class="article-faq-label">FAQ</p>
        <h2>この記事のよくある質問</h2>
        <div class="article-faq-list">
          {faqItems.map((item) => (
            <details class="article-faq-item">
              <summary>
                <span class="article-faq-q">Q</span>
                <span>{item.question}</span>
              </summary>
              <p>{item.answer}</p>
            </details>
          ))}
        </div>
      </section>
    )}

    <script is:inline type="application/ld+json" set:html={articleJsonLd} />
    {faqJsonLd && <script is:inline type="application/ld+json" set:html={faqJsonLd} />}
    <script is:inline type="application/ld+json" set:html={breadcrumbJsonLd} />

    <!-- 編集部プロフィールボックス -->
    <aside class="author-box">
      <div class="author-box-avatar">
        <svg width="56" height="56" viewBox="0 0 40 40" fill="none" aria-hidden="true">
          <rect width="40" height="40" rx="8" fill="#F8F9FA"/>
          <rect x="11" y="24" width="18" height="5" rx="1.5" fill="#1B3A5B"/>
          <rect x="13" y="17.5" width="14" height="5" rx="1.5" fill="#1B3A5B"/>
          <rect x="15" y="11" width="10" height="5" rx="1.5" fill="#1B3A5B"/>
        </svg>
      </div>
      <div class="author-box-body">
        <p class="author-box-label">この記事を書いた人</p>
        <p class="author-box-name">tsumiba 編集部</p>
        <p class="author-box-bio">国内FX口座のスプレッド・スワップ・約定力・取引単位・各種条件を、公式情報ベースで比較・整理する編集部です。少額で始めたい初心者がFX口座を選ぶときの判断材料を、できるだけ中立にまとめています。</p>
      </div>
    </aside>

    <aside class="next-read" aria-label="次に読む記事">
      <p class="next-read-label">次の一歩</p>
      <a class="next-read-card" href={nextRead.href}>
        <span class="next-read-note">{nextRead.note}</span>
        <strong>{nextRead.label} »</strong>
      </a>
    </aside>

    <RelatedPosts currentSlug={slug} category={category} />

    <div class="disclaimer">
      <strong>【免責事項】</strong>
      当記事は情報提供を目的としており、特定の金融商品・サービスへの投資・申し込みを推奨するものではありません。
      投資にはリスクが伴い、元本を割り込む可能性があります。最終的な判断はご自身の責任でお願いします。
      掲載情報は作成時点のものであり、最新情報は各社公式サイトをご確認ください。
    </div>

    {stickyCta && (
      <div class="sticky-cta" id="stickyCta" hidden>
        <span class="sticky-cta-pr">PR</span>
        <a class="sticky-cta-link" href={stickyCta.href} rel="sponsored nofollow noopener noreferrer"
           data-google-event="affiliate_click"
           data-google-category="affiliate"
           data-google-label={stickyCta.label}>{stickyCta.text}</a>
        <button type="button" class="sticky-cta-close" id="stickyCtaClose" aria-label="閉じる">×</button>
      </div>
      <script is:inline>
        (() => {
          const bar = document.getElementById('stickyCta');
          if (!bar) return;
          const close = document.getElementById('stickyCtaClose');
          let dismissed = false;
          close?.addEventListener('click', () => { dismissed = true; bar.hidden = true; });
          const onScroll = () => {
            if (dismissed) return;
            bar.hidden = window.scrollY < 600;
          };
          window.addEventListener('scroll', onScroll, { passive: true });
          onScroll();
        })();
      </script>
    )}
  </article>
</BaseLayout>

<style>
  /* ── 目次 ── */
  .toc {
    margin: 1.5rem 0;
    padding: 1.1rem 1.25rem 1.25rem;
    background: #f6f7f9;
    border: 1px solid #e5e7eb;
    border-radius: 10px;
  }
  .toc-title {
    font-size: 0.82rem;
    font-weight: 800;
    color: #1B3A5B;
    letter-spacing: 0.06em;
    margin: 0 0 0.85rem;
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }
  .toc-title::before {
    content: '';
    display: inline-block;
    width: 14px;
    height: 14px;
    background: #1B3A5B;
    border-radius: 3px;
    flex-shrink: 0;
  }
  .toc-list {
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .toc-item { margin: 0; }
  .toc-link {
    display: flex;
    align-items: baseline;
    gap: 0.6rem;
    font-size: 0.88rem;
    color: #1F2937;
    text-decoration: none;
    line-height: 1.55;
    padding: 0.3rem 0.5rem;
    border-radius: 5px;
    transition: background 0.15s;
  }
  .toc-link:hover {
    background: rgba(255,255,255,0.65);
    text-decoration: none;
  }
  .toc-num {
    flex-shrink: 0;
    width: 1.4rem;
    height: 1.4rem;
    background: #1B3A5B;
    color: #fff;
    border-radius: 50%;
    font-size: 0.7rem;
    font-weight: 800;
    display: flex;
    align-items: center;
    justify-content: center;
    line-height: 1;
  }

  /* ── LINE CTA ── */
  .article-faq {
    margin-top: 2.2rem;
    padding: 1.2rem 1.25rem;
    border: 1px solid #e5e7eb;
    border-radius: var(--radius);
    background: #fff;
  }
  .article-faq-label {
    margin: 0 0 0.35rem;
    font-size: 0.72rem;
    font-weight: 800;
    color: #64748b;
    letter-spacing: 0.08em;
  }
  .article-faq h2 {
    margin: 0 0 0.85rem;
    font-size: 1.15rem;
    line-height: 1.45;
  }
  .article-faq-list {
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
  }
  .article-faq-item {
    border: 1px solid #e5e7eb;
    border-radius: 8px;
    background: #f8fafc;
  }
  .article-faq-item summary {
    display: flex;
    align-items: baseline;
    gap: 0.65rem;
    padding: 0.85rem 0.9rem;
    cursor: pointer;
    font-size: 0.92rem;
    font-weight: 700;
    line-height: 1.55;
    color: #111827;
  }
  .article-faq-item summary::-webkit-details-marker { display: none; }
  .article-faq-q {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.45rem;
    height: 1.45rem;
    border-radius: 999px;
    background: #F8F9FA;
    color: #1B3A5B;
    font-size: 0.75rem;
    font-weight: 900;
  }
  .article-faq-item p {
    margin: 0;
    padding: 0 0.9rem 0.9rem 3rem;
    color: var(--color-text-muted);
    font-size: 0.9rem;
    line-height: 1.75;
  }

  /* ── 次の一歩（リベ大型 原則7・白地＋左ボーダー） ── */
  .next-read {
    margin-top: 2rem;
  }
  .next-read-label {
    margin: 0 0 0.5rem;
    color: #1B3A5B;
    font-size: 0.78rem;
    font-weight: 900;
    letter-spacing: 0.08em;
  }
  .next-read-card {
    display: block;
    padding: 1rem 1.15rem;
    border: 1px solid #e5e7eb;
    border-left: 4px solid #E0A458;
    border-radius: 6px;
    background: #fff;
    color: #1F2937;
    text-decoration: none;
    transition: transform 0.15s ease;
  }
  .next-read-card:hover {
    text-decoration: none;
    transform: translateY(-2px);
  }
  .next-read-note {
    display: block;
    margin-bottom: 4px;
    color: #6b7280;
    font-size: 0.76rem;
    font-weight: 700;
  }
  .next-read-card strong {
    font-size: 1rem;
    line-height: 1.5;
    color: #1B3A5B;
  }

  /* ── 著者プロフィールボックス ── */
  .author-box {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
    margin-top: 2.5rem;
    padding: 1.25rem;
    background: #f8fafc;
    border: 1px solid #e2e8f0;
    border-radius: 10px;
  }
  .author-box-avatar {
    flex-shrink: 0;
    width: 60px;
    height: 60px;
    border-radius: 50%;
    overflow: hidden;
    border: 2px solid #F8F9FA;
  }
  .author-box-avatar svg { display: block; }
  .author-box-label {
    font-size: 0.72rem;
    font-weight: 700;
    color: #94a3b8;
    letter-spacing: 0.06em;
    margin: 0 0 0.2rem;
  }
  .author-box-name {
    font-size: 1rem;
    font-weight: 700;
    color: #1e293b;
    margin: 0 0 0.4rem;
  }
  .author-box-bio {
    font-size: 0.83rem;
    color: #64748b;
    line-height: 1.7;
    margin: 0;
  }

  /* ── モバイル追従CTA（控えめ・FX記事のみ） ── */
  .sticky-cta { display: none; }
  @media (max-width: 640px) {
    .sticky-cta {
      display: flex;
      align-items: center;
      gap: 0.6rem;
      position: fixed;
      left: 0; right: 0; bottom: 0;
      z-index: 50;
      padding: 0.6rem 0.85rem;
      background: #fff;
      border-top: 1px solid #e5e7eb;
      box-shadow: 0 -4px 16px rgba(15,23,42,.06);
    }
    .sticky-cta[hidden] { display: none; }
    .sticky-cta-pr {
      flex-shrink: 0;
      font-size: 0.6rem;
      font-weight: 700;
      color: #94a3b8;
      letter-spacing: 0.05em;
    }
    .sticky-cta-link {
      flex: 1;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 0.7rem 0.5rem;
      border-radius: 8px;
      background: #E0A458;
      color: #1B3A5B;
      font-size: 0.92rem;
      font-weight: 700;
      text-decoration: none;
    }
    .sticky-cta-close {
      flex-shrink: 0;
      width: 1.9rem;
      height: 1.9rem;
      border: none;
      background: transparent;
      color: #94a3b8;
      font-size: 1.2rem;
      line-height: 1;
      cursor: pointer;
    }
  }
</style>
