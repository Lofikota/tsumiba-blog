---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  image?: string;
  article?: boolean;
  pubDate?: Date;
  updatedDate?: Date;
}

const { title, description, image = '/og-default.svg', article = false, pubDate, updatedDate } = Astro.props;
const siteUrl = 'https://ren-money.com';
const canonicalUrl = new URL(Astro.url.pathname, siteUrl);
const siteName = '田中蓮のマネーブログ';
const pageTitle = title.includes(siteName) ? title : `${title} | ${siteName}`;
const absoluteImageUrl = new URL(image, siteUrl);
const gaId = import.meta.env.PUBLIC_GA_ID;
---

<!doctype html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{pageTitle}</title>
  <meta name="description" content={description} />
  <meta name="robots" content="index,follow,max-image-preview:large" />
  <meta name="referrer" content="strict-origin-when-cross-origin" />
  <meta name="theme-color" content="#2563eb" />
  <link rel="canonical" href={canonicalUrl} />
  <link rel="alternate" type="application/rss+xml" title={`${siteName} RSS`} href={new URL('/rss.xml', siteUrl)} />

  <!-- OGP -->
  <meta property="og:type" content={article ? 'article' : 'website'} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:title" content={pageTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={absoluteImageUrl} />
  <meta property="og:image:alt" content={title} />
  <meta property="og:site_name" content={siteName} />
  <meta property="og:locale" content="ja_JP" />
  {article && pubDate && <meta property="article:published_time" content={pubDate.toISOString()} />}
  {article && updatedDate && <meta property="article:modified_time" content={updatedDate.toISOString()} />}
  {article && <meta property="article:author" content="田中蓮" />}

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:site" content="@tanaka_ren_fire" />
  <meta name="twitter:title" content={pageTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={absoluteImageUrl} />
  <meta name="twitter:image:alt" content={title} />

  <!-- フォント -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700;900&family=Noto+Serif+JP:wght@700;900&display=swap" rel="stylesheet" />

  <link rel="sitemap" href="/sitemap-index.xml" />

  {gaId && (
    <>
      <script async src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`}></script>
      <script define:vars={{ gaId }}>
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        gtag('js', new Date());
        gtag('config', gaId);
      </script>
    </>
  )}
</head>
<style is:global>
  /* ─── Design Tokens（記事ページ共通） ─── */
  :root {
    --ink:    #0A0A0A; --paper:  #F6F3EC;
    --navy:   #0B1942; --amber:  #B8780E;
    --amber-warm: #E8940F; --amber-pale: #FEF3D0;
    --gray:   #6B6560; --border: #D9D4CA;
    --cream:  #FBF8F2; --white:  #FFFFFF;
    --serif: "Noto Serif JP", "Hiragino Mincho ProN", serif;
    --sans:  "Noto Sans JP", "Hiragino Kaku Gothic ProN", sans-serif;
  }
  body { font-family: var(--sans); }

  /* ─── Announcement bar ─── */
  .bl-announce {
    background: var(--amber-pale);
    border-bottom: 1px solid #E8D4A0;
    padding: 8px 20px;
    font-size: 11.5px; color: #6B4A0A;
    text-align: center; font-weight: 500;
  }
  .bl-announce strong { color: var(--amber); }

  /* ─── Header ─── */
  .bl-header {
    background: var(--white);
    border-bottom: 3px solid var(--ink);
    position: sticky; top: 0; z-index: 60;
  }
  .bl-header-inner {
    max-width: 1080px; margin: 0 auto; padding: 0 28px;
    display: flex; align-items: center;
    justify-content: space-between; height: 58px;
  }
  .bl-brand {
    display: inline-flex; align-items: center; gap: 9px;
    border-right: 1px solid var(--border);
    padding-right: 20px; margin-right: 6px;
    text-decoration: none;
  }
  .bl-brand-text {
    font-family: var(--serif);
    font-weight: 700; font-size: 15px;
    color: var(--ink); letter-spacing: .03em; white-space: nowrap;
  }
  .bl-nav { display: flex; gap: 22px; }
  .bl-nav a {
    font-size: 13px; font-weight: 500;
    color: var(--ink); opacity: .75;
    text-decoration: none; transition: opacity .15s;
  }
  .bl-nav a:hover { opacity: 1; }
  .bl-header-right {
    display: flex; flex-direction: column;
    align-items: flex-end; line-height: 1.25;
  }
  .bl-header-pr { font-size: 10px; color: var(--gray); letter-spacing: .05em; }
  .bl-header-about { font-size: 11px; color: var(--amber); font-weight: 600; }

  /* ─── Main content ─── */
  .bl-main { max-width: 800px; margin: 0 auto; padding: 2rem 1.5rem 3rem; }

  /* ─── Footer ─── */
  .bl-footer {
    background: #0F1A3A; color: #C7D2FE;
    padding: 36px 28px 20px; text-align: center; font-size: 12px;
  }
  .bl-footer-brand {
    display: inline-flex; align-items: center; gap: 8px;
    color: #fff; font-family: var(--serif); font-weight: 700; font-size: 14px;
    margin-bottom: 12px;
  }
  .bl-footer-nav {
    display: flex; gap: 18px; justify-content: center;
    margin: 10px 0; flex-wrap: wrap;
  }
  .bl-footer-nav a { color: #C7D2FE; font-size: 12px; text-decoration: none; }
  .bl-footer-nav a:hover { color: #fff; }
  .bl-footer-copy { color: #9CA3AF; font-size: 11px; margin-top: 8px; }

  @media (max-width: 640px) {
    .bl-nav { display: none; }
    .bl-header-right { display: none; }
    .bl-brand-text { font-size: 13px; }
  }
</style>

<body>
  <!-- Announcement bar -->
  <div class="bl-announce">
    <strong>【PR】</strong> 当サイトはアフィリエイト広告を含みます。掲載情報は作成時点のものです。
  </div>

  <!-- Header -->
  <header class="bl-header">
    <div class="bl-header-inner">
      <a class="bl-brand" href="/">
        <!-- Bar-chart + trend logo -->
        <svg width="26" height="26" viewBox="0 0 40 40" fill="none" aria-hidden="true">
          <rect x="4"  y="22" width="6" height="14" rx="1" fill="#0B1942"/>
          <rect x="13" y="16" width="6" height="20" rx="1" fill="#0B1942"/>
          <rect x="22" y="10" width="6" height="26" rx="1" fill="#0B1942"/>
          <path d="M6 22 L16 14 L24 18 L36 6" stroke="#B8780E" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M30 6 L36 6 L36 12" stroke="#B8780E" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <span class="bl-brand-text">田中蓮のマネーブログ</span>
      </a>
      <nav class="bl-nav">
        <a href="/#articles">記事一覧</a>
        <a href="/#themes">テーマ</a>
        <a href="/#reasons">このブログについて</a>
        <a href="/#faq">よくある質問</a>
      </nav>
    </div>
  </header>

  <!-- Main content -->
  <main class="bl-main">
    <slot />
  </main>

  <!-- Footer -->
  <footer class="bl-footer">
    <div class="bl-footer-brand">
      <svg width="20" height="20" viewBox="0 0 40 40" fill="none" aria-hidden="true">
        <rect x="4"  y="22" width="6" height="14" rx="1" fill="#fff"/>
        <rect x="13" y="16" width="6" height="20" rx="1" fill="#fff"/>
        <rect x="22" y="10" width="6" height="26" rx="1" fill="#fff"/>
        <path d="M6 22 L16 14 L24 18 L36 6" stroke="#E8940F" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
        <path d="M30 6 L36 6 L36 12" stroke="#E8940F" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      田中蓮のマネーブログ
    </div>
    <p style="font-size:10px;color:#9CA3AF;margin-bottom:10px;letter-spacing:.06em;">PR・アフィリエイト広告を含みます</p>
    <nav class="bl-footer-nav">
      <a href="/about">運営者情報</a>
      <a href="/privacy">プライバシーポリシー</a>
      <a href="/disclaimer">免責事項</a>
      <a href="/tokushoho">特定商取引法に基づく表示</a>
      <a href="/about">このブログについて</a>
    </nav>
    <p class="bl-footer-copy">© 2025 田中蓮のマネーブログ. All rights reserved.</p>
  </footer>
</body>
</html>
