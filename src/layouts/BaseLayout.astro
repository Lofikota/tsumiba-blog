---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  image?: string;
  article?: boolean;
  pubDate?: Date;
  updatedDate?: Date;
}

const { title, description, image = '/og-default.jpg', article = false, pubDate, updatedDate } = Astro.props;
const siteUrl = 'https://ren-money.com';
const canonicalUrl = new URL(Astro.url.pathname, siteUrl);
const siteName = '田中蓮のマネーブログ';
const pageTitle = title.includes(siteName) ? title : `${title} | ${siteName}`;
const absoluteImageUrl = new URL(image, siteUrl);
---

<!doctype html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{pageTitle}</title>
  <meta name="description" content={description} />
  <meta name="robots" content="index,follow,max-image-preview:large" />
  <meta name="referrer" content="strict-origin-when-cross-origin" />
  <meta name="theme-color" content="#2563eb" />
  <link rel="canonical" href={canonicalUrl} />
  <link rel="alternate" type="application/rss+xml" title={`${siteName} RSS`} href={new URL('/rss.xml', siteUrl)} />

  <!-- OGP -->
  <meta property="og:type" content={article ? 'article' : 'website'} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:title" content={pageTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={absoluteImageUrl} />
  <meta property="og:image:alt" content={title} />
  <meta property="og:site_name" content={siteName} />
  <meta property="og:locale" content="ja_JP" />
  {article && pubDate && <meta property="article:published_time" content={pubDate.toISOString()} />}
  {article && updatedDate && <meta property="article:modified_time" content={updatedDate.toISOString()} />}
  {article && <meta property="article:author" content="田中蓮" />}

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:site" content="@tanaka_ren_fire" />
  <meta name="twitter:title" content={pageTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={absoluteImageUrl} />
  <meta name="twitter:image:alt" content={title} />

  <!-- フォント -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;700&display=swap" rel="stylesheet" />

  <link rel="sitemap" href="/sitemap-index.xml" />
</head>
<body>
  <header style="background:white;border-bottom:1px solid var(--color-border);padding:0.75rem 1rem;">
    <div style="max-width:800px;margin:0 auto;display:flex;align-items:center;justify-content:space-between;">
      <a href="/" style="font-weight:700;font-size:1.1rem;color:var(--color-text);">
        田中蓮のマネーブログ
      </a>
      <nav style="display:flex;gap:1.25rem;font-size:0.9rem;">
        <a href="/blog/category/nisa">NISA</a>
        <a href="/blog/category/fukugyo">副業</a>
        <a href="/blog/category/otoku">お得情報</a>
      </nav>
    </div>
  </header>

  <main style="max-width:800px;margin:0 auto;padding:1.5rem 1rem;">
    <slot />
  </main>

  <footer style="border-top:1px solid var(--color-border);padding:2rem 1rem;text-align:center;font-size:0.8rem;color:var(--color-text-muted);margin-top:3rem;">
    <p>当サイトはアフィリエイト広告を利用しています。</p>
    <p style="margin-top:0.5rem;">© 2024 田中蓮のマネーブログ</p>
    <nav style="margin-top:0.75rem;display:flex;gap:1rem;justify-content:center;">
      <a href="/privacy">プライバシーポリシー</a>
      <a href="/disclaimer">免責事項</a>
      <a href="/about">このブログについて</a>
    </nav>
  </footer>
</body>
</html>
