---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  image?: string;
  article?: boolean;
  pubDate?: Date;
  updatedDate?: Date;
  robots?: string;
  wide?: boolean;
  commercial?: boolean;
}

const {
  title,
  description,
  image = '/og-default.svg',
  article = false,
  pubDate,
  updatedDate,
  robots = 'index,follow,max-image-preview:large',
  wide = false,
  commercial = false,
} = Astro.props;
const siteUrl = 'https://tsumiba.com';
const canonicalUrl = new URL(Astro.url.pathname, siteUrl);
const siteName = 'tsumiba';
const pageTitle = title.includes(siteName) ? title : `${title} | ${siteName}`;
const absoluteImageUrl = new URL(image, siteUrl);
const googleTagId = import.meta.env.PUBLIC_GOOGLE_TAG_ID ?? import.meta.env.PUBLIC_GA_ID ?? 'AW-17326430733';
const googleAdsConversionSendTo = import.meta.env.PUBLIC_GOOGLE_ADS_CONVERSION_SEND_TO ?? '';
---

<!doctype html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{pageTitle}</title>
  <meta name="description" content={description} />
  <meta name="robots" content={robots} />
  <meta name="referrer" content="strict-origin-when-cross-origin" />
  <meta name="theme-color" content="#ffffff" />
  <link rel="canonical" href={canonicalUrl} />
  <link rel="alternate" type="application/rss+xml" title={`${siteName} RSS`} href={new URL('/rss.xml', siteUrl)} />

  <!-- OGP -->
  <meta property="og:type" content={article ? 'article' : 'website'} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:title" content={pageTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={absoluteImageUrl} />
  <meta property="og:image:alt" content={title} />
  <meta property="og:site_name" content={siteName} />
  <meta property="og:locale" content="ja_JP" />
  {article && pubDate && <meta property="article:published_time" content={pubDate.toISOString()} />}
  {article && updatedDate && <meta property="article:modified_time" content={updatedDate.toISOString()} />}
  {article && <meta property="article:author" content="tsumiba編集部" />}

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={pageTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={absoluteImageUrl} />
  <meta name="twitter:image:alt" content={title} />

  <!-- フォント -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700;900&family=Noto+Serif+JP:wght@700;900&display=swap" rel="stylesheet" />

  <link rel="sitemap" href="/sitemap-index.xml" />

  {googleTagId && (
    <>
      <script async src={`https://www.googletagmanager.com/gtag/js?id=${googleTagId}`}></script>
      <script define:vars={{ googleTagId, googleAdsConversionSendTo, article, commercial }}>
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        window.gtag = window.gtag || gtag;
        gtag('js', new Date());
        gtag('config', googleTagId);

        if (article) {
          var articleSlug = window.location.pathname.replace(/^\/blog\//, '').replace(/\/$/, '');
          gtag('event', 'article_view', {
            event_category: 'content',
            event_label: articleSlug,
            page_path: window.location.pathname,
            is_commercial: commercial ? 'true' : 'false',
          });
        }

        document.addEventListener('click', (event) => {
          const target = event.target;
          if (!(target instanceof Element)) return;
          const anchor = target.closest('a[data-google-event]');
          if (!anchor) return;
          const eventName = anchor.getAttribute('data-google-event') || 'click';
          const label = anchor.getAttribute('data-google-label') || anchor.textContent?.trim().replace(/\s+/g, ' ').slice(0, 80) || '';
          window.gtag('event', eventName, {
            event_category: anchor.getAttribute('data-google-category') || 'engagement',
            event_label: label,
            link_url: anchor.getAttribute('href') || '',
            page_path: window.location.pathname,
          });
          if (googleAdsConversionSendTo && ['affiliate_click', 'line_click', 'line_add_click'].includes(eventName)) {
            window.gtag('event', 'conversion', {
              send_to: googleAdsConversionSendTo,
              event_category: anchor.getAttribute('data-google-category') || 'engagement',
              event_label: label,
              link_url: anchor.getAttribute('href') || '',
              page_path: window.location.pathname,
            });
          }
        }, true);
      </script>
    </>
  )}
</head>
<style is:global>
  /* ─── Design Tokens（tsumiba：紺#1B3A5B 主 / 琥珀#E0A458 CTAのみ） ─── */
  :root {
    --ink:    #1F2937; --paper:  #ffffff;
    --navy:   #1B3A5B; --amber:  #E0A458;
    --amber-warm: #E0A458; --amber-pale: #F8F9FA;
    --green: #1B3A5B; --green-soft: #F8F9FA;
    --gray:   #6b7280; --border: #e5e7eb;
    --cream:  #ffffff; --white:  #FFFFFF;
    --serif: "Noto Serif JP", "Hiragino Mincho ProN", serif;
    --sans:  "Noto Sans JP", "Hiragino Kaku Gothic ProN", sans-serif;
  }
  body { font-family: var(--sans); }

  /* ─── Announcement bar ─── */
  .bl-announce {
    background: var(--amber-pale);
    border-top: 1px solid var(--border);
    padding: 8px 20px;
    font-size: 11.5px; color: #6b7280;
    text-align: center; font-weight: 500;
  }
  .bl-announce strong { color: var(--navy); }

  /* ─── Header ─── */
  .bl-header {
    background: rgba(255,255,255,.96);
    border-bottom: 1px solid var(--border);
    position: sticky; top: 0; z-index: 60;
    backdrop-filter: blur(10px);
  }
  .bl-header-inner {
    max-width: 1080px; margin: 0 auto; padding: 0 28px;
    display: flex; align-items: center;
    justify-content: space-between; height: 58px;
  }
  .bl-brand {
    display: inline-flex; align-items: center; gap: 9px;
    padding-right: 20px; margin-right: 6px;
    text-decoration: none;
  }
  .bl-brand-text {
    font-family: var(--sans);
    font-weight: 700; font-size: 18px;
    color: var(--navy); letter-spacing: .01em; white-space: nowrap;
  }
  .bl-brand-cat {
    font-size: 12px; font-weight: 500; color: var(--gray);
    border-left: 1px solid var(--border);
    padding-left: 8px; margin-left: 2px;
  }
  .bl-nav { display: flex; gap: 22px; }
  .bl-nav a {
    font-size: 13px; font-weight: 500;
    color: var(--ink); opacity: .75;
    text-decoration: none; transition: opacity .15s;
  }
  .bl-nav a:hover { opacity: 1; color: var(--green); text-decoration: none; }
  .bl-header-right {
    display: flex; flex-direction: column;
    align-items: flex-end; line-height: 1.25;
  }
  .bl-header-pr { font-size: 10px; color: var(--gray); letter-spacing: .05em; }
  .bl-header-about { font-size: 11px; color: var(--green); font-weight: 600; }

  /* ─── Main content ─── */
  .bl-main { max-width: 800px; margin: 0 auto; padding: 2rem 1.5rem 3rem; }
  .bl-main-wide { max-width: 1180px; }

  /* ─── Footer ─── */
  .bl-footer {
    background: var(--navy); color: #cdd6e0;
    padding: 36px 28px 20px; text-align: center; font-size: 12px;
  }
  .bl-footer-brand {
    display: inline-flex; align-items: center; gap: 8px;
    color: #fff; font-family: var(--sans); font-weight: 700; font-size: 15px;
    margin-bottom: 12px;
  }
  .bl-footer-nav {
    display: flex; gap: 18px; justify-content: center;
    margin: 10px 0; flex-wrap: wrap;
  }
  .bl-footer-nav a { color: #d1d5db; font-size: 12px; text-decoration: none; }
  .bl-footer-nav a:hover { color: #fff; }
  .bl-footer-risk { max-width: 760px; margin: 14px auto 0; color: #8a93a0; font-size: 11px; line-height: 1.7; text-align: left; }
  .bl-footer-copy { color: #9CA3AF; font-size: 11px; margin-top: 10px; }

  @media (max-width: 640px) {
    .bl-nav { display: none; }
    .bl-header-right { display: none; }
    .bl-brand-text { font-size: 13px; }
  }
</style>

<body>
  <!-- Header -->
  <header class="bl-header">
    <div class="bl-header-inner">
      <a class="bl-brand" href="/">
        <!-- tsumiba ロゴ：3段積みブロック -->
        <svg width="28" height="28" viewBox="0 0 40 40" fill="none" aria-hidden="true">
          <rect x="6"  y="26" width="28" height="7" rx="1.5" fill="#1B3A5B"/>
          <rect x="10" y="17" width="20" height="7" rx="1.5" fill="#1B3A5B"/>
          <rect x="14" y="8"  width="12" height="7" rx="1.5" fill="#1B3A5B"/>
        </svg>
        <span class="bl-brand-text">tsumiba</span>
        <span class="bl-brand-cat">FX</span>
      </a>
      <!-- 学習順序型ナビ（リベ大型 原則3: はじめての方へ→全体像→口座を選ぶ） -->
      <nav class="bl-nav">
        <a href="/start/">はじめての方へ</a>
        <a href="/blog/fx-shoshinsha-guide/">FXの全体像</a>
        <a href="/blog/fx-kouza-hikaku/">口座を選ぶ</a>
        <a href="/blog/category/fuyasu/">増やす</a>
        <a href="/line/x-profile-main/">LINE</a>
      </nav>
    </div>
  </header>

  <!-- Main content -->
  <main class:list={['bl-main', wide && 'bl-main-wide']}>
    <slot />
  </main>

  <!-- Footer -->
  <footer class="bl-footer">
    <div class="bl-footer-brand">
      <svg width="22" height="22" viewBox="0 0 40 40" fill="none" aria-hidden="true">
        <rect x="6"  y="26" width="28" height="7" rx="1.5" fill="#fff"/>
        <rect x="10" y="17" width="20" height="7" rx="1.5" fill="#fff"/>
        <rect x="14" y="8"  width="12" height="7" rx="1.5" fill="#fff"/>
      </svg>
      tsumiba ｜ FX
    </div>
    <p style="font-size:10px;color:#9CA3AF;margin-bottom:10px;letter-spacing:.06em;">PR・アフィリエイト広告を含みます</p>
    <nav class="bl-footer-nav">
      <a href="/about">運営者情報</a>
      <a href="/privacy">プライバシーポリシー</a>
      <a href="/disclaimer">免責事項</a>
      <a href="/tokushoho">特定商取引法に基づく表示</a>
      <a href="/about">このブログについて</a>
    </nav>
    <p class="bl-footer-risk">FXは元本保証のない金融商品です。レバレッジにより、預け入れた資金を上回る損失が発生する可能性があります。取引にあたっては各社の契約締結前交付書面・公式サイトの最新情報を必ずご確認のうえ、ご自身の判断と責任で行ってください。</p>
    <p class="bl-footer-copy">© 2025 {siteName}. All rights reserved.</p>
  </footer>

  <!-- Announcement bar -->
  <div class="bl-announce">
    <strong>【PR】</strong> 当サイトはアフィリエイト広告を含みます。掲載情報は作成時点のものです。
  </div>
</body>
</html>
